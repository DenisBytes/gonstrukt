#!/bin/bash
# Run all tests for {{.ProjectName}}
# This script starts test infrastructure, runs tests, and cleans up.
#
# Usage: ./scripts/run-tests.sh [test-args...]
# Example: ./scripts/run-tests.sh -v ./internals/services/...

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

cd "$PROJECT_ROOT"

{{- if .HasDockerTests}}

# Start test infrastructure
echo "Starting test infrastructure..."
docker compose -f docker-compose.test.yml up -d --wait

# Get dynamic ports
{{- if eq .Database "postgres"}}
POSTGRES_PORT=$(docker compose -f docker-compose.test.yml port postgres 5432 | cut -d: -f2)
export TEST_DATABASE_URL="postgres://postgres:postgres@localhost:$POSTGRES_PORT/test_db?sslmode=disable"
echo "  PostgreSQL: localhost:$POSTGRES_PORT"
{{- end}}

{{- if eq .Database "mysql"}}
MYSQL_PORT=$(docker compose -f docker-compose.test.yml port mysql 3306 | cut -d: -f2)
export TEST_DATABASE_URL="root:root@tcp(localhost:$MYSQL_PORT)/test_db?parseTime=true"
echo "  MySQL: localhost:$MYSQL_PORT"
{{- end}}

{{- if eq .Database "sqlite"}}
export TEST_DATABASE_URL=":memory:"
echo "  SQLite: in-memory"
{{- end}}

{{- if eq .CacheType "redis"}}
REDIS_PORT=$(docker compose -f docker-compose.test.yml port redis 6379 | cut -d: -f2)
export TEST_REDIS_ADDR="localhost:$REDIS_PORT"
echo "  Redis: localhost:$REDIS_PORT"
{{- end}}

{{- if eq .CacheType "valkey"}}
VALKEY_PORT=$(docker compose -f docker-compose.test.yml port valkey 6379 | cut -d: -f2)
export TEST_VALKEY_ADDR="localhost:$VALKEY_PORT"
echo "  Valkey: localhost:$VALKEY_PORT"
{{- end}}

{{- if eq .Database "mongodb"}}
MONGO_PORT=$(docker compose -f docker-compose.test.yml port mongodb 27017 | cut -d: -f2)
export TEST_MONGODB_URL="mongodb://localhost:$MONGO_PORT"
echo "  MongoDB: localhost:$MONGO_PORT"
{{- end}}
{{- end}}

# Cleanup function
cleanup() {
{{- if .HasDockerTests}}
    echo ""
    echo "Stopping test infrastructure..."
    docker compose -f docker-compose.test.yml down -v
{{- end}}
}
trap cleanup EXIT

# Run backend tests
echo ""
echo "Running backend tests..."
{{- if eq .ServiceType "both"}}
if [ $# -eq 0 ]; then
    cd services/gateway && go test -v -race ./... && cd "$PROJECT_ROOT"
    cd services/auth_service && go test -v -race ./... && cd "$PROJECT_ROOT"
else
    cd services/gateway && go test -v -race "$@" && cd "$PROJECT_ROOT"
    cd services/auth_service && go test -v -race "$@" && cd "$PROJECT_ROOT"
fi
{{- else}}
if [ $# -eq 0 ]; then
    go test -v -race ./...
else
    go test -v -race "$@"
fi
{{- end}}

{{- if .HasFrontend}}

# Run frontend tests
if [ -d "frontend" ]; then
    echo ""
    echo "Running frontend unit tests..."
    cd frontend
    npm test -- --run

{{- if or .HasCypress .HasPlaywright}}
    echo ""
    echo "Running E2E tests..."

    # Start the backend in background
    cd "$PROJECT_ROOT"
    go run ./cmd/*/main.go &
    BACKEND_PID=$!
    sleep 3

    # Start frontend dev server
    cd frontend
    npm run dev &
    FRONTEND_PID=$!
    sleep 5

    # Run E2E tests
    npm run test:e2e

    # Stop servers
    kill $FRONTEND_PID 2>/dev/null || true
    kill $BACKEND_PID 2>/dev/null || true

    cd "$PROJECT_ROOT"
{{- end}}
fi
{{- end}}

echo ""
echo "All tests passed!"
