// GetActiveConsentsByUserID retrieves all active consents for a user
func (c *ArangoClient) GetActiveConsentsByUserID(ctx context.Context, userID string) ([]*types.Consent, error) {
	query := `
		FOR c IN consents
		FILTER c.user_id == @userID
		AND c.granted == true
		AND c.revoked_at == null
		AND (c.expires_at == null OR c.expires_at > DATE_NOW())
		SORT c.granted_at DESC
		RETURN c
	`
	cursor, err := c.queryWithBindVars(ctx, query, map[string]interface{}{"userID": userID})
	if err != nil {
		return nil, err
	}
	defer cursor.Close()

	var consents []*types.Consent
	for cursor.HasMore() {
		consent := &types.Consent{}
		_, err := cursor.ReadDocument(ctx, consent)
		if err != nil {
			return nil, err
		}
		consents = append(consents, consent)
	}
	return consents, nil
}

// GetConsentHistory retrieves the full consent history for a user
func (c *ArangoClient) GetConsentHistory(ctx context.Context, userID string) ([]*types.Consent, error) {
	return c.GetUserConsents(ctx, userID)
}
