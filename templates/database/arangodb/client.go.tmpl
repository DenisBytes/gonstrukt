// ArangoClient implements the Database interface for ArangoDB
type ArangoClient struct {
	client   arangodb.Client
	database arangodb.Database
}

// NewArangoClient creates a new ArangoDB client
func NewArangoClient(ctx context.Context, endpoint, dbName string) (*ArangoClient, error) {
	endpoints := connection.NewRoundRobinEndpoints([]string{endpoint})
	conn := connection.NewHttp2Connection(connection.Http2Configuration{
		Endpoint: endpoints,
	})

	client := arangodb.NewClient(conn)

	// Get or create database
	exists, err := client.DatabaseExists(ctx, dbName)
	if err != nil {
		return nil, fmt.Errorf("failed to check database: %w", err)
	}

	var database arangodb.Database
	if !exists {
		database, err = client.CreateDatabase(ctx, dbName, nil)
	} else {
		database, err = client.Database(ctx, dbName)
	}
	if err != nil {
		return nil, fmt.Errorf("failed to get/create database: %w", err)
	}

	return &ArangoClient{
		client:   client,
		database: database,
	}, nil
}

// Migrate creates collections and indexes
func (c *ArangoClient) Migrate(ctx context.Context) error {
	collections := []string{"users", "sessions", "consents", "mfa_backups"}

	for _, name := range collections {
		exists, err := c.database.CollectionExists(ctx, name)
		if err != nil {
			return err
		}
		if !exists {
			_, err = c.database.CreateCollection(ctx, name, nil)
			if err != nil {
				return err
			}
		}
	}

	// Create indexes
	uniqueTrue := true
	usersCol, _ := c.database.Collection(ctx, "users")
	usersCol.EnsurePersistentIndex(ctx, []string{"email"}, &arangodb.CreatePersistentIndexOptions{Unique: &uniqueTrue})

	sessionsCol, _ := c.database.Collection(ctx, "sessions")
	sessionsCol.EnsurePersistentIndex(ctx, []string{"user_id"}, nil)
	sessionsCol.EnsurePersistentIndex(ctx, []string{"refresh_token"}, &arangodb.CreatePersistentIndexOptions{Unique: &uniqueTrue})

	consentsCol, _ := c.database.Collection(ctx, "consents")
	consentsCol.EnsurePersistentIndex(ctx, []string{"user_id"}, nil)

	mfaCol, _ := c.database.Collection(ctx, "mfa_backups")
	mfaCol.EnsurePersistentIndex(ctx, []string{"user_id"}, nil)

	return nil
}

// Ping checks the database connection
func (c *ArangoClient) Ping(ctx context.Context) error {
	_, err := c.client.Version(ctx)
	return err
}

// Close closes the database connection
func (c *ArangoClient) Close(ctx context.Context) error {
	return nil // ArangoDB HTTP/2 connections don't require explicit close
}

// queryWithBindVars executes a query with bind variables
func (c *ArangoClient) queryWithBindVars(ctx context.Context, query string, bindVars map[string]interface{}) (arangodb.Cursor, error) {
	return c.database.Query(ctx, query, &arangodb.QueryOptions{BindVars: bindVars})
}

// User operations
func (c *ArangoClient) CreateUser(ctx context.Context, user *types.User) error {
	col, _ := c.database.Collection(ctx, "users")
	_, err := col.CreateDocument(ctx, user)
	return err
}

func (c *ArangoClient) GetUserByID(ctx context.Context, id string) (*types.User, error) {
	query := "FOR u IN users FILTER u._key == @id AND u.deleted_at == null RETURN u"
	cursor, err := c.queryWithBindVars(ctx, query, map[string]interface{}{"id": id})
	if err != nil {
		return nil, err
	}
	defer cursor.Close()

	user := &types.User{}
	if cursor.HasMore() {
		_, err = cursor.ReadDocument(ctx, user)
		return user, err
	}
	return nil, errors.New("user not found")
}

func (c *ArangoClient) GetUserByEmail(ctx context.Context, email string) (*types.User, error) {
	query := "FOR u IN users FILTER u.email == @email AND u.deleted_at == null RETURN u"
	cursor, err := c.queryWithBindVars(ctx, query, map[string]interface{}{"email": email})
	if err != nil {
		return nil, err
	}
	defer cursor.Close()

	user := &types.User{}
	if cursor.HasMore() {
		_, err = cursor.ReadDocument(ctx, user)
		return user, err
	}
	return nil, errors.New("user not found")
}

func (c *ArangoClient) UpdateUser(ctx context.Context, user *types.User) error {
	user.UpdatedAt = time.Now()
	col, _ := c.database.Collection(ctx, "users")
	_, err := col.UpdateDocument(ctx, user.ID, user)
	return err
}

func (c *ArangoClient) DeleteUser(ctx context.Context, id string) error {
	now := time.Now()
	query := "UPDATE @id WITH { deleted_at: @now } IN users"
	_, err := c.queryWithBindVars(ctx, query, map[string]interface{}{"id": id, "now": now})
	return err
}

