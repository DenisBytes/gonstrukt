{{- if .HasGDPRDataDeletion}}

// SoftDeleteUser performs a GDPR-compliant soft delete by anonymizing PII
func (c *ArangoClient) SoftDeleteUser(ctx context.Context, id string) error {
	now := time.Now()
	anonymizedEmail := fmt.Sprintf("deleted_%s@anonymized.local", id)

	query := `
		UPDATE @id WITH {
			email: @email,
			first_name: "DELETED",
			last_name: "USER",
			password_hash: "",
			mfa_enabled: false,
			mfa_secret: "",
			deleted_at: @now,
			updated_at: @now
		} IN users
	`
	_, err := c.queryWithBindVars(ctx, query, map[string]interface{}{
		"id":    id,
		"email": anonymizedEmail,
		"now":   now,
	})
	if err != nil {
		return err
	}

	// Delete sessions and MFA backups
	c.queryWithBindVars(ctx, "FOR s IN sessions FILTER s.user_id == @id REMOVE s IN sessions", map[string]interface{}{"id": id})
	c.queryWithBindVars(ctx, "FOR b IN mfa_backups FILTER b.user_id == @id REMOVE b IN mfa_backups", map[string]interface{}{"id": id})
	return nil
}
{{- end}}

{{- if .HasGDPRDataExport}}

// ExportUserData exports all user data for GDPR data portability
func (c *ArangoClient) ExportUserData(ctx context.Context, userID string) (*types.UserDataExport, error) {
	user, err := c.GetUserByID(ctx, userID)
	if err != nil {
		return nil, err
	}

	sessions, err := c.GetUserSessions(ctx, userID)
	if err != nil {
		return nil, err
	}

	consents, err := c.GetUserConsents(ctx, userID)
	if err != nil {
		return nil, err
	}

	userExport := types.UserExportData{
		ID:        user.ID,
		Email:     user.Email,
		FirstName: user.FirstName,
		LastName:  user.LastName,
		CreatedAt: user.CreatedAt,
		UpdatedAt: user.UpdatedAt,
	}

	sessionExports := make([]types.SessionExportData, len(sessions))
	for i, s := range sessions {
		sessionExports[i] = types.SessionExportData{
			ID:        s.ID,
			UserAgent: s.UserAgent,
			IP:        s.IP,
			CreatedAt: s.CreatedAt,
			ExpiresAt: s.ExpiresAt,
		}
	}

	consentExports := make([]types.ConsentExportData, len(consents))
	for i, consent := range consents {
		consentExports[i] = types.ConsentExportData{
			Type:      consent.Type,
			Granted:   consent.Granted,
			Version:   consent.Version,
			GrantedAt: consent.GrantedAt,
			RevokedAt: consent.RevokedAt,
		}
	}

	return &types.UserDataExport{
		ExportedAt: time.Now(),
		User:       userExport,
		Sessions:   sessionExports,
		Consents:   consentExports,
	}, nil
}
{{- end}}

{{- if .HasOAuth}}

// GetUserByOAuthID retrieves a user by OAuth provider and ID
func (c *ArangoClient) GetUserByOAuthID(ctx context.Context, provider, oauthID string) (*types.User, error) {
	query := `
		FOR oa IN oauth_accounts
		FILTER oa.provider == @provider AND oa.provider_id == @oauthID
		FOR u IN users
		FILTER u._key == oa.user_id AND u.deleted_at == null
		RETURN u
	`
	cursor, err := c.queryWithBindVars(ctx, query, map[string]interface{}{
		"provider": provider,
		"oauthID":  oauthID,
	})
	if err != nil {
		return nil, err
	}
	defer cursor.Close()

	user := &types.User{}
	if cursor.HasMore() {
		_, err = cursor.ReadDocument(ctx, user)
		return user, err
	}
	return nil, errors.New("user not found")
}
