// GetBackupCode retrieves a backup code by user ID and hashed code
func (c *ArangoClient) GetBackupCode(ctx context.Context, userID, hashedCode string) (*types.MFABackup, error) {
	query := "FOR b IN mfa_backups FILTER b.user_id == @userID AND b.code == @code RETURN b"
	cursor, err := c.queryWithBindVars(ctx, query, map[string]interface{}{"userID": userID, "code": hashedCode})
	if err != nil {
		return nil, err
	}
	defer cursor.Close()

	backup := &types.MFABackup{}
	if cursor.HasMore() {
		_, err = cursor.ReadDocument(ctx, backup)
		return backup, err
	}
	return nil, errors.New("backup code not found")
}

// UpdateBackupCode updates an MFA backup code
func (c *ArangoClient) UpdateBackupCode(ctx context.Context, backup *types.MFABackup) error {
	col, _ := c.database.Collection(ctx, "mfa_backups")
	_, err := col.UpdateDocument(ctx, backup.ID, map[string]interface{}{
		"used":    backup.Used,
		"used_at": backup.UsedAt,
	})
	return err
}

// DeleteBackupCodes deletes all MFA backup codes for a user
func (c *ArangoClient) DeleteBackupCodes(ctx context.Context, userID string) error {
	return c.DeleteMFABackups(ctx, userID)
}
