// UpdateTenant updates an existing tenant
func (c *PostgresClient) UpdateTenant(ctx context.Context, tenant *types.Tenant) error {
	tenant.UpdatedAt = time.Now()

	settings, err := json.Marshal(tenant.Settings)
	if err != nil {
		return err
	}

	result, err := c.pool.Exec(ctx, `
		UPDATE tenants
		SET name = $2, slug = $3, plan = $4, settings = $5, is_active = $6, updated_at = $7
		WHERE id = $1
	`,
		tenant.ID,
		tenant.Name,
		tenant.Slug,
		tenant.Plan,
		settings,
		tenant.IsActive,
		tenant.UpdatedAt,
	)
	if err != nil {
		return err
	}

	if result.RowsAffected() == 0 {
		return errors.New("tenant not found")
	}

	return nil
}

// DeleteTenant deletes a tenant
func (c *PostgresClient) DeleteTenant(ctx context.Context, id string) error {
	result, err := c.pool.Exec(ctx, `DELETE FROM tenants WHERE id = $1`, id)
	if err != nil {
		return err
	}

	if result.RowsAffected() == 0 {
		return errors.New("tenant not found")
	}

	return nil
}
