// GetActiveConsentsByUserID retrieves all active (not expired, not revoked) consents for a user
func (c *PostgresClient) GetActiveConsentsByUserID(ctx context.Context, userID string) ([]*types.Consent, error) {
	rows, err := c.pool.Query(ctx, `
		SELECT id, user_id, type, granted, granted_at, expires_at, revoked_at, version, description
		FROM consents
		WHERE user_id = $1 AND granted = true AND revoked_at IS NULL AND (expires_at IS NULL OR expires_at > NOW())
		ORDER BY granted_at DESC
	`, userID)
	if err != nil {
		return nil, err
	}
	defer rows.Close()

	var consents []*types.Consent
	for rows.Next() {
		consent := &types.Consent{}
		if err := rows.Scan(
			&consent.ID,
			&consent.UserID,
			&consent.Type,
			&consent.Granted,
			&consent.GrantedAt,
			&consent.ExpiresAt,
			&consent.RevokedAt,
			&consent.Version,
			&consent.Description,
		); err != nil {
			return nil, err
		}
		consents = append(consents, consent)
	}

	return consents, rows.Err()
}

// GetConsentHistory retrieves the full consent history for a user (for GDPR audit trail)
func (c *PostgresClient) GetConsentHistory(ctx context.Context, userID string) ([]*types.Consent, error) {
	return c.GetUserConsents(ctx, userID)
}
