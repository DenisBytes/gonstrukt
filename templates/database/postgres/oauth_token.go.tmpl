{{- if .HasOAuth}}
package db

import (
	"context"
	"time"

	"{{.ModuleName}}/internals/types"
)

// UpsertOAuthToken inserts or updates an OAuth token for a user/provider pair
func (c *PostgresClient) UpsertOAuthToken(ctx context.Context, token *types.OAuthToken) error {
	token.UpdatedAt = time.Now()
	if token.CreatedAt.IsZero() {
		token.CreatedAt = token.UpdatedAt
	}

	_, err := c.pool.Exec(ctx, `
		INSERT INTO oauth_tokens (id, user_id, provider, access_token, refresh_token, token_type, expires_at, created_at, updated_at)
		VALUES ($1, $2, $3, $4, $5, $6, $7, $8, $9)
		ON CONFLICT (user_id, provider) DO UPDATE SET
			access_token = EXCLUDED.access_token,
			refresh_token = EXCLUDED.refresh_token,
			token_type = EXCLUDED.token_type,
			expires_at = EXCLUDED.expires_at,
			updated_at = EXCLUDED.updated_at
	`,
		token.ID,
		token.UserID,
		token.Provider,
		token.AccessToken,
		token.RefreshToken,
		token.TokenType,
		token.ExpiresAt,
		token.CreatedAt,
		token.UpdatedAt,
	)
	return err
}

// GetOAuthTokensByUser retrieves all OAuth tokens for a user
func (c *PostgresClient) GetOAuthTokensByUser(ctx context.Context, userID string) ([]*types.OAuthToken, error) {
	rows, err := c.pool.Query(ctx, `
		SELECT id, user_id, provider, access_token, refresh_token, token_type, expires_at, created_at, updated_at
		FROM oauth_tokens
		WHERE user_id = $1
		ORDER BY created_at DESC
	`, userID)
	if err != nil {
		return nil, err
	}
	defer rows.Close()

	var tokens []*types.OAuthToken
	for rows.Next() {
		token := &types.OAuthToken{}
		if err := rows.Scan(
			&token.ID,
			&token.UserID,
			&token.Provider,
			&token.AccessToken,
			&token.RefreshToken,
			&token.TokenType,
			&token.ExpiresAt,
			&token.CreatedAt,
			&token.UpdatedAt,
		); err != nil {
			return nil, err
		}
		tokens = append(tokens, token)
	}

	return tokens, rows.Err()
}

// DeleteOAuthTokensByUser deletes all OAuth tokens for a user
func (c *PostgresClient) DeleteOAuthTokensByUser(ctx context.Context, userID string) error {
	_, err := c.pool.Exec(ctx, `DELETE FROM oauth_tokens WHERE user_id = $1`, userID)
	return err
}
{{- end}}
