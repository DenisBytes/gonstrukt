func TestPostgresClient_ExportUserData(t *testing.T) {
	db := mustGetTestDB(t)
	ctx := context.Background()

	t.Cleanup(func() {
		cleanupSessions(t)
		cleanupUsers(t)
	})

	// Create user with session and consent
	user := newTestUser("export@test.com")
	if err := db.CreateUser(ctx, user); err != nil {
		t.Fatalf("Failed to create test user: %v", err)
	}

	now := time.Now()
	session := &types.Session{
		ID:           uuid.New().String(),
		UserID:       user.ID,
		RefreshToken: "test-refresh-token-" + uuid.New().String(),
		UserAgent:    "Test Browser",
		IP:           "127.0.0.1",
		CreatedAt:    now,
		ExpiresAt:    now.Add(24 * time.Hour),
	}
	if err := db.CreateSession(ctx, session); err != nil {
		t.Fatalf("Failed to create test session: %v", err)
	}

	consent := &types.Consent{
		ID:        uuid.New().String(),
		UserID:    user.ID,
		Type:      "marketing",
		Granted:   true,
		Version:   "1.0",
		GrantedAt: now,
	}
	if err := db.CreateConsent(ctx, consent); err != nil {
		t.Fatalf("Failed to create test consent: %v", err)
	}

	// Export
	export, err := db.ExportUserData(ctx, user.ID)
	if err != nil {
		t.Fatalf("ExportUserData() error = %v", err)
	}

	if export.User.Email != user.Email {
		t.Errorf("ExportUserData() user email = %v, want %v", export.User.Email, user.Email)
	}
	if len(export.Sessions) != 1 {
		t.Errorf("ExportUserData() sessions count = %d, want 1", len(export.Sessions))
	}
	if len(export.Consents) != 1 {
		t.Errorf("ExportUserData() consents count = %d, want 1", len(export.Consents))
	}
