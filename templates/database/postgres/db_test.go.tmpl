func TestPostgresClient_SoftDeleteUser(t *testing.T) {
	db := mustGetTestDB(t)
	ctx := context.Background()

	t.Cleanup(func() {
		cleanupUsers(t)
	})

	// Create user with session
	user := newTestUser("softdelete@test.com")
	if err := db.CreateUser(ctx, user); err != nil {
		t.Fatalf("Failed to create test user: %v", err)
	}

	now := time.Now()
	session := &types.Session{
		ID:           uuid.New().String(),
		UserID:       user.ID,
		RefreshToken: "test-refresh-token-" + uuid.New().String(),
		UserAgent:    "Test Browser",
		IP:           "127.0.0.1",
		CreatedAt:    now,
		ExpiresAt:    now.Add(24 * time.Hour),
	}
	if err := db.CreateSession(ctx, session); err != nil {
		t.Fatalf("Failed to create test session: %v", err)
	}

	// Soft delete
	if err := db.SoftDeleteUser(ctx, user.ID); err != nil {
		t.Fatalf("SoftDeleteUser() error = %v", err)
	}

	// User should not be findable
	_, err := db.GetUserByID(ctx, user.ID)
	if err == nil {
		t.Error("GetUserByID() should return error for soft-deleted user")
	}

	// Sessions should be deleted
	sessions, _ := db.GetUserSessions(ctx, user.ID)
	if len(sessions) != 0 {
		t.Errorf("SoftDeleteUser() sessions count = %d, want 0", len(sessions))
	}
}
