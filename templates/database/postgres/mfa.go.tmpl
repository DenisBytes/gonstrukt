// CreateBackupCode creates a new MFA backup code (alias for CreateMFABackup)
func (c *PostgresClient) CreateBackupCode(ctx context.Context, backup *types.MFABackup) error {
	return c.CreateMFABackup(ctx, backup)
}

// GetBackupCode retrieves a backup code by user ID and hashed code
func (c *PostgresClient) GetBackupCode(ctx context.Context, userID, hashedCode string) (*types.MFABackup, error) {
	backup := &types.MFABackup{}
	err := c.pool.QueryRow(ctx, `
		SELECT id, user_id, code, used, used_at, created_at
		FROM mfa_backups
		WHERE user_id = $1 AND code = $2
	`, userID, hashedCode).Scan(
		&backup.ID,
		&backup.UserID,
		&backup.Code,
		&backup.Used,
		&backup.UsedAt,
		&backup.CreatedAt,
	)

	if err != nil {
		return nil, err
	}

	return backup, nil
}

// UpdateBackupCode updates an MFA backup code
func (c *PostgresClient) UpdateBackupCode(ctx context.Context, backup *types.MFABackup) error {
	_, err := c.pool.Exec(ctx, `
		UPDATE mfa_backups
		SET used = $2, used_at = $3
		WHERE id = $1
	`, backup.ID, backup.Used, backup.UsedAt)
	return err
}

// DeleteBackupCodes deletes all MFA backup codes for a user (alias for DeleteMFABackups)
func (c *PostgresClient) DeleteBackupCodes(ctx context.Context, userID string) error {
	return c.DeleteMFABackups(ctx, userID)
}
