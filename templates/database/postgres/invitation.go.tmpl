// GetInvitationsByEmail retrieves all pending invitations for an email
func (c *PostgresClient) GetInvitationsByEmail(ctx context.Context, email string) ([]*types.Invitation, error) {
	rows, err := c.pool.Query(ctx, `
		SELECT i.id, i.tenant_id, i.email, i.role, i.status, i.invited_by, i.token, i.expires_at, i.created_at, i.accepted_at, i.revoked_at
		FROM invitations i
		WHERE i.email = $1 AND i.status = 'pending' AND i.expires_at > NOW()
		ORDER BY i.created_at DESC
	`, email)
	if err != nil {
		return nil, err
	}
	defer rows.Close()

	var invitations []*types.Invitation
	for rows.Next() {
		inv := &types.Invitation{}
		if err := rows.Scan(
			&inv.ID,
			&inv.TenantID,
			&inv.Email,
			&inv.Role,
			&inv.Status,
			&inv.InvitedBy,
			&inv.Token,
			&inv.ExpiresAt,
			&inv.CreatedAt,
			&inv.AcceptedAt,
			&inv.RevokedAt,
		); err != nil {
			return nil, err
		}
		invitations = append(invitations, inv)
	}

	return invitations, rows.Err()
}

// GetInvitationsByTenant retrieves all invitations for a tenant
func (c *PostgresClient) GetInvitationsByTenant(ctx context.Context, tenantID string) ([]*types.Invitation, error) {
	rows, err := c.pool.Query(ctx, `
		SELECT id, tenant_id, email, role, status, invited_by, token, expires_at, created_at, accepted_at, revoked_at
		FROM invitations
		WHERE tenant_id = $1
		ORDER BY created_at DESC
	`, tenantID)
	if err != nil {
		return nil, err
	}
	defer rows.Close()

	var invitations []*types.Invitation
	for rows.Next() {
		inv := &types.Invitation{}
