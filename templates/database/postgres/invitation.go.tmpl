}

// UpdateInvitationStatus updates an invitation's status
func (c *PostgresClient) UpdateInvitationStatus(ctx context.Context, id, status string) error {
	now := time.Now()
	var query string
	var args []interface{}

	switch status {
	case "accepted":
		query = `UPDATE invitations SET status = $2, accepted_at = $3 WHERE id = $1`
		args = []interface{}{id, status, now}
	case "revoked":
		query = `UPDATE invitations SET status = $2, revoked_at = $3 WHERE id = $1`
		args = []interface{}{id, status, now}
	default:
		query = `UPDATE invitations SET status = $2 WHERE id = $1`
		args = []interface{}{id, status}
	}

	result, err := c.pool.Exec(ctx, query, args...)
	if err != nil {
		return err
	}

	if result.RowsAffected() == 0 {
		return errors.New("invitation not found")
	}

	return nil
}

// UpdateInvitationToken updates the token and expiry for an invitation (for resend)
func (c *PostgresClient) UpdateInvitationToken(ctx context.Context, id, token string, expiresAt time.Time) error {
	result, err := c.pool.Exec(ctx, `
		UPDATE invitations SET token = $2, expires_at = $3
		WHERE id = $1 AND status = 'pending'
	`, id, token, expiresAt)
	if err != nil {
		return err
	}

	if result.RowsAffected() == 0 {
		return errors.New("invitation not found or not pending")
	}

	return nil
}
