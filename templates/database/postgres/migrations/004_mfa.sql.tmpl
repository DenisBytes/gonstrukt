-- Create MFA backup codes table
CREATE TABLE IF NOT EXISTS mfa_backups (
    id UUID PRIMARY KEY,
    user_id UUID NOT NULL REFERENCES users(id) ON DELETE CASCADE,
    code VARCHAR(255) NOT NULL,
    used BOOLEAN DEFAULT FALSE,
    used_at TIMESTAMP WITH TIME ZONE,
    created_at TIMESTAMP WITH TIME ZONE NOT NULL DEFAULT NOW()
);

-- Create indexes
CREATE INDEX IF NOT EXISTS idx_mfa_backups_user_id ON mfa_backups(user_id);
CREATE INDEX IF NOT EXISTS idx_mfa_backups_used ON mfa_backups(used);
