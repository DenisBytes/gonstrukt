{{- if .HasGDPRProcessingLogs}}
-- Create data processing logs table for GDPR Article 30 compliance
CREATE TABLE IF NOT EXISTS data_processing_logs (
    id UUID PRIMARY KEY,
    user_id UUID REFERENCES users(id) ON DELETE SET NULL,
    process_type VARCHAR(100) NOT NULL,
    processed_data TEXT NOT NULL,
    status VARCHAR(50) NOT NULL DEFAULT 'processing',
    request_ip VARCHAR(100),
    processor_id VARCHAR(100) NOT NULL,
    legal_basis VARCHAR(100) NOT NULL,
    purpose TEXT NOT NULL,
    data_subject VARCHAR(255),
    error_details TEXT,
    requested_at TIMESTAMP WITH TIME ZONE NOT NULL DEFAULT NOW(),
    completed_at TIMESTAMP WITH TIME ZONE,
    created_at TIMESTAMP WITH TIME ZONE NOT NULL DEFAULT NOW()
);

-- Create indexes for efficient querying
CREATE INDEX IF NOT EXISTS idx_data_processing_logs_user_id ON data_processing_logs(user_id);
CREATE INDEX IF NOT EXISTS idx_data_processing_logs_process_type ON data_processing_logs(process_type);
CREATE INDEX IF NOT EXISTS idx_data_processing_logs_status ON data_processing_logs(status);
CREATE INDEX IF NOT EXISTS idx_data_processing_logs_legal_basis ON data_processing_logs(legal_basis);
CREATE INDEX IF NOT EXISTS idx_data_processing_logs_created_at ON data_processing_logs(created_at);
{{- end}}
