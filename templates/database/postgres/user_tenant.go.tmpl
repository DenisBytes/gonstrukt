package db

import (
	"context"
	"errors"
	"time"

	"{{.ModuleName}}/internals/types"

	"github.com/jackc/pgx/v5"
)

// CreateUserTenant creates a user-tenant membership
func (c *PostgresClient) CreateUserTenant(ctx context.Context, ut *types.UserTenant) error {
	_, err := c.pool.Exec(ctx, `
		INSERT INTO user_tenants (user_id, tenant_id, roles, is_owner, created_at)
		VALUES ($1, $2, $3, $4, $5)
	`,
		ut.UserID,
		ut.TenantID,
		ut.Roles,
		ut.IsOwner,
		ut.CreatedAt,
	)
	return err
}

// GetUserTenant retrieves a specific user-tenant membership
func (c *PostgresClient) GetUserTenant(ctx context.Context, userID, tenantID string) (*types.UserTenant, error) {
	ut := &types.UserTenant{}
	err := c.pool.QueryRow(ctx, `
		SELECT ut.user_id, ut.tenant_id, ut.roles, ut.is_owner, ut.created_at, ut.last_used_at,
		       t.name, t.slug
		FROM user_tenants ut
		INNER JOIN tenants t ON ut.tenant_id = t.id
		WHERE ut.user_id = $1 AND ut.tenant_id = $2
	`, userID, tenantID).Scan(
		&ut.UserID,
		&ut.TenantID,
		&ut.Roles,
		&ut.IsOwner,
		&ut.CreatedAt,
		&ut.LastUsedAt,
		&ut.TenantName,
		&ut.TenantSlug,
	)

	if errors.Is(err, pgx.ErrNoRows) {
		return nil, errors.New("membership not found")
	}
	if err != nil {
		return nil, err
	}

	return ut, nil
}

// CheckUserTenantMembership checks if a user belongs to a tenant
func (c *PostgresClient) CheckUserTenantMembership(ctx context.Context, userID, tenantID string) (bool, error) {
	var exists bool
	err := c.pool.QueryRow(ctx, `
		SELECT EXISTS(SELECT 1 FROM user_tenants WHERE user_id = $1 AND tenant_id = $2)
	`, userID, tenantID).Scan(&exists)
	if err != nil {
		return false, err
	}
	return exists, nil
}

// GetUserTenants retrieves all tenants for a user
func (c *PostgresClient) GetUserTenants(ctx context.Context, userID string) ([]*types.UserTenant, error) {
	rows, err := c.pool.Query(ctx, `
		SELECT ut.user_id, ut.tenant_id, ut.roles, ut.is_owner, ut.created_at, ut.last_used_at,
		       t.name, t.slug
		FROM user_tenants ut
		INNER JOIN tenants t ON ut.tenant_id = t.id
		WHERE ut.user_id = $1 AND t.is_active = true
		ORDER BY ut.last_used_at DESC NULLS LAST, ut.created_at DESC
	`, userID)
	if err != nil {
		return nil, err
	}
	defer rows.Close()

	var memberships []*types.UserTenant
	for rows.Next() {
		ut := &types.UserTenant{}
		if err := rows.Scan(
			&ut.UserID,
			&ut.TenantID,
			&ut.Roles,
			&ut.IsOwner,
			&ut.CreatedAt,
			&ut.LastUsedAt,
			&ut.TenantName,
			&ut.TenantSlug,
		); err != nil {
			return nil, err
		}
		memberships = append(memberships, ut)
	}

	return memberships, rows.Err()
}

// DeleteUserTenant removes a user-tenant membership
func (c *PostgresClient) DeleteUserTenant(ctx context.Context, userID, tenantID string) error {
	result, err := c.pool.Exec(ctx, `
		DELETE FROM user_tenants WHERE user_id = $1 AND tenant_id = $2
	`, userID, tenantID)
	if err != nil {
		return err
	}

	if result.RowsAffected() == 0 {
		return errors.New("membership not found")
	}

	return nil
}

// GetTenantMembers retrieves all members of a tenant
func (c *PostgresClient) GetTenantMembers(ctx context.Context, tenantID string) ([]*types.TenantMember, error) {
	rows, err := c.pool.Query(ctx, `
		SELECT u.id, u.email, u.first_name, u.last_name,
		       ut.roles, ut.is_owner, ut.created_at
		FROM user_tenants ut
		INNER JOIN users u ON ut.user_id = u.id
		WHERE ut.tenant_id = $1 AND u.deleted_at IS NULL
		ORDER BY ut.created_at ASC
	`, tenantID)
	if err != nil {
		return nil, err
	}
	defer rows.Close()

	var members []*types.TenantMember
	for rows.Next() {
		m := &types.TenantMember{}
		if err := rows.Scan(
			&m.UserID,
			&m.Email,
			&m.FirstName,
			&m.LastName,
			&m.Roles,
			&m.IsOwner,
			&m.JoinedAt,
		); err != nil {
			return nil, err
		}
		members = append(members, m)
	}

	return members, rows.Err()
}

// UpdateUserTenantRole updates a user's roles in a tenant
func (c *PostgresClient) UpdateUserTenantRole(ctx context.Context, userID, tenantID string, roles []string) error {
	result, err := c.pool.Exec(ctx, `
		UPDATE user_tenants SET roles = $3
		WHERE user_id = $1 AND tenant_id = $2
	`, userID, tenantID, roles)
	if err != nil {
		return err
	}

	if result.RowsAffected() == 0 {
		return errors.New("membership not found")
	}

	return nil
}

// CountTenantMembers returns the number of members in a tenant
func (c *PostgresClient) CountTenantMembers(ctx context.Context, tenantID string) (int, error) {
	var count int
	err := c.pool.QueryRow(ctx, `
		SELECT COUNT(*) FROM user_tenants WHERE tenant_id = $1
	`, tenantID).Scan(&count)
	return count, err
}

// UpdateLastUsedTenant updates the last_used_at timestamp for a user-tenant membership
func (c *PostgresClient) UpdateLastUsedTenant(ctx context.Context, userID, tenantID string) error {
	_, err := c.pool.Exec(ctx, `
		UPDATE user_tenants SET last_used_at = $3
		WHERE user_id = $1 AND tenant_id = $2
	`, userID, tenantID, time.Now())
	return err
}
