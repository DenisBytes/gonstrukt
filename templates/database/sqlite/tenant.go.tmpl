}

// UpdateTenant updates an existing tenant
func (c *SQLiteClient) UpdateTenant(ctx context.Context, tenant *types.Tenant) error {
	tenant.UpdatedAt = time.Now()

	settings, err := json.Marshal(tenant.Settings)
	if err != nil {
		return err
	}

	result, err := c.db.ExecContext(ctx, `
		UPDATE tenants SET name = ?, slug = ?, plan = ?, settings = ?, is_active = ?, updated_at = ?
		WHERE id = ?
	`, tenant.Name, tenant.Slug, tenant.Plan, string(settings), tenant.IsActive,
		tenant.UpdatedAt.Format("2006-01-02T15:04:05Z"), tenant.ID)
	if err != nil {
		return err
	}

	rows, err := result.RowsAffected()
	if err != nil {
		return err
	}
	if rows == 0 {
		return errors.New("tenant not found")
	}

	return nil
}

// DeleteTenant deletes a tenant
func (c *SQLiteClient) DeleteTenant(ctx context.Context, id string) error {
	result, err := c.db.ExecContext(ctx, `DELETE FROM tenants WHERE id = ?`, id)
	if err != nil {
		return err
	}

	rows, err := result.RowsAffected()
	if err != nil {
		return err
	}
	if rows == 0 {
		return errors.New("tenant not found")
	}

	return nil
}
