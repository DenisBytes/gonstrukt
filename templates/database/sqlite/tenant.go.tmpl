	if errors.Is(err, sql.ErrNoRows) {
		return nil, errors.New("tenant not found")
	}
	if err != nil {
		return nil, err
	}

	if settings != "" {
		if err := json.Unmarshal([]byte(settings), &tenant.Settings); err != nil {
