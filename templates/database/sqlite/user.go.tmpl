// CreateUser creates a new user
func (c *SQLiteClient) CreateUser(ctx context.Context, user *types.User) error {
{{- if .HasOAuth}}
	_, err := c.db.ExecContext(ctx, `
		INSERT INTO users (id, email, password_hash, first_name, last_name, mfa_enabled, mfa_secret, roles, oauth_provider, oauth_id, created_at, updated_at)
		VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
	`, user.ID, user.Email, user.PasswordHash, user.FirstName, user.LastName, user.MFAEnabled, user.MFASecret, user.Roles, user.OAuthProvider, user.OAuthID, user.CreatedAt.Format("2006-01-02T15:04:05Z"), user.UpdatedAt.Format("2006-01-02T15:04:05Z"))
{{- else}}
	_, err := c.db.ExecContext(ctx, `
		INSERT INTO users (id, email, password_hash, first_name, last_name, mfa_enabled, mfa_secret, roles, created_at, updated_at)
		VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
	`, user.ID, user.Email, user.PasswordHash, user.FirstName, user.LastName, user.MFAEnabled, user.MFASecret, user.Roles, user.CreatedAt.Format("2006-01-02T15:04:05Z"), user.UpdatedAt.Format("2006-01-02T15:04:05Z"))
{{- end}}
	return err
}

// GetUserByID retrieves a user by ID
func (c *SQLiteClient) GetUserByID(ctx context.Context, id string) (*types.User, error) {
	user := &types.User{}
	err := c.db.QueryRowContext(ctx, `
		SELECT id, email, password_hash, first_name, last_name, mfa_enabled, mfa_secret, roles, created_at, updated_at, deleted_at
		FROM users WHERE id = ? AND deleted_at IS NULL
	`, id).Scan(&user.ID, &user.Email, &user.PasswordHash, &user.FirstName, &user.LastName, &user.MFAEnabled, &user.MFASecret, &user.Roles, &user.CreatedAt, &user.UpdatedAt, &user.DeletedAt)

	if errors.Is(err, sql.ErrNoRows) {
		return nil, errors.New("user not found")
	}
	if err != nil {
		return nil, err
	}

	return user, nil
}

