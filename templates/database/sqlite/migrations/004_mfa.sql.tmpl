-- Create MFA backup codes table
CREATE TABLE IF NOT EXISTS mfa_backups (
    id TEXT PRIMARY KEY,
    user_id TEXT NOT NULL,
    code TEXT NOT NULL,
    used INTEGER DEFAULT 0,
    used_at TEXT,
    created_at TEXT NOT NULL DEFAULT (datetime('now')),
    FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE
);

-- Create indexes
CREATE INDEX IF NOT EXISTS idx_mfa_backups_user_id ON mfa_backups(user_id);
CREATE INDEX IF NOT EXISTS idx_mfa_backups_used ON mfa_backups(used);
