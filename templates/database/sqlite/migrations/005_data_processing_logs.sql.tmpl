{{- if .HasGDPRProcessingLogs}}
-- Create data processing logs table for GDPR Article 30 compliance
CREATE TABLE IF NOT EXISTS data_processing_logs (
    id TEXT PRIMARY KEY,
    user_id TEXT,
    process_type TEXT NOT NULL,
    processed_data TEXT NOT NULL,
    status TEXT NOT NULL DEFAULT 'processing',
    request_ip TEXT,
    processor_id TEXT NOT NULL,
    legal_basis TEXT NOT NULL,
    purpose TEXT NOT NULL,
    data_subject TEXT,
    error_details TEXT,
    requested_at TEXT NOT NULL DEFAULT (datetime('now')),
    completed_at TEXT,
    created_at TEXT NOT NULL DEFAULT (datetime('now')),
    FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE SET NULL
);

-- Create indexes
CREATE INDEX IF NOT EXISTS idx_dpl_user_id ON data_processing_logs(user_id);
CREATE INDEX IF NOT EXISTS idx_dpl_process_type ON data_processing_logs(process_type);
CREATE INDEX IF NOT EXISTS idx_dpl_status ON data_processing_logs(status);
CREATE INDEX IF NOT EXISTS idx_dpl_legal_basis ON data_processing_logs(legal_basis);
CREATE INDEX IF NOT EXISTS idx_dpl_created_at ON data_processing_logs(created_at);
{{- end}}
