// GetInvitationsByEmail retrieves all pending invitations for an email
func (c *SQLiteClient) GetInvitationsByEmail(ctx context.Context, email string) ([]*types.Invitation, error) {
	rows, err := c.db.QueryContext(ctx, `
		SELECT id, tenant_id, email, role, status, invited_by, token, expires_at, created_at, accepted_at, revoked_at
		FROM invitations
		WHERE email = ? AND status = 'pending' AND expires_at > datetime('now')
		ORDER BY created_at DESC
	`, email)
	if err != nil {
		return nil, err
	}
	defer rows.Close()

	var invitations []*types.Invitation
	for rows.Next() {
		inv := &types.Invitation{}
		if err := rows.Scan(
			&inv.ID, &inv.TenantID, &inv.Email, &inv.Role, &inv.Status,
			&inv.InvitedBy, &inv.Token, &inv.ExpiresAt, &inv.CreatedAt, &inv.AcceptedAt, &inv.RevokedAt,
		); err != nil {
			return nil, err
		}
		invitations = append(invitations, inv)
	}
	if err := rows.Err(); err != nil {
		return nil, err
	}
	return invitations, nil
}

// GetInvitationsByTenant retrieves all invitations for a tenant
func (c *SQLiteClient) GetInvitationsByTenant(ctx context.Context, tenantID string) ([]*types.Invitation, error) {
	rows, err := c.db.QueryContext(ctx, `
		SELECT id, tenant_id, email, role, status, invited_by, token, expires_at, created_at, accepted_at, revoked_at
		FROM invitations
		WHERE tenant_id = ?
		ORDER BY created_at DESC
	`, tenantID)
	if err != nil {
		return nil, err
	}
	defer rows.Close()

	var invitations []*types.Invitation
	for rows.Next() {
