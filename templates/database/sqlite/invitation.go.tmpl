}

// UpdateInvitationStatus updates an invitation's status
func (c *SQLiteClient) UpdateInvitationStatus(ctx context.Context, id, status string) error {
	now := time.Now().Format("2006-01-02T15:04:05Z")
	var result sql.Result
	var err error

	switch status {
	case "accepted":
		result, err = c.db.ExecContext(ctx, `UPDATE invitations SET status = ?, accepted_at = ? WHERE id = ?`, status, now, id)
	case "revoked":
		result, err = c.db.ExecContext(ctx, `UPDATE invitations SET status = ?, revoked_at = ? WHERE id = ?`, status, now, id)
	default:
		result, err = c.db.ExecContext(ctx, `UPDATE invitations SET status = ? WHERE id = ?`, status, id)
	}
	if err != nil {
		return err
	}

	rows, err := result.RowsAffected()
	if err != nil {
		return err
	}
	if rows == 0 {
		return errors.New("invitation not found")
	}

	return nil
}

// UpdateInvitationToken updates the token and expiry for an invitation (for resend)
func (c *SQLiteClient) UpdateInvitationToken(ctx context.Context, id, token string, expiresAt time.Time) error {
	result, err := c.db.ExecContext(ctx, `
		UPDATE invitations SET token = ?, expires_at = ?
		WHERE id = ? AND status = 'pending'
	`, token, expiresAt.Format("2006-01-02T15:04:05Z"), id)
	if err != nil {
		return err
	}

	rows, err := result.RowsAffected()
	if err != nil {
		return err
	}
	if rows == 0 {
		return errors.New("invitation not found or not pending")
	}

	return nil
}
