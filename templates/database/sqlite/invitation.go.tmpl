package db

import (
	"context"
	"database/sql"
	"errors"
	"time"

	"{{.ModuleName}}/internals/types"
)

// CreateInvitation creates a new invitation
func (c *SQLiteClient) CreateInvitation(ctx context.Context, invitation *types.Invitation) error {
	_, err := c.db.ExecContext(ctx, `
		INSERT INTO invitations (id, tenant_id, email, role, status, invited_by, token, expires_at, created_at)
		VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)
	`, invitation.ID, invitation.TenantID, invitation.Email, invitation.Role,
		invitation.Status, invitation.InvitedBy, invitation.Token,
		invitation.ExpiresAt.Format("2006-01-02T15:04:05Z"), invitation.CreatedAt.Format("2006-01-02T15:04:05Z"))
	return err
}

// GetInvitationByID retrieves an invitation by ID
func (c *SQLiteClient) GetInvitationByID(ctx context.Context, id string) (*types.Invitation, error) {
	inv := &types.Invitation{}
	err := c.db.QueryRowContext(ctx, `
		SELECT id, tenant_id, email, role, status, invited_by, token, expires_at, created_at, accepted_at, revoked_at
		FROM invitations WHERE id = ?
	`, id).Scan(
		&inv.ID, &inv.TenantID, &inv.Email, &inv.Role, &inv.Status,
		&inv.InvitedBy, &inv.Token, &inv.ExpiresAt, &inv.CreatedAt, &inv.AcceptedAt, &inv.RevokedAt,
	)
	if errors.Is(err, sql.ErrNoRows) {
		return nil, errors.New("invitation not found")
	}
	if err != nil {
		return nil, err
	}
	return inv, nil
}

