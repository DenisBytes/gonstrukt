{{- if .HasOAuth}}
package db

import (
	"context"
	"time"

	"{{.ModuleName}}/internals/types"
)

// UpsertOAuthToken inserts or updates an OAuth token for a user/provider pair
func (c *SQLiteClient) UpsertOAuthToken(ctx context.Context, token *types.OAuthToken) error {
	token.UpdatedAt = time.Now()
	if token.CreatedAt.IsZero() {
		token.CreatedAt = token.UpdatedAt
	}

	_, err := c.db.ExecContext(ctx, `
		INSERT OR REPLACE INTO oauth_tokens (id, user_id, provider, access_token, refresh_token, token_type, expires_at, created_at, updated_at)
		VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)
	`,
		token.ID,
		token.UserID,
		token.Provider,
		token.AccessToken,
		token.RefreshToken,
		token.TokenType,
		token.ExpiresAt,
		token.CreatedAt.Format("2006-01-02T15:04:05Z"),
		token.UpdatedAt.Format("2006-01-02T15:04:05Z"),
	)
	return err
}

// GetOAuthTokensByUser retrieves all OAuth tokens for a user
func (c *SQLiteClient) GetOAuthTokensByUser(ctx context.Context, userID string) ([]*types.OAuthToken, error) {
	rows, err := c.db.QueryContext(ctx, `
		SELECT id, user_id, provider, access_token, refresh_token, token_type, expires_at, created_at, updated_at
		FROM oauth_tokens
		WHERE user_id = ?
		ORDER BY created_at DESC
	`, userID)
	if err != nil {
		return nil, err
	}
	defer rows.Close()

	var tokens []*types.OAuthToken
	for rows.Next() {
		token := &types.OAuthToken{}
		if err := rows.Scan(
			&token.ID,
			&token.UserID,
			&token.Provider,
			&token.AccessToken,
			&token.RefreshToken,
			&token.TokenType,
			&token.ExpiresAt,
			&token.CreatedAt,
			&token.UpdatedAt,
		); err != nil {
			return nil, err
		}
		tokens = append(tokens, token)
	}
	if err := rows.Err(); err != nil {
		return nil, err
	}

	return tokens, nil
}

// DeleteOAuthTokensByUser deletes all OAuth tokens for a user
func (c *SQLiteClient) DeleteOAuthTokensByUser(ctx context.Context, userID string) error {
	_, err := c.db.ExecContext(ctx, `DELETE FROM oauth_tokens WHERE user_id = ?`, userID)
	return err
}
{{- end}}
