// SQLiteClient implements the Database interface for SQLite
type SQLiteClient struct {
	db *sql.DB
}

// NewSQLiteClient creates a new SQLite client
func NewSQLiteClient(path string) (*SQLiteClient, error) {
	db, err := sql.Open("sqlite", path)
	if err != nil {
		return nil, fmt.Errorf("failed to open database: %w", err)
	}

	// Enable WAL mode for better concurrency
	_, err = db.Exec("PRAGMA journal_mode=WAL")
	if err != nil {
		db.Close()
		return nil, fmt.Errorf("failed to enable WAL mode: %w", err)
	}

	// Enable foreign keys
	_, err = db.Exec("PRAGMA foreign_keys=ON")
	if err != nil {
		db.Close()
		return nil, fmt.Errorf("failed to enable foreign keys: %w", err)
	}

	return &SQLiteClient{db: db}, nil
}

// Migrate runs database migrations
func (c *SQLiteClient) Migrate(ctx context.Context) error {
	// Create users table
	_, err := c.db.ExecContext(ctx, `
		CREATE TABLE IF NOT EXISTS users (
			id TEXT PRIMARY KEY,
			email TEXT UNIQUE NOT NULL,
			password_hash TEXT NOT NULL,
			first_name TEXT,
			last_name TEXT,
			mfa_enabled INTEGER DEFAULT 0,
			mfa_secret TEXT,
			roles TEXT,
			created_at TEXT NOT NULL,
			updated_at TEXT NOT NULL,
			deleted_at TEXT
		)
	`)
	if err != nil {
		return err
	}

	// Create sessions table
	_, err = c.db.ExecContext(ctx, `
		CREATE TABLE IF NOT EXISTS sessions (
			id TEXT PRIMARY KEY,
			user_id TEXT NOT NULL,
			refresh_token TEXT UNIQUE NOT NULL,
			user_agent TEXT,
			ip TEXT,
			expires_at TEXT NOT NULL,
			created_at TEXT NOT NULL,
			FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE
		)
	`)
	if err != nil {
		return err
	}

	// Create consents table
	_, err = c.db.ExecContext(ctx, `
		CREATE TABLE IF NOT EXISTS consents (
			id TEXT PRIMARY KEY,
			user_id TEXT NOT NULL,
			type TEXT NOT NULL,
			granted INTEGER DEFAULT 0,
			granted_at TEXT,
			revoked_at TEXT,
			version TEXT NOT NULL,
			description TEXT,
			FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE,
			UNIQUE(user_id, type, version)
		)
	`)
	if err != nil {
		return err
	}

	// Create mfa_backups table
	_, err = c.db.ExecContext(ctx, `
		CREATE TABLE IF NOT EXISTS mfa_backups (
			id TEXT PRIMARY KEY,
			user_id TEXT NOT NULL,
			code TEXT NOT NULL,
			used INTEGER DEFAULT 0,
			used_at TEXT,
			created_at TEXT NOT NULL,
			FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE
		)
	`)

	return err
}

// Ping checks the database connection
func (c *SQLiteClient) Ping(ctx context.Context) error {
	return c.db.PingContext(ctx)
}

// Close closes the database connection
func (c *SQLiteClient) Close(ctx context.Context) error {
	return c.db.Close()
}

// User operations
func (c *SQLiteClient) CreateUser(ctx context.Context, user *types.User) error {
	_, err := c.db.ExecContext(ctx, `
		INSERT INTO users (id, email, password_hash, first_name, last_name, mfa_enabled, mfa_secret, created_at, updated_at)
		VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)
	`, user.ID, user.Email, user.PasswordHash, user.FirstName, user.LastName, user.MFAEnabled, user.MFASecret, user.CreatedAt.Format("2006-01-02T15:04:05Z"), user.UpdatedAt.Format("2006-01-02T15:04:05Z"))
	return err
}

func (c *SQLiteClient) GetUserByID(ctx context.Context, id string) (*types.User, error) {
	user := &types.User{}
	err := c.db.QueryRowContext(ctx, `SELECT id, email, password_hash, first_name, last_name, mfa_enabled, mfa_secret, created_at, updated_at, deleted_at FROM users WHERE id = ? AND deleted_at IS NULL`, id).
		Scan(&user.ID, &user.Email, &user.PasswordHash, &user.FirstName, &user.LastName, &user.MFAEnabled, &user.MFASecret, &user.CreatedAt, &user.UpdatedAt, &user.DeletedAt)
	return user, err
}

func (c *SQLiteClient) GetUserByEmail(ctx context.Context, email string) (*types.User, error) {
	user := &types.User{}
	err := c.db.QueryRowContext(ctx, `SELECT id, email, password_hash, first_name, last_name, mfa_enabled, mfa_secret, created_at, updated_at, deleted_at FROM users WHERE email = ? AND deleted_at IS NULL`, email).
		Scan(&user.ID, &user.Email, &user.PasswordHash, &user.FirstName, &user.LastName, &user.MFAEnabled, &user.MFASecret, &user.CreatedAt, &user.UpdatedAt, &user.DeletedAt)
	return user, err
}

func (c *SQLiteClient) UpdateUser(ctx context.Context, user *types.User) error {
	_, err := c.db.ExecContext(ctx, `UPDATE users SET email = ?, first_name = ?, last_name = ?, mfa_enabled = ?, mfa_secret = ?, updated_at = datetime('now') WHERE id = ? AND deleted_at IS NULL`,
		user.Email, user.FirstName, user.LastName, user.MFAEnabled, user.MFASecret, user.ID)
	return err
}

func (c *SQLiteClient) DeleteUser(ctx context.Context, id string) error {
	_, err := c.db.ExecContext(ctx, `UPDATE users SET deleted_at = datetime('now') WHERE id = ? AND deleted_at IS NULL`, id)
	return err
}

// Session operations
func (c *SQLiteClient) CreateSession(ctx context.Context, session *types.Session) error {
	_, err := c.db.ExecContext(ctx, `INSERT INTO sessions (id, user_id, refresh_token, user_agent, ip, expires_at, created_at) VALUES (?, ?, ?, ?, ?, ?, ?)`,
		session.ID, session.UserID, session.RefreshToken, session.UserAgent, session.IP, session.ExpiresAt.Format("2006-01-02T15:04:05Z"), session.CreatedAt.Format("2006-01-02T15:04:05Z"))
	return err
}

func (c *SQLiteClient) GetSessionByID(ctx context.Context, id string) (*types.Session, error) {
	session := &types.Session{}
	err := c.db.QueryRowContext(ctx, `SELECT id, user_id, refresh_token, user_agent, ip, expires_at, created_at FROM sessions WHERE id = ?`, id).
		Scan(&session.ID, &session.UserID, &session.RefreshToken, &session.UserAgent, &session.IP, &session.ExpiresAt, &session.CreatedAt)
	return session, err
}

func (c *SQLiteClient) GetSessionByRefreshToken(ctx context.Context, token string) (*types.Session, error) {
	session := &types.Session{}
	err := c.db.QueryRowContext(ctx, `SELECT id, user_id, refresh_token, user_agent, ip, expires_at, created_at FROM sessions WHERE refresh_token = ?`, token).
		Scan(&session.ID, &session.UserID, &session.RefreshToken, &session.UserAgent, &session.IP, &session.ExpiresAt, &session.CreatedAt)
	return session, err
}

func (c *SQLiteClient) GetUserSessions(ctx context.Context, userID string) ([]*types.Session, error) {
	rows, err := c.db.QueryContext(ctx, `SELECT id, user_id, refresh_token, user_agent, ip, expires_at, created_at FROM sessions WHERE user_id = ?`, userID)
	if err != nil {
		return nil, err
	}
	defer rows.Close()
	var sessions []*types.Session
	for rows.Next() {
		s := &types.Session{}
		rows.Scan(&s.ID, &s.UserID, &s.RefreshToken, &s.UserAgent, &s.IP, &s.ExpiresAt, &s.CreatedAt)
		sessions = append(sessions, s)
	}
	return sessions, nil
}

func (c *SQLiteClient) DeleteSession(ctx context.Context, id string) error {
	_, err := c.db.ExecContext(ctx, `DELETE FROM sessions WHERE id = ?`, id)
	return err
}

func (c *SQLiteClient) DeleteUserSessions(ctx context.Context, userID string) error {
	_, err := c.db.ExecContext(ctx, `DELETE FROM sessions WHERE user_id = ?`, userID)
	return err
}

