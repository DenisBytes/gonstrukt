package db

import (
	"context"
	"database/sql"
	"encoding/json"
	"errors"

	"{{.ModuleName}}/internals/types"
)

// CreateUserTenant creates a user-tenant membership
func (c *MySQLClient) CreateUserTenant(ctx context.Context, ut *types.UserTenant) error {
	roles, err := json.Marshal(ut.Roles)
	if err != nil {
		return err
	}

	_, err = c.db.ExecContext(ctx, `
		INSERT INTO user_tenants (user_id, tenant_id, roles, is_owner, created_at)
		VALUES (?, ?, ?, ?, ?)
	`, ut.UserID, ut.TenantID, string(roles), ut.IsOwner, ut.CreatedAt)
	return err
}

// GetUserTenant retrieves a specific user-tenant membership
func (c *MySQLClient) GetUserTenant(ctx context.Context, userID, tenantID string) (*types.UserTenant, error) {
	ut := &types.UserTenant{}
	var rolesJSON string

	err := c.db.QueryRowContext(ctx, `
		SELECT ut.user_id, ut.tenant_id, ut.roles, ut.is_owner, ut.created_at, ut.last_used_at,
		       t.name, t.slug
		FROM user_tenants ut
		INNER JOIN tenants t ON ut.tenant_id = t.id
		WHERE ut.user_id = ? AND ut.tenant_id = ?
	`, userID, tenantID).Scan(
		&ut.UserID, &ut.TenantID, &rolesJSON, &ut.IsOwner, &ut.CreatedAt, &ut.LastUsedAt,
		&ut.TenantName, &ut.TenantSlug,
	)
	if errors.Is(err, sql.ErrNoRows) {
		return nil, errors.New("membership not found")
	}
	if err != nil {
		return nil, err
	}

	if err := json.Unmarshal([]byte(rolesJSON), &ut.Roles); err != nil {
		return nil, err
	}

	return ut, nil
}

// CheckUserTenantMembership checks if a user belongs to a tenant
func (c *MySQLClient) CheckUserTenantMembership(ctx context.Context, userID, tenantID string) (bool, error) {
	var count int
	err := c.db.QueryRowContext(ctx, `
		SELECT COUNT(*) FROM user_tenants WHERE user_id = ? AND tenant_id = ?
	`, userID, tenantID).Scan(&count)
	if err != nil {
		return false, err
	}
	return count > 0, nil
}

// GetUserTenants retrieves all tenants for a user
func (c *MySQLClient) GetUserTenants(ctx context.Context, userID string) ([]*types.UserTenant, error) {
	rows, err := c.db.QueryContext(ctx, `
		SELECT ut.user_id, ut.tenant_id, ut.roles, ut.is_owner, ut.created_at, ut.last_used_at,
		       t.name, t.slug
		FROM user_tenants ut
		INNER JOIN tenants t ON ut.tenant_id = t.id
		WHERE ut.user_id = ? AND t.is_active = TRUE
		ORDER BY COALESCE(ut.last_used_at, '1970-01-01') DESC, ut.created_at DESC
	`, userID)
	if err != nil {
		return nil, err
	}
	defer rows.Close()

	var memberships []*types.UserTenant
	for rows.Next() {
		ut := &types.UserTenant{}
		var rolesJSON string
		if err := rows.Scan(
			&ut.UserID, &ut.TenantID, &rolesJSON, &ut.IsOwner, &ut.CreatedAt, &ut.LastUsedAt,
			&ut.TenantName, &ut.TenantSlug,
		); err != nil {
			return nil, err
		}
		if err := json.Unmarshal([]byte(rolesJSON), &ut.Roles); err != nil {
			return nil, err
		}
		memberships = append(memberships, ut)
	}
	if err := rows.Err(); err != nil {
		return nil, err
	}

	return memberships, nil
}

// DeleteUserTenant removes a user-tenant membership
func (c *MySQLClient) DeleteUserTenant(ctx context.Context, userID, tenantID string) error {
	result, err := c.db.ExecContext(ctx, `
		DELETE FROM user_tenants WHERE user_id = ? AND tenant_id = ?
	`, userID, tenantID)
	if err != nil {
		return err
	}

	rows, err := result.RowsAffected()
	if err != nil {
		return err
	}
	if rows == 0 {
		return errors.New("membership not found")
	}

	return nil
}

// GetTenantMembers retrieves all members of a tenant
func (c *MySQLClient) GetTenantMembers(ctx context.Context, tenantID string) ([]*types.TenantMember, error) {
	rows, err := c.db.QueryContext(ctx, `
		SELECT u.id, u.email, u.first_name, u.last_name,
		       ut.roles, ut.is_owner, ut.created_at
		FROM user_tenants ut
		INNER JOIN users u ON ut.user_id = u.id
		WHERE ut.tenant_id = ? AND u.deleted_at IS NULL
		ORDER BY ut.created_at ASC
	`, tenantID)
	if err != nil {
		return nil, err
	}
	defer rows.Close()

	var members []*types.TenantMember
	for rows.Next() {
		m := &types.TenantMember{}
		var rolesJSON string
		if err := rows.Scan(
			&m.UserID, &m.Email, &m.FirstName, &m.LastName,
			&rolesJSON, &m.IsOwner, &m.JoinedAt,
		); err != nil {
			return nil, err
		}
		if err := json.Unmarshal([]byte(rolesJSON), &m.Roles); err != nil {
			return nil, err
		}
		members = append(members, m)
	}
	if err := rows.Err(); err != nil {
		return nil, err
	}

	return members, nil
}

// UpdateUserTenantRole updates a user's roles in a tenant
func (c *MySQLClient) UpdateUserTenantRole(ctx context.Context, userID, tenantID string, roles []string) error {
	rolesJSON, err := json.Marshal(roles)
	if err != nil {
		return err
	}

	result, err := c.db.ExecContext(ctx, `
		UPDATE user_tenants SET roles = ?
		WHERE user_id = ? AND tenant_id = ?
	`, string(rolesJSON), userID, tenantID)
	if err != nil {
		return err
	}

	rows, err := result.RowsAffected()
	if err != nil {
		return err
	}
	if rows == 0 {
		return errors.New("membership not found")
	}

	return nil
}

// CountTenantMembers returns the number of members in a tenant
func (c *MySQLClient) CountTenantMembers(ctx context.Context, tenantID string) (int, error) {
	var count int
	err := c.db.QueryRowContext(ctx, `
		SELECT COUNT(*) FROM user_tenants WHERE tenant_id = ?
	`, tenantID).Scan(&count)
	return count, err
}

// UpdateLastUsedTenant updates the last_used_at timestamp for a user-tenant membership
func (c *MySQLClient) UpdateLastUsedTenant(ctx context.Context, userID, tenantID string) error {
	_, err := c.db.ExecContext(ctx, `
		UPDATE user_tenants SET last_used_at = NOW()
		WHERE user_id = ? AND tenant_id = ?
	`, userID, tenantID)
	return err
}
