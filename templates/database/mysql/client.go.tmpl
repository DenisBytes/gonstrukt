// MySQLClient implements the Database interface for MySQL
type MySQLClient struct {
	db *sql.DB
}

// NewMySQLClient creates a new MySQL client
func NewMySQLClient(connString string) (*MySQLClient, error) {
	db, err := sql.Open("mysql", connString)
	if err != nil {
		return nil, fmt.Errorf("failed to open database: %w", err)
	}

	// Set connection pool settings
	db.SetMaxOpenConns(25)
	db.SetMaxIdleConns(5)
	db.SetConnMaxLifetime(5 * time.Minute)

	// Verify connection
	if err := db.Ping(); err != nil {
		db.Close()
		return nil, fmt.Errorf("failed to ping database: %w", err)
	}

	return &MySQLClient{db: db}, nil
}

// Migrate runs database migrations
func (c *MySQLClient) Migrate(ctx context.Context) error {
	// Create users table
	_, err := c.db.ExecContext(ctx, `
		CREATE TABLE IF NOT EXISTS users (
			id VARCHAR(36) PRIMARY KEY,
			email VARCHAR(255) UNIQUE NOT NULL,
			password_hash VARCHAR(255) NOT NULL,
			first_name VARCHAR(100),
			last_name VARCHAR(100),
			mfa_enabled BOOLEAN DEFAULT FALSE,
			mfa_secret VARCHAR(255),
			roles JSON,
			created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
			updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
			deleted_at TIMESTAMP NULL,
			INDEX idx_email (email),
			INDEX idx_deleted_at (deleted_at)
		)
	`)
	if err != nil {
		return err
	}

	// Create sessions table
	_, err = c.db.ExecContext(ctx, `
		CREATE TABLE IF NOT EXISTS sessions (
			id VARCHAR(36) PRIMARY KEY,
			user_id VARCHAR(36) NOT NULL,
			refresh_token VARCHAR(255) UNIQUE NOT NULL,
			user_agent TEXT,
			ip VARCHAR(45),
			expires_at TIMESTAMP NOT NULL,
			created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
			FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE,
			INDEX idx_user_id (user_id),
			INDEX idx_refresh_token (refresh_token)
		)
	`)
	if err != nil {
		return err
	}

	// Create consents table
	_, err = c.db.ExecContext(ctx, `
		CREATE TABLE IF NOT EXISTS consents (
			id VARCHAR(36) PRIMARY KEY,
			user_id VARCHAR(36) NOT NULL,
			type VARCHAR(50) NOT NULL,
			granted BOOLEAN DEFAULT FALSE,
			granted_at TIMESTAMP NULL,
			revoked_at TIMESTAMP NULL,
			version VARCHAR(20) NOT NULL,
			description TEXT,
			FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE,
			UNIQUE KEY unique_consent (user_id, type, version),
			INDEX idx_user_consents (user_id)
		)
	`)
	if err != nil {
		return err
	}

	// Create mfa_backups table
	_, err = c.db.ExecContext(ctx, `
		CREATE TABLE IF NOT EXISTS mfa_backups (
			id VARCHAR(36) PRIMARY KEY,
			user_id VARCHAR(36) NOT NULL,
			code VARCHAR(255) NOT NULL,
			used BOOLEAN DEFAULT FALSE,
			used_at TIMESTAMP NULL,
			created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
			FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE,
			INDEX idx_mfa_user (user_id)
		)
	`)

	return err
}

// Ping checks the database connection
func (c *MySQLClient) Ping(ctx context.Context) error {
	return c.db.PingContext(ctx)
}

// Close closes the database connection pool
func (c *MySQLClient) Close(ctx context.Context) error {
	return c.db.Close()
}

// CreateUser creates a new user
func (c *MySQLClient) CreateUser(ctx context.Context, user *types.User) error {
	_, err := c.db.ExecContext(ctx, `
		INSERT INTO users (id, email, password_hash, first_name, last_name, mfa_enabled, mfa_secret, created_at, updated_at)
		VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)
	`, user.ID, user.Email, user.PasswordHash, user.FirstName, user.LastName, user.MFAEnabled, user.MFASecret, user.CreatedAt, user.UpdatedAt)
	return err
}

// GetUserByID retrieves a user by ID
func (c *MySQLClient) GetUserByID(ctx context.Context, id string) (*types.User, error) {
	user := &types.User{}
	err := c.db.QueryRowContext(ctx, `
		SELECT id, email, password_hash, first_name, last_name, mfa_enabled, mfa_secret, created_at, updated_at, deleted_at
		FROM users WHERE id = ? AND deleted_at IS NULL
	`, id).Scan(&user.ID, &user.Email, &user.PasswordHash, &user.FirstName, &user.LastName, &user.MFAEnabled, &user.MFASecret, &user.CreatedAt, &user.UpdatedAt, &user.DeletedAt)
	return user, err
}

// GetUserByEmail retrieves a user by email
func (c *MySQLClient) GetUserByEmail(ctx context.Context, email string) (*types.User, error) {
	user := &types.User{}
	err := c.db.QueryRowContext(ctx, `
		SELECT id, email, password_hash, first_name, last_name, mfa_enabled, mfa_secret, created_at, updated_at, deleted_at
		FROM users WHERE email = ? AND deleted_at IS NULL
	`, email).Scan(&user.ID, &user.Email, &user.PasswordHash, &user.FirstName, &user.LastName, &user.MFAEnabled, &user.MFASecret, &user.CreatedAt, &user.UpdatedAt, &user.DeletedAt)
	return user, err
}

// UpdateUser updates a user
func (c *MySQLClient) UpdateUser(ctx context.Context, user *types.User) error {
	_, err := c.db.ExecContext(ctx, `
		UPDATE users SET email = ?, first_name = ?, last_name = ?, mfa_enabled = ?, mfa_secret = ?, updated_at = NOW()
		WHERE id = ? AND deleted_at IS NULL
	`, user.Email, user.FirstName, user.LastName, user.MFAEnabled, user.MFASecret, user.ID)
	return err
}

// DeleteUser soft deletes a user
func (c *MySQLClient) DeleteUser(ctx context.Context, id string) error {
	_, err := c.db.ExecContext(ctx, `UPDATE users SET deleted_at = NOW() WHERE id = ? AND deleted_at IS NULL`, id)
	return err
}

