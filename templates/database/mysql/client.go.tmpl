// SoftDeleteUser performs a GDPR-compliant soft delete by anonymizing PII
func (c *MySQLClient) SoftDeleteUser(ctx context.Context, id string) error {
	anonymizedEmail := fmt.Sprintf("deleted_%s@anonymized.local", id)
	_, err := c.db.ExecContext(ctx, `
		UPDATE users SET
			email = ?, first_name = 'DELETED', last_name = 'USER',
			password_hash = '', mfa_enabled = FALSE, mfa_secret = '',
			deleted_at = NOW(), updated_at = NOW()
		WHERE id = ? AND deleted_at IS NULL
	`, anonymizedEmail, id)
	if err != nil {
		return err
	}

	// Delete sessions and MFA backup codes
	c.db.ExecContext(ctx, `DELETE FROM sessions WHERE user_id = ?`, id)
	c.db.ExecContext(ctx, `DELETE FROM mfa_backups WHERE user_id = ?`, id)
	return nil
}
{{- end}}

{{- if .HasGDPRDataExport}}

// ExportUserData exports all user data for GDPR data portability
func (c *MySQLClient) ExportUserData(ctx context.Context, userID string) (*types.UserDataExport, error) {
	user, err := c.GetUserByID(ctx, userID)
	if err != nil {
		return nil, err
	}

	sessions, err := c.GetUserSessions(ctx, userID)
	if err != nil {
		return nil, err
	}

	consents, err := c.GetUserConsents(ctx, userID)
	if err != nil {
		return nil, err
	}

	userExport := types.UserExportData{
		ID:        user.ID,
		Email:     user.Email,
		FirstName: user.FirstName,
		LastName:  user.LastName,
		CreatedAt: user.CreatedAt,
		UpdatedAt: user.UpdatedAt,
	}

	sessionExports := make([]types.SessionExportData, len(sessions))
	for i, s := range sessions {
		sessionExports[i] = types.SessionExportData{
			ID:        s.ID,
			UserAgent: s.UserAgent,
			IP:        s.IP,
			CreatedAt: s.CreatedAt,
			ExpiresAt: s.ExpiresAt,
		}
	}

	consentExports := make([]types.ConsentExportData, len(consents))
	for i, consent := range consents {
		consentExports[i] = types.ConsentExportData{
			Type:      consent.Type,
			Granted:   consent.Granted,
			Version:   consent.Version,
			GrantedAt: consent.GrantedAt,
			RevokedAt: consent.RevokedAt,
		}
	}

	return &types.UserDataExport{
		ExportedAt: time.Now(),
		User:       userExport,
		Sessions:   sessionExports,
		Consents:   consentExports,
	}, nil
}
{{- end}}

{{- if .HasOAuth}}

// GetUserByOAuthID retrieves a user by OAuth provider and ID
func (c *MySQLClient) GetUserByOAuthID(ctx context.Context, provider, oauthID string) (*types.User, error) {
	user := &types.User{}
	err := c.db.QueryRowContext(ctx, `
		SELECT u.id, u.email, u.password_hash, u.first_name, u.last_name,
		       u.mfa_enabled, u.mfa_secret, u.created_at, u.updated_at, u.deleted_at
		FROM users u
		INNER JOIN oauth_accounts oa ON u.id = oa.user_id
		WHERE oa.provider = ? AND oa.provider_id = ? AND u.deleted_at IS NULL
	`, provider, oauthID).Scan(&user.ID, &user.Email, &user.PasswordHash, &user.FirstName, &user.LastName,
		&user.MFAEnabled, &user.MFASecret, &user.CreatedAt, &user.UpdatedAt, &user.DeletedAt)
	return user, err
}
