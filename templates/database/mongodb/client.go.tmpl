// MongoClient implements the Database interface for MongoDB
type MongoClient struct {
	client   *mongo.Client
	database *mongo.Database
}

// NewMongoClient creates a new MongoDB client
func NewMongoClient(ctx context.Context, uri, dbName string) (*MongoClient, error) {
	clientOptions := options.Client().ApplyURI(uri)
	clientOptions.SetMaxPoolSize(100)
	clientOptions.SetMinPoolSize(5)

	client, err := mongo.Connect(ctx, clientOptions)
	if err != nil {
		return nil, fmt.Errorf("failed to connect to MongoDB: %w", err)
	}

	if err := client.Ping(ctx, nil); err != nil {
		client.Disconnect(ctx)
		return nil, fmt.Errorf("failed to ping MongoDB: %w", err)
	}

	return &MongoClient{
		client:   client,
		database: client.Database(dbName),
	}, nil
}

// Migrate sets up indexes
func (c *MongoClient) Migrate(ctx context.Context) error {
	// Users collection indexes
	usersCol := c.database.Collection("users")
	_, err := usersCol.Indexes().CreateMany(ctx, []mongo.IndexModel{
		{Keys: bson.D{bson.E{Key: "email", Value: 1}}, Options: options.Index().SetUnique(true)},
		{Keys: bson.D{bson.E{Key: "deleted_at", Value: 1}}},
	})
	if err != nil {
		return err
	}

	// Sessions collection indexes
	sessionsCol := c.database.Collection("sessions")
	_, err = sessionsCol.Indexes().CreateMany(ctx, []mongo.IndexModel{
		{Keys: bson.D{bson.E{Key: "user_id", Value: 1}}},
		{Keys: bson.D{bson.E{Key: "refresh_token", Value: 1}}, Options: options.Index().SetUnique(true)},
		{Keys: bson.D{bson.E{Key: "expires_at", Value: 1}}, Options: options.Index().SetExpireAfterSeconds(0)},
	})
	if err != nil {
		return err
	}

	// Consents collection indexes
	consentsCol := c.database.Collection("consents")
	_, err = consentsCol.Indexes().CreateMany(ctx, []mongo.IndexModel{
		{Keys: bson.D{bson.E{Key: "user_id", Value: 1}}},
		{Keys: bson.D{bson.E{Key: "user_id", Value: 1}, bson.E{Key: "type", Value: 1}, bson.E{Key: "version", Value: 1}}, Options: options.Index().SetUnique(true)},
	})
	if err != nil {
		return err
	}

	// MFA backups collection indexes
	mfaCol := c.database.Collection("mfa_backups")
	_, err = mfaCol.Indexes().CreateOne(ctx, mongo.IndexModel{
		Keys: bson.D{bson.E{Key: "user_id", Value: 1}},
	})

	return err
}

// Ping checks the database connection
func (c *MongoClient) Ping(ctx context.Context) error {
	return c.client.Ping(ctx, nil)
}

// Close closes the database connection
func (c *MongoClient) Close(ctx context.Context) error {
	return c.client.Disconnect(ctx)
}

// User operations
func (c *MongoClient) CreateUser(ctx context.Context, user *types.User) error {
	_, err := c.database.Collection("users").InsertOne(ctx, user)
	return err
}

func (c *MongoClient) GetUserByID(ctx context.Context, id string) (*types.User, error) {
	user := &types.User{}
	err := c.database.Collection("users").FindOne(ctx, bson.M{"_id": id, "deleted_at": nil}).Decode(user)
	if errors.Is(err, mongo.ErrNoDocuments) {
		return nil, errors.New("user not found")
	}
	return user, err
}

func (c *MongoClient) GetUserByEmail(ctx context.Context, email string) (*types.User, error) {
	user := &types.User{}
	err := c.database.Collection("users").FindOne(ctx, bson.M{"email": email, "deleted_at": nil}).Decode(user)
	if errors.Is(err, mongo.ErrNoDocuments) {
		return nil, errors.New("user not found")
	}
	return user, err
}

func (c *MongoClient) UpdateUser(ctx context.Context, user *types.User) error {
	user.UpdatedAt = time.Now()
	_, err := c.database.Collection("users").UpdateOne(ctx, bson.M{"_id": user.ID}, bson.M{"$set": user})
	return err
}

func (c *MongoClient) DeleteUser(ctx context.Context, id string) error {
	now := time.Now()
	_, err := c.database.Collection("users").UpdateOne(ctx, bson.M{"_id": id}, bson.M{"$set": bson.M{"deleted_at": now}})
	return err
}

