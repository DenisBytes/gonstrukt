	backup := &types.MFABackup{}
	err := c.database.Collection("mfa_backups").FindOne(ctx, bson.M{"user_id": userID, "code": hashedCode}).Decode(backup)
	if errors.Is(err, mongo.ErrNoDocuments) {
		return nil, errors.New("backup code not found")
	}
	return backup, err
}

// UpdateBackupCode updates an MFA backup code
func (c *MongoClient) UpdateBackupCode(ctx context.Context, backup *types.MFABackup) error {
	_, err := c.database.Collection("mfa_backups").UpdateOne(ctx, bson.M{"_id": backup.ID},
		bson.M{"$set": bson.M{"used": backup.Used, "used_at": backup.UsedAt}})
	return err
}

// DeleteBackupCodes deletes all MFA backup codes for a user
func (c *MongoClient) DeleteBackupCodes(ctx context.Context, userID string) error {
	return c.DeleteMFABackups(ctx, userID)
}
