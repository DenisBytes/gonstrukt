{{- if .HasGDPRConsent}}

// GetActiveConsentsByUserID retrieves all active consents for a user
func (c *MongoClient) GetActiveConsentsByUserID(ctx context.Context, userID string) ([]*types.Consent, error) {
	filter := bson.M{
		"user_id":    userID,
		"granted":    true,
		"revoked_at": nil,
		"$or": []bson.M{
			{"expires_at": nil},
			{"expires_at": bson.M{"$gt": time.Now()}},
		},
	}
	cursor, err := c.database.Collection("consents").Find(ctx, filter)
	if err != nil {
		return nil, err
	}
	defer cursor.Close(ctx)

	var consents []*types.Consent
	if err := cursor.All(ctx, &consents); err != nil {
		return nil, err
	}
	return consents, nil
}

// GetConsentHistory retrieves the full consent history for a user
func (c *MongoClient) GetConsentHistory(ctx context.Context, userID string) ([]*types.Consent, error) {
	return c.GetUserConsents(ctx, userID)
}
{{- end}}

{{- if .HasGDPRDataDeletion}}

// SoftDeleteUser performs a GDPR-compliant soft delete by anonymizing PII
func (c *MongoClient) SoftDeleteUser(ctx context.Context, id string) error {
	now := time.Now()
	anonymizedEmail := fmt.Sprintf("deleted_%s@anonymized.local", id)

	_, err := c.database.Collection("users").UpdateOne(ctx, bson.M{"_id": id, "deleted_at": nil},
		bson.M{"$set": bson.M{
			"email":         anonymizedEmail,
			"first_name":    "DELETED",
			"last_name":     "USER",
			"password_hash": "",
			"mfa_enabled":   false,
			"mfa_secret":    "",
			"deleted_at":    now,
			"updated_at":    now,
		}})
	if err != nil {
		return err
	}

	c.database.Collection("sessions").DeleteMany(ctx, bson.M{"user_id": id})
	c.database.Collection("mfa_backups").DeleteMany(ctx, bson.M{"user_id": id})
	return nil
}
{{- end}}

{{- if .HasGDPRDataExport}}

// ExportUserData exports all user data for GDPR data portability
func (c *MongoClient) ExportUserData(ctx context.Context, userID string) (*types.UserDataExport, error) {
	user, err := c.GetUserByID(ctx, userID)
	if err != nil {
		return nil, err
	}

	sessions, err := c.GetUserSessions(ctx, userID)
	if err != nil {
		return nil, err
	}

	consents, err := c.GetUserConsents(ctx, userID)
	if err != nil {
		return nil, err
	}

	userExport := types.UserExportData{
		ID:        user.ID,
		Email:     user.Email,
		FirstName: user.FirstName,
		LastName:  user.LastName,
		CreatedAt: user.CreatedAt,
		UpdatedAt: user.UpdatedAt,
	}

	sessionExports := make([]types.SessionExportData, len(sessions))
	for i, s := range sessions {
		sessionExports[i] = types.SessionExportData{
			ID:        s.ID,
			UserAgent: s.UserAgent,
			IP:        s.IP,
			CreatedAt: s.CreatedAt,
			ExpiresAt: s.ExpiresAt,
		}
	}

	consentExports := make([]types.ConsentExportData, len(consents))
	for i, consent := range consents {
		consentExports[i] = types.ConsentExportData{
			Type:      consent.Type,
			Granted:   consent.Granted,
			Version:   consent.Version,
			GrantedAt: consent.GrantedAt,
			RevokedAt: consent.RevokedAt,
		}
	}

	return &types.UserDataExport{
		ExportedAt: time.Now(),
		User:       userExport,
		Sessions:   sessionExports,
		Consents:   consentExports,
	}, nil
}
{{- end}}

{{- if .HasOAuth}}

// GetUserByOAuthID retrieves a user by OAuth provider and ID
func (c *MongoClient) GetUserByOAuthID(ctx context.Context, provider, oauthID string) (*types.User, error) {
	// First find the OAuth account
	var oauthAccount struct {
		UserID string `bson:"user_id"`
	}
	err := c.database.Collection("oauth_accounts").FindOne(ctx, bson.M{
		"provider":    provider,
		"provider_id": oauthID,
	}).Decode(&oauthAccount)
	if errors.Is(err, mongo.ErrNoDocuments) {
		return nil, errors.New("user not found")
	}
	if err != nil {
		return nil, err
	}

	return c.GetUserByID(ctx, oauthAccount.UserID)
}
