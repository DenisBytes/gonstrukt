func (c *MongoClient) GetUserSessions(ctx context.Context, userID string) ([]*types.Session, error) {
	cursor, err := c.database.Collection("sessions").Find(ctx, bson.M{"user_id": userID})
	if err != nil {
		return nil, err
	}
	defer cursor.Close(ctx)

	var sessions []*types.Session
	if err := cursor.All(ctx, &sessions); err != nil {
		return nil, err
	}
	return sessions, nil
}

func (c *MongoClient) DeleteSession(ctx context.Context, id string) error {
	_, err := c.database.Collection("sessions").DeleteOne(ctx, bson.M{"_id": id})
	return err
}

func (c *MongoClient) DeleteUserSessions(ctx context.Context, userID string) error {
	_, err := c.database.Collection("sessions").DeleteMany(ctx, bson.M{"user_id": userID})
	return err
}

