{{- if .HasGDPRProcessingLogs}}
package db

import (
	"context"

	"{{.ModuleName}}/internals/types"

	"go.mongodb.org/mongo-driver/bson"
	"go.mongodb.org/mongo-driver/mongo/options"
)

// CreateDataProcessingLog creates a new GDPR data processing log entry
func (c *MongoClient) CreateDataProcessingLog(ctx context.Context, log *types.DataProcessingLog) error {
	_, err := c.database.Collection("data_processing_logs").InsertOne(ctx, log)
	return err
}

// GetDataProcessingLogs retrieves all processing logs for a user
func (c *MongoClient) GetDataProcessingLogs(ctx context.Context, userID string) ([]*types.DataProcessingLog, error) {
	opts := options.Find().SetSort(bson.D{bson.E{Key: "created_at", Value: -1}})
	cursor, err := c.database.Collection("data_processing_logs").Find(ctx, bson.M{"user_id": userID}, opts)
	if err != nil {
		return nil, err
	}
	defer cursor.Close(ctx)

	var logs []*types.DataProcessingLog
	if err := cursor.All(ctx, &logs); err != nil {
		return nil, err
	}

	return logs, nil
}
{{- end}}
