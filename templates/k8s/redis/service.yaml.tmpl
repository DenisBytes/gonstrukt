apiVersion: v1
kind: Service
metadata:
  name: redis
  namespace: {{ .ProjectName }}
  labels:
    app: redis
    app.kubernetes.io/part-of: {{ .ProjectName }}
spec:
  type: NodePort
  selector:
    app: redis
  ports:
    - name: redis
      port: 6379
      targetPort: 6379
      nodePort: 36379
    - name: metrics
      port: 9121
      targetPort: 9121
