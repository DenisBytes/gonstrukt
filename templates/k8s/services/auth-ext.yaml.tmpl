apiVersion: v1
kind: Service
metadata:
  name: auth-ext
  namespace: {{ .ProjectName }}
  labels:
    app: auth
    app.kubernetes.io/part-of: {{ .ProjectName }}
spec:
  type: ClusterIP
  ports:
    - name: http
      port: 8081
      targetPort: 8081
---
apiVersion: v1
kind: Endpoints
metadata:
  name: auth-ext
  namespace: {{ .ProjectName }}
subsets:
  - addresses:
      - ip: __HOST_IP__
    ports:
      - name: http
        port: 8081
