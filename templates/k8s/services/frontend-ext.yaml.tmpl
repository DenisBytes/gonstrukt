apiVersion: v1
kind: Service
metadata:
  name: frontend-ext
  namespace: {{ .ProjectName }}
  labels:
    app: frontend
    app.kubernetes.io/part-of: {{ .ProjectName }}
spec:
  type: ClusterIP
  ports:
    - name: http
      port: 3000
      targetPort: 3000
---
apiVersion: v1
kind: Endpoints
metadata:
  name: frontend-ext
  namespace: {{ .ProjectName }}
subsets:
  - addresses:
      - ip: __HOST_IP__
    ports:
      - name: http
        port: 3000
