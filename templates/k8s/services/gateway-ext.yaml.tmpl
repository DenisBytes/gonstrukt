apiVersion: v1
kind: Service
metadata:
  name: gateway-ext
  namespace: {{ .ProjectName }}
  labels:
    app: gateway
    app.kubernetes.io/part-of: {{ .ProjectName }}
spec:
  type: ClusterIP
  ports:
    - name: http
      port: 8080
      targetPort: 8080
---
apiVersion: v1
kind: Endpoints
metadata:
  name: gateway-ext
  namespace: {{ .ProjectName }}
subsets:
  - addresses:
      - ip: __HOST_IP__
    ports:
      - name: http
        port: 8080
