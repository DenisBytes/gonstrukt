apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: {{ .ProjectName }}-ingress
  namespace: {{ .ProjectName }}
  annotations:
    nginx.ingress.kubernetes.io/ssl-redirect: "true"
    nginx.ingress.kubernetes.io/proxy-body-size: "10m"
    nginx.ingress.kubernetes.io/proxy-read-timeout: "60"
    nginx.ingress.kubernetes.io/proxy-send-timeout: "60"
spec:
  ingressClassName: nginx
  tls:
    - hosts:
        - {{ .Domain }}
      secretName: {{ .ProjectName }}-tls
  rules:
    - host: {{ .Domain }}
      http:
        paths:
          - path: /api
            pathType: Prefix
            backend:
              service:
                name: gateway-ext
                port:
                  number: 8080
{{- if .HasObservability }}
          - path: /grafana
            pathType: Prefix
            backend:
              service:
                name: monitoring-grafana
                port:
                  number: 80
          - path: /jaeger
            pathType: Prefix
            backend:
              service:
                name: jaeger
                port:
                  number: 16686
{{- end }}
{{- if .HasFrontend }}
          - path: /
            pathType: Prefix
            backend:
              service:
                name: frontend-ext
                port:
                  number: 3000
{{- end }}
