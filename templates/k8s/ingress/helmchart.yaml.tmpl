apiVersion: helm.cattle.io/v1
kind: HelmChart
metadata:
  name: ingress-nginx
  namespace: kube-system
spec:
  repo: https://kubernetes.github.io/ingress-nginx
  chart: ingress-nginx
  version: "4.14.3"
  targetNamespace: ingress-nginx
  createNamespace: true
  valuesContent: |-
    controller:
      ingressClassResource:
        default: true
      service:
        type: LoadBalancer
