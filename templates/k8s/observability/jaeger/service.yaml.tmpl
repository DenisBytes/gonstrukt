apiVersion: v1
kind: Service
metadata:
  name: jaeger
  namespace: {{ .ProjectName }}
  labels:
    app: jaeger
    app.kubernetes.io/part-of: {{ .ProjectName }}
spec:
  type: ClusterIP
  selector:
    app: jaeger
  ports:
    - name: ui
      port: 16686
      targetPort: 16686
    - name: otlp-grpc
      port: 4317
      targetPort: 4317
    - name: otlp-http
      port: 4318
      targetPort: 4318
