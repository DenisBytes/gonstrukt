apiVersion: apps/v1
kind: Deployment
metadata:
  name: jaeger
  namespace: {{ .ProjectName }}
  labels:
    app: jaeger
    app.kubernetes.io/part-of: {{ .ProjectName }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: jaeger
  template:
    metadata:
      labels:
        app: jaeger
        app.kubernetes.io/part-of: {{ .ProjectName }}
    spec:
      containers:
        - name: jaeger
          image: jaegertracing/jaeger:2.15.1
          args:
            - --config
            - /etc/jaeger/jaeger-config.yaml
          ports:
            - name: ui
              containerPort: 16686
            - name: otlp-grpc
              containerPort: 4317
            - name: otlp-http
              containerPort: 4318
          volumeMounts:
            - name: jaeger-config
              mountPath: /etc/jaeger
            - name: badger-data
              mountPath: /badger
          resources:
            requests:
              cpu: 100m
              memory: 256Mi
            limits:
              cpu: 500m
              memory: 512Mi
          readinessProbe:
            httpGet:
              path: /jaeger
              port: 16686
            initialDelaySeconds: 10
            periodSeconds: 10
          livenessProbe:
            httpGet:
              path: /jaeger
              port: 16686
            initialDelaySeconds: 30
            periodSeconds: 30
      volumes:
        - name: jaeger-config
          configMap:
            name: jaeger-config
        - name: badger-data
          persistentVolumeClaim:
            claimName: jaeger-badger-data
