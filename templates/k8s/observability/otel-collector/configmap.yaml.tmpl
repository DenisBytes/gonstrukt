apiVersion: v1
kind: ConfigMap
metadata:
  name: otel-collector-config
  namespace: {{ .ProjectName }}
  labels:
    app: otel-collector
    app.kubernetes.io/part-of: {{ .ProjectName }}
data:
  otel-collector-config.yaml: |
    receivers:
      otlp:
        protocols:
          grpc:
            endpoint: 0.0.0.0:4317
          http:
            endpoint: 0.0.0.0:4318

    processors:
      memory_limiter:
        check_interval: 5s
        limit_mib: 256
        spike_limit_mib: 64

      resource:
        attributes:
          - key: environment
            value: development
            action: upsert
          - key: service.namespace
            value: {{ .ProjectName }}
            action: upsert

      attributes/redact-ip:
        actions:
          - key: net.peer.ip
            action: delete
          - key: net.host.ip
            action: delete
          - key: http.client_ip
            action: hash

      batch:
        timeout: 5s
        send_batch_size: 512
        send_batch_max_size: 1024

    exporters:
      otlp/jaeger:
        endpoint: jaeger.{{ .ProjectName }}.svc.cluster.local:4317
        tls:
          insecure: true

      prometheusremotewrite:
        endpoint: http://monitoring-prometheus.{{ .ProjectName }}.svc.cluster.local:9090/api/v1/write
        tls:
          insecure: true

    service:
      pipelines:
        traces:
          receivers: [otlp]
          processors: [memory_limiter, resource, attributes/redact-ip, batch]
          exporters: [otlp/jaeger]
        metrics:
          receivers: [otlp]
          processors: [memory_limiter, resource, batch]
          exporters: [prometheusremotewrite]
