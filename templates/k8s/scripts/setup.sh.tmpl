#!/usr/bin/env bash
set -euo pipefail

NAMESPACE="{{ .ProjectName }}"
DOMAIN="{{ .Domain }}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
K8S_DIR="$(dirname "$SCRIPT_DIR")"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

info()  { echo -e "${BLUE}[INFO]${NC}  $*"; }
ok()    { echo -e "${GREEN}[OK]${NC}    $*"; }
warn()  { echo -e "${YELLOW}[WARN]${NC}  $*"; }
error() { echo -e "${RED}[ERROR]${NC} $*"; exit 1; }

# ─── 1. Install k3s ──────────────────────────────────────────────────────────
install_k3s() {
  if command -v k3s &>/dev/null; then
    ok "k3s is already installed: $(k3s --version | head -1)"
    return
  fi

  info "Installing k3s..."
  curl -sfL https://get.k3s.io | INSTALL_K3S_EXEC="server \
    --disable traefik \
    --kube-apiserver-arg service-node-port-range=30000-40000 \
    --write-kubeconfig-mode 644" sh -

  ok "k3s installed successfully"
}

# ─── 2. Set KUBECONFIG ───────────────────────────────────────────────────────
setup_kubeconfig() {
  export KUBECONFIG=/etc/rancher/k3s/k3s.yaml
  info "KUBECONFIG set to $KUBECONFIG"

  if [ ! -f "$KUBECONFIG" ]; then
    error "k3s kubeconfig not found at $KUBECONFIG. Is k3s running?"
  fi
}

# ─── 3. Wait for k3s node ready ──────────────────────────────────────────────
wait_for_node() {
  info "Waiting for k3s node to be ready..."
  local retries=30
  for i in $(seq 1 $retries); do
    if kubectl get nodes | grep -q " Ready"; then
      ok "k3s node is ready"
      return
    fi
    echo -n "."
    sleep 2
  done
  error "k3s node did not become ready within ${retries} attempts"
}

# ─── 4. Generate TLS certificates ────────────────────────────────────────────
generate_tls_certs() {
  if ! command -v mkcert &>/dev/null; then
    warn "mkcert not found. Installing..."
    if command -v apt-get &>/dev/null; then
      sudo apt-get update && sudo apt-get install -y libnss3-tools
    fi
    curl -JLO "https://dl.filippo.io/mkcert/latest?for=linux/amd64"
    chmod +x mkcert-v*-linux-amd64
    sudo mv mkcert-v*-linux-amd64 /usr/local/bin/mkcert
    mkcert -install
  fi

  info "Generating TLS certificates for ${DOMAIN}..."
  local cert_dir="${K8S_DIR}/certs"
  mkdir -p "$cert_dir"
  mkcert -key-file "${cert_dir}/key.pem" -cert-file "${cert_dir}/cert.pem" \
    "${DOMAIN}" "*.${DOMAIN}"
  ok "TLS certificates generated in ${cert_dir}"
}

# ─── 5. Add domain to /etc/hosts ─────────────────────────────────────────────
setup_hosts() {
  if grep -q "${DOMAIN}" /etc/hosts; then
    ok "${DOMAIN} already in /etc/hosts"
  else
    info "Adding ${DOMAIN} to /etc/hosts..."
    echo "127.0.0.1 ${DOMAIN}" | sudo tee -a /etc/hosts >/dev/null
    ok "${DOMAIN} added to /etc/hosts"
  fi
}

# ─── 6. Detect host IP ───────────────────────────────────────────────────────
detect_host_ip() {
  HOST_IP=$(ip route get 1 | awk '{print $7; exit}' 2>/dev/null || hostname -I | awk '{print $1}')
  if [ -z "$HOST_IP" ]; then
    error "Could not detect host IP address"
  fi
  info "Detected host IP: ${HOST_IP}"
}

# ─── 7. Create namespace ─────────────────────────────────────────────────────
create_namespace() {
  info "Creating namespace ${NAMESPACE}..."
  kubectl apply -f "${K8S_DIR}/namespace.yaml"
  ok "Namespace ${NAMESPACE} created"
}

# ─── 8. Install Nginx Ingress ────────────────────────────────────────────────
install_ingress() {
  info "Installing Nginx Ingress Controller..."
  kubectl apply -f "${K8S_DIR}/ingress/helmchart.yaml"

  info "Waiting for ingress-nginx namespace..."
  local retries=30
  for i in $(seq 1 $retries); do
    if kubectl get ns ingress-nginx &>/dev/null; then
      break
    fi
    sleep 2
  done

  info "Waiting for Nginx Ingress Controller to be ready..."
  for i in $(seq 1 $retries); do
    if kubectl -n ingress-nginx get pods 2>/dev/null | grep -q "Running"; then
      ok "Nginx Ingress Controller is ready"
      return
    fi
    sleep 5
  done
  warn "Ingress controller may still be starting up"
}

# ─── 9. Create TLS secret ────────────────────────────────────────────────────
create_tls_secret() {
  local cert_dir="${K8S_DIR}/certs"
  info "Creating TLS secret in namespace ${NAMESPACE}..."
  kubectl create secret tls "${NAMESPACE}-tls" \
    --cert="${cert_dir}/cert.pem" \
    --key="${cert_dir}/key.pem" \
    -n "${NAMESPACE}" \
    --dry-run=client -o yaml | kubectl apply -f -
  ok "TLS secret created"
}

# ─── 10. Apply external services ─────────────────────────────────────────────
apply_external_services() {
  info "Applying external services (host IP: ${HOST_IP})..."

  sed "s/__HOST_IP__/${HOST_IP}/g" "${K8S_DIR}/services/gateway-ext.yaml" | kubectl apply -f -
  sed "s/__HOST_IP__/${HOST_IP}/g" "${K8S_DIR}/services/auth-ext.yaml" | kubectl apply -f -
{{- if .HasFrontend }}
  sed "s/__HOST_IP__/${HOST_IP}/g" "${K8S_DIR}/services/frontend-ext.yaml" | kubectl apply -f -
{{- end }}

  ok "External services applied"
}

# ─── 11. Deploy Redis ────────────────────────────────────────────────────────
{{- if or (eq .CacheType "redis") (eq .CacheType "valkey") }}
deploy_redis() {
  info "Deploying Redis..."
  kubectl apply -f "${K8S_DIR}/redis/pvc.yaml"
  kubectl apply -f "${K8S_DIR}/redis/deployment.yaml"
  kubectl apply -f "${K8S_DIR}/redis/service.yaml"
  ok "Redis deployed"
}
{{- end }}

# ─── 12. Deploy observability stack ──────────────────────────────────────────
{{- if .HasObservability }}
deploy_observability() {
  info "Deploying Jaeger..."
  kubectl apply -f "${K8S_DIR}/observability/jaeger/configmap.yaml"
  kubectl apply -f "${K8S_DIR}/observability/jaeger/pvc.yaml"
  kubectl apply -f "${K8S_DIR}/observability/jaeger/deployment.yaml"
  kubectl apply -f "${K8S_DIR}/observability/jaeger/service.yaml"
  ok "Jaeger deployed"

  info "Deploying OTel Collector..."
  kubectl apply -f "${K8S_DIR}/observability/otel-collector/configmap.yaml"
  kubectl apply -f "${K8S_DIR}/observability/otel-collector/deployment.yaml"
  kubectl apply -f "${K8S_DIR}/observability/otel-collector/service.yaml"
  ok "OTel Collector deployed"

  info "Deploying Prometheus + Grafana (kube-prometheus-stack)..."
  kubectl apply -f "${K8S_DIR}/observability/prometheus/helmchart.yaml"
  ok "Prometheus stack deployment initiated"

  info "Applying Grafana dashboards..."
  kubectl apply -f "${K8S_DIR}/observability/grafana/dashboards-configmap.yaml"
  ok "Grafana dashboards applied"
}

# ─── 13. Apply Redis ServiceMonitor ──────────────────────────────────────────
apply_redis_servicemonitor() {
{{- if or (eq .CacheType "redis") (eq .CacheType "valkey") }}
  info "Waiting for ServiceMonitor CRD to be available..."
  local retries=60
  for i in $(seq 1 $retries); do
    if kubectl get crd servicemonitors.monitoring.coreos.com &>/dev/null; then
      ok "ServiceMonitor CRD is available"
      kubectl apply -f "${K8S_DIR}/observability/prometheus/redis-servicemonitor.yaml"
      ok "Redis ServiceMonitor applied"
      return
    fi
    sleep 5
  done
  warn "ServiceMonitor CRD not available after ${retries} attempts. Apply redis-servicemonitor.yaml manually later."
{{- else }}
  info "No Redis cache configured, skipping ServiceMonitor"
{{- end }}
}
{{- end }}

# ─── 14. Deploy Fluent Bit (conditional on AXIOM_TOKEN) ──────────────────────
{{- if .HasObservability }}
deploy_fluent_bit() {
  if [ -n "${AXIOM_TOKEN:-}" ]; then
    info "AXIOM_TOKEN detected. Deploying Fluent Bit for log shipping..."
    kubectl create secret generic axiom-credentials \
      --from-literal=token="${AXIOM_TOKEN}" \
      -n "${NAMESPACE}" \
      --dry-run=client -o yaml | kubectl apply -f -
    kubectl apply -f "${K8S_DIR}/observability/fluent-bit/helmchart.yaml"
    ok "Fluent Bit deployed"
  else
    warn "AXIOM_TOKEN not set. Skipping Fluent Bit deployment."
    warn "To enable log shipping, set AXIOM_TOKEN and re-run this script."
  fi
}
{{- end }}

# ─── 15. Apply ingress rules ─────────────────────────────────────────────────
apply_ingress() {
  info "Applying ingress rules..."
  kubectl apply -f "${K8S_DIR}/ingress/ingress.yaml"
  ok "Ingress rules applied"
}

# ─── 16. Wait for pods to be ready ───────────────────────────────────────────
wait_for_pods() {
  info "Waiting for all pods in ${NAMESPACE} to be ready..."
  local retries=60
  for i in $(seq 1 $retries); do
    local not_ready
    not_ready=$(kubectl get pods -n "${NAMESPACE}" --no-headers 2>/dev/null | grep -cv "Running\|Completed" || true)
    if [ "$not_ready" -eq 0 ] 2>/dev/null; then
      local total
      total=$(kubectl get pods -n "${NAMESPACE}" --no-headers 2>/dev/null | wc -l)
      if [ "$total" -gt 0 ]; then
        ok "All ${total} pods are ready in ${NAMESPACE}"
        return
      fi
    fi
    echo -n "."
    sleep 5
  done
  echo ""
  warn "Some pods may still be starting. Check with: kubectl get pods -n ${NAMESPACE}"
}

# ─── 17. Print access URLs ───────────────────────────────────────────────────
print_urls() {
  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo -e "${GREEN} {{ .ProjectName }} - Local Dev Environment Ready${NC}"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""
  printf "  %-24s %s\n" "Service" "URL"
  echo "  ────────────────────────────────────────────────────────────"
  printf "  %-24s %s\n" "Gateway API" "https://${DOMAIN}/api"
  printf "  %-24s %s\n" "Auth API" "localhost:8081"
{{- if .HasFrontend }}
  printf "  %-24s %s\n" "Frontend" "https://${DOMAIN}/"
{{- end }}
{{- if .HasObservability }}
  printf "  %-24s %s\n" "Grafana" "https://${DOMAIN}/grafana"
  printf "  %-24s %s\n" "Jaeger" "https://${DOMAIN}/jaeger"
  printf "  %-24s %s\n" "OTel Collector (gRPC)" "localhost:34317"
  printf "  %-24s %s\n" "OTel Collector (HTTP)" "localhost:34318"
{{- end }}
{{- if or (eq .CacheType "redis") (eq .CacheType "valkey") }}
  printf "  %-24s %s\n" "Redis" "localhost:36379"
{{- end }}
  echo ""
  echo "  KUBECONFIG: /etc/rancher/k3s/k3s.yaml"
  echo "  Namespace:  ${NAMESPACE}"
  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
}

# ─── Main ─────────────────────────────────────────────────────────────────────
main() {
  echo ""
  info "Setting up {{ .ProjectName }} k3s dev environment..."
  echo ""

  install_k3s
  setup_kubeconfig
  wait_for_node
  generate_tls_certs
  setup_hosts
  detect_host_ip
  create_namespace
  install_ingress
  create_tls_secret
  apply_external_services
{{- if or (eq .CacheType "redis") (eq .CacheType "valkey") }}
  deploy_redis
{{- end }}
{{- if .HasObservability }}
  deploy_observability
  apply_redis_servicemonitor
  deploy_fluent_bit
{{- end }}
  apply_ingress
  wait_for_pods
  print_urls
}

main "$@"
