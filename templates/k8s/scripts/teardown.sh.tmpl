#!/usr/bin/env bash
set -euo pipefail

NAMESPACE="{{ .ProjectName }}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
K8S_DIR="$(dirname "$SCRIPT_DIR")"

export KUBECONFIG=/etc/rancher/k3s/k3s.yaml

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

info()  { echo -e "${BLUE}[INFO]${NC}  $*"; }
ok()    { echo -e "${GREEN}[OK]${NC}    $*"; }
warn()  { echo -e "${YELLOW}[WARN]${NC}  $*"; }

echo ""
info "Tearing down {{ .ProjectName }} k3s dev environment..."
echo ""

# ─── Remove ingress rules ────────────────────────────────────────────────────
info "Removing ingress rules..."
kubectl delete -f "${K8S_DIR}/ingress/ingress.yaml" --ignore-not-found
ok "Ingress rules removed"

# ─── Remove Fluent Bit ───────────────────────────────────────────────────────
{{- if .HasObservability }}
info "Removing Fluent Bit..."
kubectl delete -f "${K8S_DIR}/observability/fluent-bit/helmchart.yaml" --ignore-not-found
kubectl delete secret axiom-credentials -n "${NAMESPACE}" --ignore-not-found
ok "Fluent Bit removed"

# ─── Remove Redis ServiceMonitor ─────────────────────────────────────────────
{{- if or (eq .CacheType "redis") (eq .CacheType "valkey") }}
info "Removing Redis ServiceMonitor..."
kubectl delete -f "${K8S_DIR}/observability/prometheus/redis-servicemonitor.yaml" --ignore-not-found
ok "Redis ServiceMonitor removed"
{{- end }}

# ─── Remove observability stack ──────────────────────────────────────────────
info "Removing Grafana dashboards..."
kubectl delete -f "${K8S_DIR}/observability/grafana/dashboards-configmap.yaml" --ignore-not-found
ok "Grafana dashboards removed"

info "Removing Prometheus + Grafana..."
kubectl delete -f "${K8S_DIR}/observability/prometheus/helmchart.yaml" --ignore-not-found
ok "Prometheus stack removed"

info "Removing OTel Collector..."
kubectl delete -f "${K8S_DIR}/observability/otel-collector/service.yaml" --ignore-not-found
kubectl delete -f "${K8S_DIR}/observability/otel-collector/deployment.yaml" --ignore-not-found
kubectl delete -f "${K8S_DIR}/observability/otel-collector/configmap.yaml" --ignore-not-found
ok "OTel Collector removed"

info "Removing Jaeger..."
kubectl delete -f "${K8S_DIR}/observability/jaeger/service.yaml" --ignore-not-found
kubectl delete -f "${K8S_DIR}/observability/jaeger/deployment.yaml" --ignore-not-found
kubectl delete -f "${K8S_DIR}/observability/jaeger/configmap.yaml" --ignore-not-found
kubectl delete -f "${K8S_DIR}/observability/jaeger/pvc.yaml" --ignore-not-found
ok "Jaeger removed"
{{- end }}

# ─── Remove Redis ────────────────────────────────────────────────────────────
{{- if or (eq .CacheType "redis") (eq .CacheType "valkey") }}
info "Removing Redis..."
kubectl delete -f "${K8S_DIR}/redis/service.yaml" --ignore-not-found
kubectl delete -f "${K8S_DIR}/redis/deployment.yaml" --ignore-not-found
kubectl delete -f "${K8S_DIR}/redis/pvc.yaml" --ignore-not-found
ok "Redis removed"
{{- end }}

# ─── Remove external services ────────────────────────────────────────────────
info "Removing external services..."
kubectl delete -f "${K8S_DIR}/services/gateway-ext.yaml" --ignore-not-found
kubectl delete -f "${K8S_DIR}/services/auth-ext.yaml" --ignore-not-found
{{- if .HasFrontend }}
kubectl delete -f "${K8S_DIR}/services/frontend-ext.yaml" --ignore-not-found
{{- end }}
ok "External services removed"

# ─── Remove TLS secret ───────────────────────────────────────────────────────
info "Removing TLS secret..."
kubectl delete secret "${NAMESPACE}-tls" -n "${NAMESPACE}" --ignore-not-found
ok "TLS secret removed"

# ─── Remove Nginx Ingress ────────────────────────────────────────────────────
info "Removing Nginx Ingress Controller..."
kubectl delete -f "${K8S_DIR}/ingress/helmchart.yaml" --ignore-not-found
ok "Nginx Ingress Controller removed"

# ─── Remove namespace ────────────────────────────────────────────────────────
info "Removing namespace ${NAMESPACE}..."
kubectl delete -f "${K8S_DIR}/namespace.yaml" --ignore-not-found
ok "Namespace ${NAMESPACE} removed"

# ─── Clean up certificates ───────────────────────────────────────────────────
if [ -d "${K8S_DIR}/certs" ]; then
  info "Removing generated certificates..."
  rm -rf "${K8S_DIR}/certs"
  ok "Certificates removed"
fi

echo ""
ok "Teardown complete."
echo ""
info "Note: k3s itself was NOT uninstalled."
info "To fully remove k3s, run: /usr/local/bin/k3s-uninstall.sh"
info "To remove ${DOMAIN} from /etc/hosts, run:"
info "  sudo sed -i '/${DOMAIN}/d' /etc/hosts"
echo ""
