module {{.ModuleName}}

go {{.GoVersion}}

require (
	go.uber.org/zap v1.27.0
	github.com/google/uuid v1.6.0
	github.com/golang-jwt/jwt/v5 v5.2.0
	golang.org/x/crypto v0.21.0
{{- if .EnableRBAC}}
	github.com/casbin/casbin/v2 v2.135.0
{{- end}}
{{- if .EnableMFA}}
	github.com/pquerna/otp v1.5.0
{{- end}}
{{- if .HasObservability}}
	go.opentelemetry.io/otel v1.24.0
	go.opentelemetry.io/otel/exporters/otlp/otlptrace/otlptracegrpc v1.24.0
	go.opentelemetry.io/otel/exporters/otlp/otlpmetric/otlpmetricgrpc v1.24.0
	go.opentelemetry.io/otel/sdk v1.24.0
	go.opentelemetry.io/otel/trace v1.24.0
	go.opentelemetry.io/otel/metric v1.24.0
{{- end}}
{{- if eq .Config "yaml"}}
	gopkg.in/yaml.v3 v3.0.1
{{- end}}
{{- if eq .Config "vault"}}
	github.com/hashicorp/vault/api v1.12.0
{{- end}}
{{- if eq .Database "postgres"}}
	github.com/jackc/pgx/v5 v5.5.5
{{- end}}
{{- if eq .Database "mysql"}}
	github.com/go-sql-driver/mysql v1.8.1
{{- end}}
{{- if eq .Database "sqlite"}}
	modernc.org/sqlite v1.29.5
{{- end}}
{{- if eq .Database "mongodb"}}
	go.mongodb.org/mongo-driver v1.14.0
{{- end}}
{{- if eq .Database "arangodb"}}
	github.com/arangodb/go-driver/v2 v2.0.3
{{- end}}
{{- if or .HasGoogleOAuth .HasMicrosoftOAuth}}
	golang.org/x/oauth2 v0.35.0
{{- end}}
{{- if .HasAppleOAuth}}
	github.com/Timothylock/go-signin-with-apple v0.2.7
{{- end}}
{{- if .HasSESEmail}}
	github.com/aws/aws-sdk-go-v2 v1.41.2
	github.com/aws/aws-sdk-go-v2/config v1.32.10
	github.com/aws/aws-sdk-go-v2/service/ses v1.34.19
{{- end}}
{{- if or (eq .CacheType "redis") (eq .CacheType "valkey")}}
	github.com/redis/go-redis/v9 v9.5.1
{{- end}}
)
