{{- if .HasAppleOAuth}}
package oauth

import (
	"context"
	"fmt"
	"time"

	"{{.ModuleName}}/internals/db"
	"{{.ModuleName}}/internals/types"

	"github.com/Timothylock/go-signin-with-apple/apple"
	"github.com/google/uuid"
)

// AppleOAuthConfig holds Apple Sign In configuration
type AppleOAuthConfig struct {
	ClientID    string // Your Services ID (e.g., com.yourapp.auth)
	TeamID      string // Your Apple Developer Team ID
	KeyID       string // Your Sign In with Apple Key ID
	PrivateKey  string // Your Sign In with Apple private key (PEM format)
	RedirectURL string
}

// AppleProvider handles Apple Sign In authentication
type AppleProvider struct {
	config AppleOAuthConfig
	db     db.Database
}

// AppleUserInfo represents the user info from Apple
type AppleUserInfo struct {
	ID        string `json:"sub"`
	Email     string `json:"email"`
	FirstName string `json:"-"`
	LastName  string `json:"-"`
}

// NewAppleProvider creates a new Apple Sign In provider
func NewAppleProvider(cfg AppleOAuthConfig, database db.Database) *AppleProvider {
	return &AppleProvider{
		config: cfg,
		db:     database,
	}
}

// GetAuthURL returns the OAuth authorization URL for Apple Sign In
func (p *AppleProvider) GetAuthURL(state string) string {
	return fmt.Sprintf(
		"https://appleid.apple.com/auth/authorize?client_id=%s&redirect_uri=%s&response_type=code&scope=name%%20email&response_mode=form_post&state=%s",
		p.config.ClientID,
		p.config.RedirectURL,
		state,
	)
}

// HandleCallback handles the Apple Sign In callback
func (p *AppleProvider) HandleCallback(ctx context.Context, code string, firstName, lastName string) (*types.User, error) {
	// Generate client secret (Apple requires a JWT)
	secret, err := apple.GenerateClientSecret(
		p.config.PrivateKey,
		p.config.TeamID,
		p.config.ClientID,
		p.config.KeyID,
	)
	if err != nil {
		return nil, fmt.Errorf("failed to generate client secret: %w", err)
	}

	// Exchange code for token
	client := apple.New()
	req := apple.AppValidationTokenRequest{
		ClientID:     p.config.ClientID,
		ClientSecret: secret,
		Code:         code,
	}

	var resp apple.ValidationResponse
	if err := client.VerifyAppToken(ctx, req, &resp); err != nil {
		return nil, fmt.Errorf("failed to verify token: %w", err)
	}

	// Parse ID token to get user info
	claim, err := apple.GetClaims(resp.IDToken)
	if err != nil {
		return nil, fmt.Errorf("failed to get claims: %w", err)
	}

	email := (*claim)["email"].(string)
	sub := (*claim)["sub"].(string)

	// Check if user exists
	user, err := p.db.GetUserByOAuthID(ctx, "apple", sub)
	if err == nil && user != nil {
		return user, nil
	}

	// Check by email as fallback
	user, err = p.db.GetUserByEmail(ctx, email)
	if err == nil && user != nil {
		// Link OAuth account
		user.OAuthProvider = "apple"
		user.OAuthID = sub
		if err := p.db.UpdateUser(ctx, user); err != nil {
			return nil, fmt.Errorf("failed to link OAuth account: %w", err)
		}
		return user, nil
	}

	// Create new user
	// Note: Apple only provides name on first sign-in
	user = &types.User{
		ID:            uuid.New().String(),
		Email:         email,
		FirstName:     firstName,
		LastName:      lastName,
		OAuthProvider: "apple",
		OAuthID:       sub,
		CreatedAt:     time.Now(),
		UpdatedAt:     time.Now(),
	}

	if err := p.db.CreateUser(ctx, user); err != nil {
		return nil, fmt.Errorf("failed to create user: %w", err)
	}

	return user, nil
}

// ProviderName returns the provider name
func (p *AppleProvider) ProviderName() string {
	return "apple"
}
{{- end}}
