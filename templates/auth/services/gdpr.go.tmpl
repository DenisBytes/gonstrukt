// Consent type constants
const (
	ConsentTypeEssential      = "essential"
	ConsentTypeAnalytics      = "analytics"
	ConsentTypeMarketing      = "marketing"
	ConsentTypeDataProcessing = "data_processing"

	// Consent version - increment when terms change
	ConsentVersion = "1.0.0"

	// Default consent expiry (1 year)
	ConsentExpiryDuration = 365 * 24 * time.Hour
)

// ConsentResponse represents a consent record in API responses
type ConsentResponse struct {
	Type      string    `json:"type"`
	Agreed    bool      `json:"agreed"`
	Version   string    `json:"version"`
	GrantedAt time.Time `json:"granted_at"`
	ExpiresAt time.Time `json:"expires_at"`
}

// ConsentUpdateRequest represents a consent update request
type ConsentUpdateRequest struct {
	Type   string `json:"type"`
	Agreed bool   `json:"agreed"`
}

{{- if .HasGDPRConsent}}

// handleGetConsent returns all active consents for the authenticated user
// GET /api/v1/auth/gdpr/consent
func (s *AuthService) handleGetConsent(w http.ResponseWriter, r *http.Request) {
	ctx := r.Context()
{{- if .HasObservability}}
	span := trace.SpanFromContext(ctx)
{{- end}}

	// Get authenticated user from context
	user, ok := s.getUserFromContext(ctx)
	if !ok || user == nil {
{{- if .HasObservability}}
		span.SetStatus(codes.Error, "User not found in context")
{{- end}}
		http.Error(w, "unauthorized", http.StatusUnauthorized)
		return
	}

{{- if .HasObservability}}
	span.SetAttributes(
		attribute.String("user.id", user.ID),
		attribute.String("gdpr.action", "get_consents"),
	)
{{- end}}

	// Get active consents
	consents, err := s.db.GetActiveConsentsByUserID(ctx, user.ID)
	if err != nil {
{{- if .HasObservability}}
		span.RecordError(err)
{{- end}}
		http.Error(w, "internal server error", http.StatusInternalServerError)
		return
	}

	// Convert to response format
	response := make([]ConsentResponse, len(consents))
	for i, c := range consents {
		response[i] = ConsentResponse{
			Type:      c.Type,
			Agreed:    c.Granted,
			Version:   c.Version,
			GrantedAt: c.GrantedAt,
			ExpiresAt: c.ExpiresAt,
		}
	}

{{- if .HasObservability}}
	span.SetStatus(codes.Ok, "Consents retrieved")
{{- end}}
	w.Header().Set("Content-Type", "application/json")
	json.NewEncoder(w).Encode(response)
}

// handleUpdateConsent updates or creates a consent record
// PUT /api/v1/auth/gdpr/consent
func (s *AuthService) handleUpdateConsent(w http.ResponseWriter, r *http.Request) {
	ctx := r.Context()
{{- if .HasObservability}}
	span := trace.SpanFromContext(ctx)
{{- end}}

	// Get authenticated user from context
	user, ok := s.getUserFromContext(ctx)
	if !ok || user == nil {
{{- if .HasObservability}}
		span.SetStatus(codes.Error, "User not found in context")
{{- end}}
		http.Error(w, "unauthorized", http.StatusUnauthorized)
		return
	}

{{- if .HasObservability}}
	span.SetAttributes(
		attribute.String("user.id", user.ID),
		attribute.String("gdpr.action", "update_consent"),
	)
{{- end}}

	// Parse request
	var req ConsentUpdateRequest
	if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
{{- if .HasObservability}}
		span.RecordError(err)
{{- end}}
		http.Error(w, "invalid request body", http.StatusBadRequest)
		return
	}

	// Validate consent type
	validTypes := map[string]bool{
		ConsentTypeEssential:      true,
		ConsentTypeAnalytics:      true,
		ConsentTypeMarketing:      true,
		ConsentTypeDataProcessing: true,
	}
	if !validTypes[req.Type] {
		http.Error(w, "invalid consent type", http.StatusBadRequest)
		return
	}

	// Essential consent cannot be revoked
	if req.Type == ConsentTypeEssential && !req.Agreed {
		http.Error(w, "essential consent cannot be revoked", http.StatusBadRequest)
		return
	}

{{- if .HasObservability}}
	span.SetAttributes(
		attribute.String("consent.type", req.Type),
		attribute.Bool("consent.agreed", req.Agreed),
	)
{{- end}}

	// Create new consent record (versioned, never update in place)
	expiresAt := time.Now().Add(ConsentExpiryDuration)
	consent := &types.Consent{
		ID:        uuid.New().String(),
		UserID:    user.ID,
		Type:      req.Type,
		Granted:   req.Agreed,
		GrantedAt: time.Now(),
		ExpiresAt: expiresAt,
		Version:   ConsentVersion,
	}

	if err := s.db.CreateConsent(ctx, consent); err != nil {
{{- if .HasObservability}}
		span.RecordError(err)
{{- end}}
		http.Error(w, "internal server error", http.StatusInternalServerError)
		return
	}

{{- if .HasGDPRProcessingLogs}}
	// Log data processing for GDPR audit trail
	legalBasis := "consent"
	if !req.Agreed {
		legalBasis = "consent_withdrawal"
	}
	s.logDataProcessing(ctx, user.ID, "consent_update", req.Type, r.RemoteAddr, legalBasis)
{{- end}}

{{- if .HasObservability}}
	span.SetStatus(codes.Ok, "Consent updated")
{{- end}}

	w.Header().Set("Content-Type", "application/json")
	json.NewEncoder(w).Encode(ConsentResponse{
		Type:      consent.Type,
		Agreed:    consent.Granted,
		Version:   consent.Version,
		GrantedAt: consent.GrantedAt,
		ExpiresAt: consent.ExpiresAt,
	})
}

