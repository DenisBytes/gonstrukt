// handleUpdateMemberRole updates a member's role in the current tenant
func (s *AuthService) handleUpdateMemberRole(w http.ResponseWriter, r *http.Request) {
	userID, ok := middleware.GetUserID(r.Context())
	if !ok {
		writeError(w, http.StatusUnauthorized, "unauthorized")
		return
	}

	claims, ok := middleware.GetClaims(r.Context())
	if !ok {
		writeError(w, http.StatusUnauthorized, "unauthorized")
		return
	}

	tenantID, _ := claims["tenant_id"].(string)
	if tenantID == "" {
		writeError(w, http.StatusBadRequest, "tenant-scoped token required")
		return
	}

	memberID := r.PathValue("user_id")
	if memberID == "" {
		writeError(w, http.StatusBadRequest, "user ID required")
		return
	}

	var req types.UpdateMemberRoleRequest
	if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
		writeError(w, http.StatusBadRequest, "invalid request body")
		return
	}

	if err := req.Validate(); err != nil {
		writeError(w, http.StatusBadRequest, err.Error())
		return
	}

	// Prevent changing own role
	if memberID == userID {
		writeError(w, http.StatusBadRequest, "cannot change your own role")
		return
	}

	// Prevent changing the owner's role
	targetMembership, err := s.db.GetUserTenant(r.Context(), memberID, tenantID)
	if err != nil {
		writeError(w, http.StatusNotFound, "member not found")
		return
	}

	if targetMembership.IsOwner {
		writeError(w, http.StatusForbidden, "cannot change the owner's role")
		return
	}

	if err := s.db.UpdateUserTenantRole(r.Context(), memberID, tenantID, req.Roles); err != nil {
		writeError(w, http.StatusInternalServerError, "failed to update member role")
		return
	}

	writeJSON(w, http.StatusOK, map[string]string{"status": "updated"})
}

// handleRemoveMember removes a member from the current tenant
func (s *AuthService) handleRemoveMember(w http.ResponseWriter, r *http.Request) {
	userID, ok := middleware.GetUserID(r.Context())
	if !ok {
		writeError(w, http.StatusUnauthorized, "unauthorized")
		return
	}

	claims, ok := middleware.GetClaims(r.Context())
	if !ok {
		writeError(w, http.StatusUnauthorized, "unauthorized")
		return
	}

	tenantID, _ := claims["tenant_id"].(string)
	if tenantID == "" {
		writeError(w, http.StatusBadRequest, "tenant-scoped token required")
		return
	}

	memberID := r.PathValue("user_id")
	if memberID == "" {
		writeError(w, http.StatusBadRequest, "user ID required")
		return
	}

	// Prevent removing self
	if memberID == userID {
		writeError(w, http.StatusBadRequest, "cannot remove yourself; use leave workspace instead")
		return
	}

	// Prevent removing the owner
	targetMembership, err := s.db.GetUserTenant(r.Context(), memberID, tenantID)
	if err != nil {
		writeError(w, http.StatusNotFound, "member not found")
		return
	}

	if targetMembership.IsOwner {
		writeError(w, http.StatusForbidden, "cannot remove the workspace owner")
		return
	}

	if err := s.db.DeleteUserTenant(r.Context(), memberID, tenantID); err != nil {
		writeError(w, http.StatusInternalServerError, "failed to remove member")
		return
	}

	writeJSON(w, http.StatusOK, map[string]string{"status": "removed"})
}
