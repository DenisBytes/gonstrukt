func setupAuthRouter(t *testing.T) http.Handler {
	t.Helper()
	svc := mustGetTestAuthService(t)

	mux := http.NewServeMux()
	svc.RegisterRoutes(mux)

	return mux
}

func TestHandlers_Register(t *testing.T) {
	t.Cleanup(func() {
		cleanupUsers(t)
		cleanupSessions(t)
	})

	router := setupAuthRouter(t)

	tests := []struct {
		name       string
		body       any
		wantStatus int
	}{
		{
			name: "register successfully",
			body: map[string]string{
				"email":      "handler-register@test.com",
				"password":   "password123",
				"first_name": "Test",
				"last_name":  "User",
			},
			wantStatus: http.StatusCreated,
		},
		{
			name: "register with missing email",
			body: map[string]string{
				"password": "password123",
			},
			wantStatus: http.StatusBadRequest,
		},
		{
			name: "register with missing password",
			body: map[string]string{
				"email": "nopassword@test.com",
			},
			wantStatus: http.StatusBadRequest,
		},
		{
			name:       "register with invalid body",
			body:       "invalid json",
			wantStatus: http.StatusBadRequest,
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			w := performRequest(router, http.MethodPost, "/api/v1/auth/register", tt.body, nil)

			if w.Code != tt.wantStatus {
				t.Errorf("Register handler status = %v, want %v, body = %s", w.Code, tt.wantStatus, w.Body.String())
				return
			}

			if tt.wantStatus == http.StatusCreated {
				var resp types.User
				if err := json.Unmarshal(w.Body.Bytes(), &resp); err != nil {
					t.Errorf("failed to unmarshal response: %v", err)
					return
				}
				if resp.ID == "" {
					t.Error("response user has empty ID")
				}
			}
		})
	}
}

func TestHandlers_Register_Duplicate(t *testing.T) {
	t.Cleanup(func() {
		cleanupUsers(t)
		cleanupSessions(t)
	})

	router := setupAuthRouter(t)

	body := map[string]string{
		"email":      "duplicate-handler@test.com",
		"password":   "password123",
		"first_name": "Test",
		"last_name":  "User",
	}

	// First registration
	w := performRequest(router, http.MethodPost, "/api/v1/auth/register", body, nil)
	if w.Code != http.StatusCreated {
		t.Fatalf("first register failed: status = %v", w.Code)
	}

	// Second registration with same email
	w = performRequest(router, http.MethodPost, "/api/v1/auth/register", body, nil)
	if w.Code != http.StatusConflict {
		t.Errorf("duplicate register status = %v, want %v", w.Code, http.StatusConflict)
	}
}

func TestHandlers_Login(t *testing.T) {
	t.Cleanup(func() {
		cleanupUsers(t)
		cleanupSessions(t)
	})

	router := setupAuthRouter(t)

	// Create a user first
	email := "handler-login@test.com"
	password := "password123"
	createTestUser(t, email, password)

	tests := []struct {
		name       string
		body       any
		wantStatus int
	}{
		{
			name: "login successfully",
			body: map[string]string{
				"email":    email,
				"password": password,
			},
			wantStatus: http.StatusOK,
		},
		{
			name: "login with wrong password",
			body: map[string]string{
				"email":    email,
				"password": "wrongpassword",
			},
			wantStatus: http.StatusUnauthorized,
		},
		{
			name: "login with non-existent user",
			body: map[string]string{
				"email":    "nonexistent@test.com",
				"password": "password123",
			},
			wantStatus: http.StatusUnauthorized,
		},
		{
			name:       "login with invalid body",
			body:       "invalid",
			wantStatus: http.StatusBadRequest,
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			w := performRequest(router, http.MethodPost, "/api/v1/auth/login", tt.body, nil)

			if w.Code != tt.wantStatus {
				t.Errorf("Login handler status = %v, want %v, body = %s", w.Code, tt.wantStatus, w.Body.String())
				return
			}

			if tt.wantStatus == http.StatusOK {
				var resp types.TokenResponse
				if err := json.Unmarshal(w.Body.Bytes(), &resp); err != nil {
					t.Errorf("failed to unmarshal response: %v", err)
					return
				}
				if resp.AccessToken == "" {
					t.Error("response has empty access token")
				}
				if resp.RefreshToken == "" {
					t.Error("response has empty refresh token")
				}
			}
		})
	}
}

