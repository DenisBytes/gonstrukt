func TestHandlers_RevokeAllSessions(t *testing.T) {
	t.Cleanup(func() {
		cleanupUsers(t)
		cleanupSessions(t)
	})

	router := setupAuthRouter(t)

	// Create and login a user multiple times
	email := "handler-revokeall@test.com"
	password := "password123"
	createTestUser(t, email, password)

	// Login 3 times
	for i := 0; i < 2; i++ {
		loginTestUser(t, email, password)
	}
	lastTokens := loginTestUser(t, email, password)

	headers := map[string]string{
		"Authorization": "Bearer " + lastTokens.AccessToken,
	}

	w := performRequest(router, http.MethodDelete, "/api/v1/auth/sessions", nil, headers)

	if w.Code != http.StatusOK {
		t.Fatalf("RevokeAllSessions handler status = %v, want %v, body = %s", w.Code, http.StatusOK, w.Body.String())
	}

	// Verify only current session remains
	w = performRequest(router, http.MethodGet, "/api/v1/auth/sessions", nil, headers)
	if w.Code != http.StatusOK {
		t.Fatalf("GetSessions after revoke status = %v", w.Code)
	}

	var sessions []types.SessionInfo
	if err := json.Unmarshal(w.Body.Bytes(), &sessions); err != nil {
		t.Fatalf("failed to unmarshal: %v", err)
	}

	if len(sessions) != 1 {
		t.Errorf("after RevokeAllSessions, %d sessions remain, want 1", len(sessions))
	}
}

