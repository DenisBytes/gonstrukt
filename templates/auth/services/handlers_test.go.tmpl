func TestHandlers_GetUser_Authenticated(t *testing.T) {
	t.Cleanup(func() {
		cleanupUsers(t)
		cleanupSessions(t)
	})

	router := setupAuthRouter(t)

	// Create and login a user
	email := "handler-getuser@test.com"
	password := "password123"
	createTestUser(t, email, password)
	tokens := loginTestUser(t, email, password)

	tests := []struct {
		name       string
		authHeader string
		wantStatus int
	}{
		{
			name:       "get user with valid token",
			authHeader: "Bearer " + tokens.AccessToken,
			wantStatus: http.StatusOK,
		},
		{
			name:       "get user without token",
			authHeader: "",
			wantStatus: http.StatusUnauthorized,
		},
		{
			name:       "get user with invalid token",
			authHeader: "Bearer invalid-token",
			wantStatus: http.StatusUnauthorized,
		},
		{
			name:       "get user with malformed auth header",
			authHeader: "NotBearer token",
			wantStatus: http.StatusUnauthorized,
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			headers := make(map[string]string)
			if tt.authHeader != "" {
				headers["Authorization"] = tt.authHeader
			}

			w := performRequest(router, http.MethodGet, "/api/v1/auth/user", nil, headers)

			if w.Code != tt.wantStatus {
				t.Errorf("GetUser handler status = %v, want %v, body = %s", w.Code, tt.wantStatus, w.Body.String())
				return
			}

			if tt.wantStatus == http.StatusOK {
				var resp types.User
				if err := json.Unmarshal(w.Body.Bytes(), &resp); err != nil {
					t.Errorf("failed to unmarshal response: %v", err)
					return
				}
				if resp.Email != email {
					t.Errorf("GetUser email = %v, want %v", resp.Email, email)
				}
			}
		})
	}
}

func TestHandlers_GetSessions(t *testing.T) {
	t.Cleanup(func() {
		cleanupUsers(t)
		cleanupSessions(t)
	})

	router := setupAuthRouter(t)

	// Create and login a user multiple times
	email := "handler-sessions@test.com"
	password := "password123"
	createTestUser(t, email, password)

	// Login 3 times
	var lastTokens *types.TokenResponse
	for i := 0; i < 3; i++ {
		lastTokens = loginTestUser(t, email, password)
	}

	headers := map[string]string{
		"Authorization": "Bearer " + lastTokens.AccessToken,
	}

	w := performRequest(router, http.MethodGet, "/api/v1/auth/sessions", nil, headers)

	if w.Code != http.StatusOK {
		t.Fatalf("GetSessions handler status = %v, want %v, body = %s", w.Code, http.StatusOK, w.Body.String())
	}

	var sessions []types.SessionInfo
	if err := json.Unmarshal(w.Body.Bytes(), &sessions); err != nil {
		t.Fatalf("failed to unmarshal response: %v", err)
	}

	if len(sessions) != 3 {
		t.Errorf("GetSessions returned %d sessions, want 3", len(sessions))
	}

	// Verify one session is marked as current
	currentCount := 0
	for _, s := range sessions {
		if s.IsCurrent {
			currentCount++
		}
	}
	if currentCount != 1 {
		t.Errorf("GetSessions has %d current sessions, want 1", currentCount)
	}
}

func TestHandlers_RevokeSession(t *testing.T) {
	t.Cleanup(func() {
		cleanupUsers(t)
		cleanupSessions(t)
	})

	router := setupAuthRouter(t)

	// Create and login a user twice
	email := "handler-revoke@test.com"
	password := "password123"
	createTestUser(t, email, password)

	firstTokens := loginTestUser(t, email, password)
	secondTokens := loginTestUser(t, email, password)

	// Get session IDs
	firstClaims, _ := testKeyManager.ValidateToken(firstTokens.AccessToken)
	firstSessionID := firstClaims["sid"].(string)

	headers := map[string]string{
		"Authorization": "Bearer " + secondTokens.AccessToken,
	}

	tests := []struct {
		name       string
		sessionID  string
		wantStatus int
	}{
		{
			name:       "revoke other session",
			sessionID:  firstSessionID,
			wantStatus: http.StatusOK,
		},
		{
			name:       "revoke non-existent session",
			sessionID:  "non-existent",
			wantStatus: http.StatusNotFound,
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			w := performRequest(router, http.MethodDelete, "/api/v1/auth/sessions/"+tt.sessionID, nil, headers)

			if w.Code != tt.wantStatus {
				t.Errorf("RevokeSession handler status = %v, want %v, body = %s", w.Code, tt.wantStatus, w.Body.String())
			}
		})
	}
}

