func TestAuthService_RevokeSession(t *testing.T) {
	t.Cleanup(func() {
		cleanupUsers(t)
		cleanupSessions(t)
	})

	// Create and login a test user
	email := "revoke@test.com"
	password := "password123"
	user := createTestUser(t, email, password)
	loginTestUser(t, email, password)

	svc := mustGetTestAuthService(t)
	ctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)
	defer cancel()

	// Get sessions
	sessions, err := svc.GetUserSessions(ctx, user.ID)
	if err != nil {
		t.Fatalf("GetUserSessions() error: %v", err)
	}

	if len(sessions) == 0 {
		t.Fatal("no sessions found")
	}

	tests := []struct {
		name      string
		userID    string
		sessionID string
		wantErr   error
	}{
		{
			name:      "revoke existing session",
			userID:    user.ID,
			sessionID: sessions[0].ID,
			wantErr:   nil,
		},
		{
			name:      "revoke non-existent session",
			userID:    user.ID,
			sessionID: "non-existent-session",
			wantErr:   ErrSessionNotFound,
		},
		{
			name:      "revoke session of different user",
			userID:    "different-user-id",
			sessionID: sessions[0].ID,
			wantErr:   ErrSessionNotFound,
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			err := svc.RevokeSession(ctx, tt.userID, tt.sessionID)

			if tt.wantErr != nil {
				if err == nil {
					t.Errorf("RevokeSession() expected error %v, got nil", tt.wantErr)
					return
				}
				if err != tt.wantErr {
					t.Errorf("RevokeSession() error = %v, want %v", err, tt.wantErr)
				}
				return
			}

			if err != nil {
				t.Errorf("RevokeSession() unexpected error: %v", err)
			}
		})
	}
}

func TestAuthService_RevokeAllSessions(t *testing.T) {
	t.Cleanup(func() {
		cleanupUsers(t)
		cleanupSessions(t)
	})

	// Create a test user
	email := "revokeall@test.com"
	password := "password123"
	user := createTestUser(t, email, password)

	// Login multiple times
	var currentSessionID string
	for i := 0; i < 3; i++ {
		tokens := loginTestUser(t, email, password)
		if i == 2 {
			// Extract session ID from the last token for testing
			claims, _ := testKeyManager.ValidateToken(tokens.AccessToken)
			if sid, ok := claims["sid"].(string); ok {
				currentSessionID = sid
			}
		}
	}

	svc := mustGetTestAuthService(t)
	ctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)
	defer cancel()

	// Revoke all except current
	if err := svc.RevokeAllSessions(ctx, user.ID, currentSessionID); err != nil {
		t.Fatalf("RevokeAllSessions() error: %v", err)
	}

	// Only current session should remain
	sessions, err := svc.GetUserSessions(ctx, user.ID)
	if err != nil {
		t.Fatalf("GetUserSessions() error: %v", err)
	}

	if len(sessions) != 1 {
		t.Errorf("RevokeAllSessions() left %d sessions, want 1", len(sessions))
	}

	if sessions[0].ID != currentSessionID {
		t.Error("RevokeAllSessions() revoked the current session")
	}
}
