{{- if .EnableMFA}}

func TestIntegration_MFAFlow(t *testing.T) {
	t.Cleanup(func() {
		cleanupUsers(t)
		cleanupSessions(t)
	})

	router := setupAuthRouter(t)

	email := "mfa@test.com"
	password := "password123"

	// Create user and login
	createTestUser(t, email, password)
	tokens := loginTestUser(t, email, password)

	headers := map[string]string{
		"Authorization": "Bearer " + tokens.AccessToken,
	}

	// Setup MFA
	var mfaSetup struct {
		Secret      string   `json:"secret"`
		QRCode      string   `json:"qr_code"`
		BackupCodes []string `json:"backup_codes"`
	}

	t.Run("setup_mfa", func(t *testing.T) {
		w := performRequest(router, http.MethodPost, "/api/v1/auth/mfa/setup", nil, headers)

		if w.Code != http.StatusOK {
			t.Fatalf("MFA setup failed: status = %v, body = %s", w.Code, w.Body.String())
		}

		if err := json.Unmarshal(w.Body.Bytes(), &mfaSetup); err != nil {
			t.Fatalf("failed to unmarshal MFA setup: %v", err)
		}

		if mfaSetup.Secret == "" {
			t.Error("MFA secret is empty")
		}
		if len(mfaSetup.BackupCodes) == 0 {
			t.Error("no backup codes returned")
		}
	})

	// Note: Full MFA verification would require generating a valid TOTP code
	// which needs the secret. In integration tests, you might use backup codes.

	t.Run("verify_mfa_with_backup", func(t *testing.T) {
		if len(mfaSetup.BackupCodes) == 0 {
			t.Skip("no backup codes available")
		}

		body := map[string]string{
			"code": mfaSetup.BackupCodes[0],
		}

		w := performRequest(router, http.MethodPost, "/api/v1/auth/mfa/verify", body, headers)

		if w.Code != http.StatusOK {
			t.Errorf("MFA verify with backup code failed: status = %v, body = %s", w.Code, w.Body.String())
		}
	})
}
