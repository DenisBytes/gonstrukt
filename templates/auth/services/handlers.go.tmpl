// handleMFALogin completes a login that requires MFA verification
func (s *AuthService) handleMFALogin(w http.ResponseWriter, r *http.Request) {
	var req types.MFAVerifyRequest
	if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
		writeError(w, http.StatusBadRequest, "invalid request body")
		return
	}

	if req.MFAToken == "" || req.Code == "" {
		writeError(w, http.StatusBadRequest, "mfa_token and code are required")
		return
	}

	tokens, err := s.VerifyMFALogin(r.Context(), req.MFAToken, req.Code)
	if err != nil {
		switch err {
		case ErrTokenInvalid, ErrTokenExpired:
			writeError(w, http.StatusUnauthorized, "invalid or expired MFA token, please login again")
		case ErrInvalidMFACode:
			writeError(w, http.StatusUnauthorized, "invalid MFA code")
		case ErrUserNotFound:
			writeError(w, http.StatusUnauthorized, "user not found")
		default:
			writeError(w, http.StatusTooManyRequests, err.Error())
		}
		return
	}

	writeJSON(w, http.StatusOK, tokens)
}
