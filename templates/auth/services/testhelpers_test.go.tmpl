// testDB is the shared database client for integration tests.
var testDB db.Database

// testKeyManager is the shared key manager for tests.
var testKeyManager *KeyManager

// testTokenBlacklist is the shared token blacklist for tests.
var testTokenBlacklist *TokenBlacklist

// testAuthService is the shared auth service for tests.
var testAuthService *AuthService

// TestMain sets up and tears down the test database.
func TestMain(m *testing.M) {
	flag.Parse()

	if testing.Short() {
		fmt.Println("Skipping integration tests in short mode")
		os.Exit(0)
	}

	// Initialize logger for tests
	if err := utils.InitLogger("test-auth-service"); err != nil {
		fmt.Fprintf(os.Stderr, "Failed to initialize logger: %v\n", err)
		os.Exit(1)
	}

	ctx, cancel := context.WithTimeout(context.Background(), 60*time.Second)
	defer cancel()

	var err error
	testDB, err = setupTestDB(ctx)
	if err != nil {
		fmt.Fprintf(os.Stderr, "Failed to setup test database: %v\n", err)
		fmt.Fprintf(os.Stderr, "Make sure the database is running and accessible\n")
		os.Exit(1)
	}

	// Run migrations
	if err := testDB.Migrate(ctx); err != nil {
		fmt.Fprintf(os.Stderr, "Failed to run migrations: %v\n", err)
		os.Exit(1)
	}

	// Setup key manager with test keys
	testKeyManager, err = setupTestKeyManager()
	if err != nil {
		fmt.Fprintf(os.Stderr, "Failed to setup key manager: %v\n", err)
		os.Exit(1)
	}

	// Setup token blacklist
	testTokenBlacklist = NewTokenBlacklist()

	// Setup auth service
	testAuthService = NewAuthService(AuthServiceConfig{
		DB:             testDB,
		KeyManager:     testKeyManager,
		TokenBlacklist: testTokenBlacklist,
		TokenTTL:       15 * time.Minute,
		RefreshTTL:     24 * time.Hour,
		Issuer:         "test-issuer",
	})

	code := m.Run()

	// Cleanup
	testTokenBlacklist.Close()
	shutdownCtx, shutdownCancel := context.WithTimeout(context.Background(), 10*time.Second)
	defer shutdownCancel()
	if err := testDB.Close(shutdownCtx); err != nil {
		fmt.Fprintf(os.Stderr, "Failed to close database: %v\n", err)
	}

	os.Exit(code)
}

// setupTestDB creates and connects to the test database.
func setupTestDB(ctx context.Context) (db.Database, error) {
{{- if eq .Database "postgres"}}
	dbURL := getEnvOrDefault("TEST_DATABASE_URL", "postgres://postgres:postgres@localhost:5432/test_auth?sslmode=disable")
	return db.NewPostgresClient(ctx, dbURL)
{{- else if eq .Database "mysql"}}
	dbURL := getEnvOrDefault("TEST_DATABASE_URL", "root:root@tcp(localhost:3306)/test_auth?parseTime=true")
	return db.NewMySQLClient(dbURL)
{{- else if eq .Database "sqlite"}}
	dbPath := getEnvOrDefault("TEST_DATABASE_PATH", ":memory:")
	return db.NewSQLiteClient(dbPath)
{{- else if eq .Database "mongodb"}}
	dbURL := getEnvOrDefault("TEST_DATABASE_URL", "mongodb://localhost:27017")
	dbName := getEnvOrDefault("TEST_DATABASE_NAME", "test_auth")
	return db.NewMongoClient(ctx, dbURL, dbName)
{{- else if eq .Database "arangodb"}}
	dbURL := getEnvOrDefault("TEST_DATABASE_URL", "http://localhost:8529")
	dbName := getEnvOrDefault("TEST_DATABASE_NAME", "test_auth")
	return db.NewArangoClient(ctx, dbURL, dbName)
{{- end}}
}

// setupTestKeyManager creates a key manager with test keys.
func setupTestKeyManager() (*KeyManager, error) {
	// For tests, generate keys in memory or use test key files
	privateKeyPath := getEnvOrDefault("TEST_JWT_PRIVATE_KEY", "testdata/private.pem")
	publicKeyPath := getEnvOrDefault("TEST_JWT_PUBLIC_KEY", "testdata/public.pem")

	// If test key files don't exist, create them
	if _, err := os.Stat(privateKeyPath); os.IsNotExist(err) {
		if err := generateTestKeys(privateKeyPath, publicKeyPath); err != nil {
			return nil, fmt.Errorf("failed to generate test keys: %w", err)
		}
	}

	return NewKeyManager(JWTConfig{
		PrivateKeyPath:  privateKeyPath,
		PublicKeyPath:   publicKeyPath,
		Issuer:          "test-issuer",
		AccessTokenTTL:  15 * time.Minute,
		RefreshTokenTTL: 24 * time.Hour,
	})
}

// generateTestKeys generates ECDSA keys for testing.
func generateTestKeys(privatePath, publicPath string) error {
	// Create testdata directory
	if err := os.MkdirAll("testdata", 0755); err != nil {
		return err
	}

	// Generate ECDSA P-256 key pair
	privateKey, err := ecdsa.GenerateKey(elliptic.P256(), rand.Reader)
	if err != nil {
		return fmt.Errorf("failed to generate private key: %w", err)
	}

	// Marshal private key to PKCS8
	privateKeyBytes, err := x509.MarshalECPrivateKey(privateKey)
	if err != nil {
		return fmt.Errorf("failed to marshal private key: %w", err)
	}

	// Write private key
	privateKeyPEM := pem.EncodeToMemory(&pem.Block{
		Type:  "EC PRIVATE KEY",
		Bytes: privateKeyBytes,
	})
	if err := os.WriteFile(privatePath, privateKeyPEM, 0600); err != nil {
		return fmt.Errorf("failed to write private key: %w", err)
	}

	// Marshal public key
	publicKeyBytes, err := x509.MarshalPKIXPublicKey(&privateKey.PublicKey)
	if err != nil {
		return fmt.Errorf("failed to marshal public key: %w", err)
	}

	// Write public key
	publicKeyPEM := pem.EncodeToMemory(&pem.Block{
		Type:  "PUBLIC KEY",
		Bytes: publicKeyBytes,
	})
	if err := os.WriteFile(publicPath, publicKeyPEM, 0644); err != nil {
		return fmt.Errorf("failed to write public key: %w", err)
	}

	return nil
}

// getEnvOrDefault returns the environment variable value or a default.
func getEnvOrDefault(key, defaultValue string) string {
	if value := os.Getenv(key); value != "" {
		return value
	}
	return defaultValue
}

// mustGetTestDB returns the shared test DB, failing if not initialized.
func mustGetTestDB(t *testing.T) db.Database {
	t.Helper()
	if testDB == nil {
		t.Fatal("test database not initialized - TestMain may have failed")
	}
	return testDB
}

// mustGetTestAuthService returns the shared auth service, failing if not initialized.
func mustGetTestAuthService(t *testing.T) *AuthService {
	t.Helper()
	if testAuthService == nil {
		t.Fatal("test auth service not initialized - TestMain may have failed")
	}
	return testAuthService
}

