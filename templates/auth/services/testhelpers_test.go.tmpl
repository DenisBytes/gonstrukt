// cleanupTestUser removes a specific test user and their sessions.
func cleanupTestUser(t *testing.T, userID string) {
	t.Helper()
	ctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)
	defer cancel()

	// Delete user sessions first
	if err := testDB.DeleteUserSessions(ctx, userID); err != nil {
		t.Logf("warning: failed to cleanup sessions for user %s: %v", userID, err)
	}

	// Delete user
	if err := testDB.DeleteUser(ctx, userID); err != nil {
		t.Logf("warning: failed to cleanup user %s: %v", userID, err)
	}
}

// testRequest represents an HTTP request for testing.
type testRequest struct {
	method  string
	path    string
	body    any
	headers map[string]string
}

// testResponse represents expected response data.
type testResponse struct {
	status int
	check  func(t *testing.T, body []byte)
}

// performRequest executes an HTTP request against the test handler.
func performRequest(handler http.Handler, method, path string, body any, headers map[string]string) *httptest.ResponseRecorder {
	var reqBody *bytes.Buffer
	if body != nil {
		jsonBody, _ := json.Marshal(body)
		reqBody = bytes.NewBuffer(jsonBody)
	} else {
		reqBody = bytes.NewBuffer(nil)
	}

	req, _ := http.NewRequest(method, path, reqBody)
	req.Header.Set("Content-Type", "application/json")

	for k, v := range headers {
		req.Header.Set(k, v)
	}

	w := httptest.NewRecorder()
	handler.ServeHTTP(w, req)
	return w
}

// Test entity factory functions

// newTestUser creates a test user with a hashed password.
func newTestUser(email, password string) *types.User {
	hashedPassword, _ := bcrypt.GenerateFromPassword([]byte(password), bcrypt.DefaultCost)
	return &types.User{
		ID:           uuid.New().String(),
		Email:        email,
		PasswordHash: string(hashedPassword),
		FirstName:    "Test",
		LastName:     "User",
		CreatedAt:    time.Now(),
		UpdatedAt:    time.Now(),
	}
}

// newTestRegisterRequest creates a test registration request.
func newTestRegisterRequest(email, password string) *types.RegisterRequest {
	return &types.RegisterRequest{
		Email:     email,
		Password:  password,
		FirstName: "Test",
		LastName:  "User",
	}
}

// newTestLoginRequest creates a test login request.
func newTestLoginRequest(email, password string) *types.LoginRequest {
	return &types.LoginRequest{
		Email:    email,
		Password: password,
	}
}

// createTestUser creates a user in the database and returns it.
func createTestUser(t *testing.T, email, password string) *types.User {
	t.Helper()
	ctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)
	defer cancel()

	user := newTestUser(email, password)
	if err := testDB.CreateUser(ctx, user); err != nil {
		t.Fatalf("failed to create test user: %v", err)
	}
	return user
}

// loginTestUser logs in a user and returns the token response.
func loginTestUser(t *testing.T, email, password string) *types.TokenResponse {
	t.Helper()
	ctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)
	defer cancel()

	resp, err := testAuthService.Login(ctx, newTestLoginRequest(email, password))
	if err != nil {
		t.Fatalf("failed to login test user: %v", err)
	}
	return resp
}
