package middleware

import (
	"net/http"
	"strings"

{{- if .HasObservability}}
	"go.opentelemetry.io/otel/attribute"
	"go.opentelemetry.io/otel/codes"
	"go.opentelemetry.io/otel/trace"
{{- end}}
)

// PathTraversalProtection creates middleware that blocks path traversal attempts
// This prevents attackers from accessing files outside the intended directory
func PathTraversalProtection() func(http.Handler) http.Handler {
	// Suspicious patterns that indicate path traversal
	suspiciousPatterns := []string{
		"..",
		"//",
		"./",
		"%2e%2e",
		"%2e.",
		".%2e",
		"%252e",
		"..%c0%af",
		"..%c1%9c",
		"..%255c",
		"..%25c0%25af",
	}

	return func(next http.Handler) http.Handler {
		return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
{{- if .HasObservability}}
			ctx := r.Context()
			span := trace.SpanFromContext(ctx)
			span.SetAttributes(
				attribute.String("security.path", r.URL.Path),
				attribute.String("security.check", "path_traversal"),
			)
{{- end}}

			path := strings.ToLower(r.URL.Path)
			rawPath := strings.ToLower(r.URL.RawPath)

			// Check both decoded and raw paths
			for _, pattern := range suspiciousPatterns {
				if strings.Contains(path, pattern) || strings.Contains(rawPath, pattern) {
{{- if .HasObservability}}
					span.SetStatus(codes.Error, "Path traversal attempt blocked")
					span.SetAttributes(
						attribute.Bool("security.blocked", true),
						attribute.String("security.pattern", pattern),
					)
{{- end}}
					http.Error(w, "Bad Request", http.StatusBadRequest)
					return
				}
			}

			// Check for null bytes
			if strings.Contains(path, "\x00") || strings.Contains(r.URL.RawQuery, "\x00") {
{{- if .HasObservability}}
				span.SetStatus(codes.Error, "Null byte injection blocked")
				span.SetAttributes(attribute.Bool("security.blocked", true))
{{- end}}
				http.Error(w, "Bad Request", http.StatusBadRequest)
				return
			}

{{- if .HasObservability}}
			span.SetAttributes(attribute.Bool("security.allowed", true))
{{- end}}
			next.ServeHTTP(w, r)
		})
	}
}
