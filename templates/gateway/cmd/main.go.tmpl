package main

import (
	"context"
	"fmt"
	"net/http"
	"os"
	"os/signal"
	"syscall"
	"time"

	"go.uber.org/zap"

	"{{.ModuleName}}/internals/config"
	"{{.ModuleName}}/internals/middleware"
	"{{.ModuleName}}/internals/services"
	"{{.ModuleName}}/internals/utils"
{{- if .HasCache}}
	"{{.ModuleName}}/internals/cache"
{{- end}}
{{- if .HasRateLimiter}}
	"{{.ModuleName}}/internals/ratelimiter"
{{- end}}
{{- if .HasObservability}}
	"{{.ModuleName}}/internals/telemetry"
{{- end}}
)

func main() {
	ctx, cancel := context.WithCancel(context.Background())
	defer cancel()

	// Initialize logger
	if err := utils.InitLogger("{{.ServiceName}}"); err != nil {
		fmt.Fprintf(os.Stderr, "failed to initialize logger: %v\n", err)
		os.Exit(1)
	}
	defer utils.Sync()

	// Load configuration
{{- if eq .Config "yaml"}}
	cfg, err := config.LoadYAML[config.Config]("config.yaml")
{{- else if eq .Config "env"}}
	cfg, err := config.LoadEnv[config.Config]()
{{- else if eq .Config "vault"}}
	vaultCfg := config.VaultConfig{
		Address: os.Getenv("VAULT_ADDR"),
		Token:   os.Getenv("VAULT_TOKEN"),
		Path:    os.Getenv("VAULT_PATH"),
	}
	vaultClient, err := config.NewVaultClient(vaultCfg)
	if err != nil {
		utils.Fatal("failed to create vault client", zap.Error(err))
	}
	cfg, err := config.LoadVault[config.Config](ctx, vaultClient, "")
{{- end}}
	if err != nil {
		utils.Fatal("failed to load config", zap.Error(err))
	}

{{- if .HasObservability}}
	// Initialize telemetry (traces + metrics exporters)
	telemetryProvider, err := telemetry.InitTelemetry(ctx, telemetry.Config{
		ServiceName:    "{{.ServiceName}}",
		ServiceVersion: "1.0.0",
		Environment:    cfg.Environment,
		OTLPEndpoint:   cfg.OTLPEndpoint,
		Enabled:        true,
	})
	if err != nil {
		utils.Fatal("failed to initialize telemetry", zap.Error(err))
	}

	// Initialize HTTP instrumentation
	// Metrics: RED signals (Rate, Errors, Duration) - answers "how is the system behaving?"
	httpMetrics, err := telemetry.NewHTTPMetrics("{{.ServiceName}}")
	if err != nil {
		utils.Fatal("failed to initialize http metrics", zap.Error(err))
	}

	// Tracing: distributed traces - answers "what path did this request take?"
	httpTracing := telemetry.NewHTTPTracing("{{.ServiceName}}")
{{- end}}

{{- if .HasCache}}
	// Initialize cache
{{- if eq .CacheType "redis"}}
	cacheClient, cacheErr := cache.NewRedisCache(cfg.Redis.Addr, cfg.Redis.Password, cfg.Redis.DB)
	if cacheErr != nil {
		utils.Fatal("failed to initialize cache", zap.Error(cacheErr))
	}
{{- else if eq .CacheType "valkey"}}
	cacheClient, cacheErr := cache.NewValkeyCache(cfg.Valkey.Addr, cfg.Valkey.Password, cfg.Valkey.DB)
	if cacheErr != nil {
		utils.Fatal("failed to initialize cache", zap.Error(cacheErr))
	}
{{- else if eq .CacheType "memory"}}
	cacheClient := cache.NewMemoryCache(cfg.Cache.MaxSize, cfg.Cache.TTL)
{{- end}}
{{- end}}

{{- if .HasRateLimiter}}
	// Initialize rate limiter
{{- if eq .RateLimiterType "token-bucket"}}
	rateLimiter := ratelimiter.NewTokenBucket(cfg.RateLimiter.Rate, cfg.RateLimiter.Burst)
{{- else if eq .RateLimiterType "sliding-window"}}
	rateLimiter := ratelimiter.NewSlidingWindow(int(cfg.RateLimiter.Rate), cfg.RateLimiter.WindowSize)
{{- else if eq .RateLimiterType "leaky-bucket"}}
	rateLimiter := ratelimiter.NewLeakyBucket(cfg.RateLimiter.Rate, cfg.RateLimiter.Burst)
{{- else if eq .RateLimiterType "fixed-window"}}
	rateLimiter := ratelimiter.NewFixedWindow(int(cfg.RateLimiter.Rate), cfg.RateLimiter.WindowSize)
{{- end}}
{{- end}}

	// Convert upstream services config to services type
	upstreamServices := make([]services.UpstreamService, len(cfg.UpstreamServices))
	for i, svc := range cfg.UpstreamServices {
		upstreamServices[i] = services.UpstreamService{
			Name:        svc.Name,
			URL:         svc.URL,
			PathPrefix:  svc.PathPrefix,
			Timeout:     svc.Timeout,
			RetryCount:  svc.RetryCount,
			HealthCheck: svc.HealthCheck,
		}
	}

	// Initialize gateway service
	gatewaySvc := services.NewGateway(services.GatewayConfig{
		UpstreamServices: upstreamServices,
{{- if .HasCache}}
		Cache:            cacheClient,
{{- end}}
{{- if .HasRateLimiter}}
		RateLimiter:      rateLimiter,
{{- end}}
	})

	// Setup HTTP server
	mux := http.NewServeMux()

	// Health check endpoint
	mux.HandleFunc("/health", services.HealthHandler)

	// Gateway routes
	gatewaySvc.RegisterRoutes(mux)

	// Convert CORS config to middleware type
	corsConfig := middleware.CORSConfig{
		AllowedOrigins:   cfg.CORS.AllowedOrigins,
		AllowedMethods:   cfg.CORS.AllowedMethods,
		AllowedHeaders:   cfg.CORS.AllowedHeaders,
		ExposedHeaders:   cfg.CORS.ExposedHeaders,
		AllowCredentials: cfg.CORS.AllowCredentials,
		MaxAge:           cfg.CORS.MaxAge,
	}

	// Apply middleware chain
	// Order matters: tracing -> metrics -> logging -> recovery -> security -> rate limiting
	handler := middleware.Chain(
		mux,
{{- if .HasObservability}}
		httpTracing.Middleware,    // Creates span context (outermost for full request timing)
		httpMetrics.Middleware,    // Records RED metrics
{{- end}}
		middleware.Logging(utils.Logger), // Logs with trace correlation
		middleware.Recovery(utils.Logger),
		middleware.SecurityHeaders,
		middleware.CORS(corsConfig),
{{- if .HasRateLimiter}}
		ratelimiter.Middleware(rateLimiter),
{{- end}}
	)

	server := &http.Server{
		Addr:         cfg.Server.Addr,
		Handler:      handler,
		ReadTimeout:  cfg.Server.ReadTimeout,
		WriteTimeout: cfg.Server.WriteTimeout,
		IdleTimeout:  cfg.Server.IdleTimeout,
	}

	// Configure TLS if enabled
	if cfg.Server.TLSEnabled {
		server.TLSConfig = utils.NewTLSConfig()
	}

	// Start server
	go func() {
		var err error
		if cfg.Server.TLSEnabled {
			utils.Info("starting server with TLS", zap.String("addr", cfg.Server.Addr))
			err = server.ListenAndServeTLS(cfg.Server.TLSCertFile, cfg.Server.TLSKeyFile)
		} else {
			utils.Info("starting server", zap.String("addr", cfg.Server.Addr))
			err = server.ListenAndServe()
		}
		if err != nil && err != http.ErrServerClosed {
			utils.Fatal("server failed", zap.Error(err))
		}
	}()

	// Wait for shutdown signal
	quit := make(chan os.Signal, 1)
	signal.Notify(quit, syscall.SIGINT, syscall.SIGTERM)
	<-quit

	utils.Info("shutting down server...")

	// Graceful shutdown with timeout
	shutdownCtx, shutdownCancel := context.WithTimeout(ctx, 30*time.Second)
	defer shutdownCancel()

	// 1. Stop accepting new connections and wait for in-flight requests
	if err := server.Shutdown(shutdownCtx); err != nil {
		utils.Error("server shutdown error", zap.Error(err))
	}

{{- if .HasCache}}
	// 2. Close cache connections
	if err := cacheClient.Close(shutdownCtx); err != nil {
		utils.Error("cache close error", zap.Error(err))
	}
{{- end}}

{{- if .HasObservability}}
	// 3. Flush telemetry
	if err := telemetryProvider.Shutdown(shutdownCtx); err != nil {
		utils.Error("telemetry shutdown error", zap.Error(err))
	}
{{- end}}

	utils.Info("server stopped")
}
