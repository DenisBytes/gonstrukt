package ratelimiter

import (
	"context"
	"sync"
	"time"
)

// bucket represents a single rate limit bucket
type bucket struct {
	tokens     float64
	lastUpdate time.Time
}

// TokenBucket implements a token bucket rate limiter
type TokenBucket struct {
	rate       float64 // tokens per second
	burst      int     // maximum bucket size
	buckets    map[string]*bucket
	mu         sync.RWMutex
	cleanupInt time.Duration
	stopCh     chan struct{}
}

// NewTokenBucket creates a new token bucket rate limiter
// rate is tokens per second, burst is the maximum tokens
func NewTokenBucket(rate float64, burst int) *TokenBucket {
	tb := &TokenBucket{
		rate:       rate,
		burst:      burst,
		buckets:    make(map[string]*bucket),
		cleanupInt: time.Minute,
		stopCh:     make(chan struct{}),
	}

	go tb.cleanup()

	return tb
}

// Allow checks if one request is allowed
func (t *TokenBucket) Allow(ctx context.Context, key string) (bool, error) {
	return t.AllowN(ctx, key, 1)
}

// AllowN checks if n requests are allowed
func (t *TokenBucket) AllowN(ctx context.Context, key string, n int) (bool, error) {
	t.mu.Lock()
	defer t.mu.Unlock()

	now := time.Now()

	b, exists := t.buckets[key]
	if !exists {
		b = &bucket{
			tokens:     float64(t.burst),
			lastUpdate: now,
		}
		t.buckets[key] = b
	}

	// Add tokens based on time elapsed
	elapsed := now.Sub(b.lastUpdate).Seconds()
	b.tokens += elapsed * t.rate
	if b.tokens > float64(t.burst) {
		b.tokens = float64(t.burst)
	}
	b.lastUpdate = now

	// Check if we have enough tokens
	if b.tokens >= float64(n) {
		b.tokens -= float64(n)
		return true, nil
	}

	return false, nil
}

// Reset resets the bucket for a key
func (t *TokenBucket) Reset(ctx context.Context, key string) error {
	t.mu.Lock()
	defer t.mu.Unlock()
	delete(t.buckets, key)
	return nil
}

// GetStats returns statistics for a key
func (t *TokenBucket) GetStats(ctx context.Context, key string) (*Stats, error) {
	t.mu.RLock()
	defer t.mu.RUnlock()

	b, exists := t.buckets[key]
	if !exists {
		return &Stats{
			Key:       key,
			Remaining: t.burst,
			Total:     t.burst,
			ResetAt:   0,
		}, nil
	}

	// Calculate remaining tokens
	now := time.Now()
	elapsed := now.Sub(b.lastUpdate).Seconds()
	tokens := b.tokens + elapsed*t.rate
	if tokens > float64(t.burst) {
		tokens = float64(t.burst)
	}

	// Calculate reset time (when bucket will be full)
	var resetAt int64
	if tokens < float64(t.burst) {
		timeToFull := (float64(t.burst) - tokens) / t.rate
		resetAt = now.Add(time.Duration(timeToFull * float64(time.Second))).Unix()
	}

	return &Stats{
		Key:       key,
		Remaining: int(tokens),
		Total:     t.burst,
		ResetAt:   resetAt,
	}, nil
}

// cleanup periodically removes old buckets
func (t *TokenBucket) cleanup() {
	ticker := time.NewTicker(t.cleanupInt)
	defer ticker.Stop()

	for {
		select {
		case <-ticker.C:
			t.removeOldBuckets()
		case <-t.stopCh:
			return
		}
	}
}

// removeOldBuckets removes buckets that are full (inactive for a while)
func (t *TokenBucket) removeOldBuckets() {
	t.mu.Lock()
	defer t.mu.Unlock()

	now := time.Now()
	threshold := time.Duration(float64(t.burst)/t.rate) * time.Second * 2

	for key, b := range t.buckets {
		if now.Sub(b.lastUpdate) > threshold {
			delete(t.buckets, key)
		}
	}
}

// Close stops the cleanup goroutine
func (t *TokenBucket) Close() {
	close(t.stopCh)
}
