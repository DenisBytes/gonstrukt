// Auth types for {{.ProjectName}}
// Generated by gonstrukt

export interface User {
  id: string;
  email: string;
  name?: string;
  created_at: string;
  updated_at: string;
{{- if .EnableMFA}}
  mfa_enabled: boolean;
{{- end}}
{{- if .HasOAuth}}
  oauth_provider?: string;
{{- end}}
}

export interface AuthTokens {
  access_token: string;
  refresh_token: string;
  expires_at: string;
}

export interface LoginRequest {
  email: string;
  password: string;
{{- if .EnableMFA}}
  mfa_code?: string;
{{- end}}
}

export interface LoginResponse {
  user: User;
  tokens: AuthTokens;
{{- if .EnableMFA}}
  mfa_required?: boolean;
{{- end}}
}

export interface RegisterRequest {
  email: string;
  password: string;
  name?: string;
}

export interface RegisterResponse {
  user: User;
  tokens: AuthTokens;
}

{{- if .EnableMFA}}

export interface MFASetupResponse {
  secret: string;
  qr_code: string;
  backup_codes: string[];
}

export interface MFAVerifyRequest {
  code: string;
}

export interface MFAVerifyResponse {
  success: boolean;
}
{{- end}}

export interface Session {
  id: string;
  user_agent: string;
  ip_address: string;
  created_at: string;
  last_active_at: string;
  is_current: boolean;
}

export interface RefreshTokenRequest {
  refresh_token: string;
}

export interface RefreshTokenResponse {
  tokens: AuthTokens;
}

{{- if .HasGDPR}}

// GDPR Types
{{- if .HasGDPRConsent}}
export interface Consent {
  id: string;
  type: string;
  granted: boolean;
  granted_at?: string;
  revoked_at?: string;
}

export interface UpdateConsentRequest {
  consent_type: string;
  granted: boolean;
}
{{- end}}

{{- if .HasGDPRDataExport}}
export interface DataExportRequest {
  format: 'json' | 'csv';
}

export interface DataExportResponse {
  download_url: string;
  expires_at: string;
}
{{- end}}

{{- if .HasGDPRDataDeletion}}
export interface DeleteAccountRequest {
  password: string;
  confirmation: string;
}
{{- end}}
{{- end}}

export interface PasswordChangeRequest {
  current_password: string;
  new_password: string;
}

export interface ForgotPasswordRequest {
  email: string;
}

export interface ResetPasswordRequest {
  token: string;
  new_password: string;
}

export interface ApiError {
  message: string;
  code?: string;
  details?: Record<string, string>;
}
