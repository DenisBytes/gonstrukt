{{- if .HasPostHog}}
{{- if .IsWebFrontend}}
import posthog from 'posthog-js'
import { useEffect } from 'react'
import { useLocation } from 'react-router-dom'

// PostHog configuration
const POSTHOG_KEY = import.meta.env.VITE_POSTHOG_KEY
const POSTHOG_HOST = import.meta.env.VITE_POSTHOG_HOST || 'https://us.i.posthog.com'

// Initialize PostHog (call once at app startup)
export function initPostHog() {
  if (POSTHOG_KEY && typeof window !== 'undefined') {
    posthog.init(POSTHOG_KEY, {
      api_host: POSTHOG_HOST,
      person_profiles: 'identified_only',
      capture_pageview: false, // We handle this manually with router
      loaded: (posthog) => {
        if (import.meta.env.DEV) {
          // In development, you can enable debug mode
          // posthog.debug()
        }
      },
    })
  }
}

// Hook to track page views with React Router
export function usePostHogPageView() {
  const location = useLocation()

  useEffect(() => {
    if (POSTHOG_KEY) {
      posthog.capture('$pageview', {
        $current_url: window.location.href,
      })
    }
  }, [location])
}

// Identify user (call after login)
export function identifyUser(userId: string, properties?: Record<string, unknown>) {
  if (POSTHOG_KEY) {
    posthog.identify(userId, properties)
  }
}

// Reset user (call after logout)
export function resetUser() {
  if (POSTHOG_KEY) {
    posthog.reset()
  }
}

// Capture custom event
export function captureEvent(event: string, properties?: Record<string, unknown>) {
  if (POSTHOG_KEY) {
    posthog.capture(event, properties)
  }
}

// Feature flags
export function isFeatureEnabled(flag: string): boolean {
  if (!POSTHOG_KEY) return false
  return posthog.isFeatureEnabled(flag) ?? false
}

export { posthog }
{{- else}}
// React Native PostHog
import PostHog from 'posthog-react-native'
import { useEffect } from 'react'

// PostHog client instance
let posthogClient: PostHog | null = null

// Initialize PostHog (call once at app startup)
export async function initPostHog() {
  const apiKey = process.env.EXPO_PUBLIC_POSTHOG_KEY
  const host = process.env.EXPO_PUBLIC_POSTHOG_HOST || 'https://us.i.posthog.com'

  if (apiKey) {
    posthogClient = await PostHog.initAsync(apiKey, {
      host,
    })
  }
}

// Get PostHog client
export function getPostHog(): PostHog | null {
  return posthogClient
}

// Identify user (call after login)
export function identifyUser(userId: string, properties?: Record<string, unknown>) {
  posthogClient?.identify(userId, properties)
}

// Reset user (call after logout)
export function resetUser() {
  posthogClient?.reset()
}

// Capture custom event
export function captureEvent(event: string, properties?: Record<string, unknown>) {
  posthogClient?.capture(event, properties)
}

// Screen view tracking hook
export function usePostHogScreenView(screenName: string) {
  useEffect(() => {
    posthogClient?.screen(screenName)
  }, [screenName])
}

// Feature flags
export function isFeatureEnabled(flag: string): boolean {
  return posthogClient?.isFeatureEnabled(flag) ?? false
}
{{- end}}
{{- end}}
