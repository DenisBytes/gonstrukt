{{- if .HasGDPR}}
// GDPR hooks for {{.ProjectName}}
// Generated by gonstrukt
{{- if .HasTanStackQuery}}

import { useQuery, useMutation, useQueryClient } from '@tanstack/react-query';
import { gdprApi } from '../api/auth';
{{- if .HasGDPRConsent}}
import type { UpdateConsentRequest } from '../types/auth';
{{- end}}
{{- if .HasGDPRDataExport}}
import type { DataExportRequest } from '../types/auth';
{{- end}}
{{- if .HasGDPRDataDeletion}}
import type { DeleteAccountRequest } from '../types/auth';
{{- end}}

{{- if .HasGDPRConsent}}

// Query keys
export const gdprKeys = {
  all: ['gdpr'] as const,
  consents: () => [...gdprKeys.all, 'consents'] as const,
};

export function useConsents() {
  const queryClient = useQueryClient();

  // Fetch consents
  const consentsQuery = useQuery({
    queryKey: gdprKeys.consents(),
    queryFn: gdprApi.getConsents,
    staleTime: 5 * 60 * 1000, // 5 minutes
  });

  // Update consent mutation
  const updateMutation = useMutation({
    mutationFn: (data: UpdateConsentRequest) => gdprApi.updateConsent(data),
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: gdprKeys.consents() });
    },
  });

  return {
    consents: consentsQuery.data ?? [],
    isLoading: consentsQuery.isLoading,
    error: consentsQuery.error,
    updateConsent: updateMutation.mutateAsync,
    updateStatus: updateMutation,
    refetch: consentsQuery.refetch,
  };
}
{{- end}}

{{- if .HasGDPRDataExport}}

export function useDataExport() {
  const exportMutation = useMutation({
    mutationFn: (data: DataExportRequest) => gdprApi.requestDataExport(data),
  });

  return {
    requestExport: exportMutation.mutateAsync,
    exportStatus: exportMutation,
    isLoading: exportMutation.isPending,
    error: exportMutation.error,
    downloadUrl: exportMutation.data?.download_url,
  };
}
{{- end}}

{{- if .HasGDPRDataDeletion}}

export function useDeleteAccount() {
  const deleteMutation = useMutation({
    mutationFn: (data: DeleteAccountRequest) => gdprApi.deleteAccount(data),
  });

  return {
    deleteAccount: deleteMutation.mutateAsync,
    deleteStatus: deleteMutation,
    isLoading: deleteMutation.isPending,
    error: deleteMutation.error,
  };
}
{{- end}}

{{- else}}
// Redux version
import { useSelector, useDispatch } from 'react-redux';
import type { AppDispatch } from '../store';
import {
{{- if .HasGDPRConsent}}
  fetchConsents,
  updateConsentAsync,
  selectConsents,
  selectConsentsLoading,
  selectConsentsError,
{{- end}}
{{- if .HasGDPRDataExport}}
  requestDataExportAsync,
  selectExportLoading,
  selectExportUrl,
{{- end}}
{{- if .HasGDPRDataDeletion}}
  deleteAccountAsync,
  selectDeleteLoading,
{{- end}}
} from '../store/gdpr-slice';
{{- if .HasGDPRConsent}}
import type { UpdateConsentRequest } from '../types/auth';
{{- end}}
{{- if .HasGDPRDataExport}}
import type { DataExportRequest } from '../types/auth';
{{- end}}
{{- if .HasGDPRDataDeletion}}
import type { DeleteAccountRequest } from '../types/auth';
{{- end}}

{{- if .HasGDPRConsent}}

export function useConsents() {
  const dispatch = useDispatch<AppDispatch>();
  const consents = useSelector(selectConsents);
  const isLoading = useSelector(selectConsentsLoading);
  const error = useSelector(selectConsentsError);

  return {
    consents,
    isLoading,
    error,
    updateConsent: (data: UpdateConsentRequest) => dispatch(updateConsentAsync(data)),
    refetch: () => dispatch(fetchConsents()),
  };
}
{{- end}}

{{- if .HasGDPRDataExport}}

export function useDataExport() {
  const dispatch = useDispatch<AppDispatch>();
  const isLoading = useSelector(selectExportLoading);
  const downloadUrl = useSelector(selectExportUrl);

  return {
    requestExport: (data: DataExportRequest) => dispatch(requestDataExportAsync(data)),
    isLoading,
    downloadUrl,
  };
}
{{- end}}

{{- if .HasGDPRDataDeletion}}

export function useDeleteAccount() {
  const dispatch = useDispatch<AppDispatch>();
  const isLoading = useSelector(selectDeleteLoading);

  return {
    deleteAccount: (data: DeleteAccountRequest) => dispatch(deleteAccountAsync(data)),
    isLoading,
  };
}
{{- end}}
{{- end}}
{{- end}}
