// Sessions hook for {{.ProjectName}}
// Generated by gonstrukt
{{- if .HasTanStackQuery}}

import { useQuery, useMutation, useQueryClient } from '@tanstack/react-query';
import { sessionsApi } from '../api/auth';
import type { Session } from '../types/auth';

// Query keys
export const sessionsKeys = {
  all: ['sessions'] as const,
  list: () => [...sessionsKeys.all, 'list'] as const,
};

export function useSessions() {
  const queryClient = useQueryClient();

  // Fetch sessions
  const sessionsQuery = useQuery({
    queryKey: sessionsKeys.list(),
    queryFn: sessionsApi.getSessions,
    staleTime: 60 * 1000, // 1 minute
  });

  // Revoke session mutation
  const revokeMutation = useMutation({
    mutationFn: (sessionId: string) => sessionsApi.revokeSession(sessionId),
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: sessionsKeys.list() });
    },
  });

  // Revoke all sessions mutation
  const revokeAllMutation = useMutation({
    mutationFn: sessionsApi.revokeAllSessions,
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: sessionsKeys.list() });
    },
  });

  return {
    sessions: sessionsQuery.data ?? [],
    isLoading: sessionsQuery.isLoading,
    error: sessionsQuery.error,
    revokeSession: revokeMutation.mutateAsync,
    revokeStatus: revokeMutation,
    revokeAllSessions: revokeAllMutation.mutateAsync,
    revokeAllStatus: revokeAllMutation,
    refetch: sessionsQuery.refetch,
  };
}

{{- else}}
// Redux version
import { useSelector, useDispatch } from 'react-redux';
import type { RootState, AppDispatch } from '../store';
import {
  fetchSessions,
  revokeSessionAsync,
  revokeAllSessionsAsync,
  selectSessions,
  selectSessionsLoading,
  selectSessionsError,
} from '../store/auth-slice';

export function useSessions() {
  const dispatch = useDispatch<AppDispatch>();
  const sessions = useSelector(selectSessions);
  const isLoading = useSelector(selectSessionsLoading);
  const error = useSelector(selectSessionsError);

  return {
    sessions,
    isLoading,
    error,
    revokeSession: (sessionId: string) => dispatch(revokeSessionAsync(sessionId)),
    revokeAllSessions: () => dispatch(revokeAllSessionsAsync()),
    refetch: () => dispatch(fetchSessions()),
  };
}
{{- end}}
