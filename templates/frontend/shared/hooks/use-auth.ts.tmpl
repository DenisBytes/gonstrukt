// Auth hook for {{.ProjectName}}
// Generated by gonstrukt
{{- if .HasTanStackQuery}}

import { useQuery, useMutation, useQueryClient } from '@tanstack/react-query';
import { useAuthStore } from '../stores/auth-store';
import { authApi{{if .EnableMFA}}, mfaApi{{end}}{{if .HasOAuth}}, oauthApi{{end}} } from '../api/auth';
import type {
  User,
  LoginRequest,
  RegisterRequest,
{{- if .EnableMFA}}
  MFAVerifyRequest,
{{- end}}
} from '../types/auth';

// Query keys
export const authKeys = {
  all: ['auth'] as const,
  user: () => [...authKeys.all, 'user'] as const,
};

export function useAuth() {
  const queryClient = useQueryClient();
  const { user, setUser, clearUser, isAuthenticated } = useAuthStore();

  // Fetch current user
  const userQuery = useQuery({
    queryKey: authKeys.user(),
    queryFn: authApi.getCurrentUser,
    enabled: isAuthenticated,
    staleTime: 5 * 60 * 1000, // 5 minutes
    retry: false,
  });

  // Update store when user data changes
  if (userQuery.data && (!user || user.id !== userQuery.data.id)) {
    setUser(userQuery.data);
  }

  // Login mutation
  const loginMutation = useMutation({
    mutationFn: (data: LoginRequest) => authApi.login(data),
    onSuccess: (response) => {
{{- if .EnableMFA}}
      if (!response.mfa_required) {
        setUser(response.user);
        queryClient.invalidateQueries({ queryKey: authKeys.user() });
      }
{{- else}}
      setUser(response.user);
      queryClient.invalidateQueries({ queryKey: authKeys.user() });
{{- end}}
    },
  });

  // Register mutation
  const registerMutation = useMutation({
    mutationFn: (data: RegisterRequest) => authApi.register(data),
    onSuccess: (response) => {
      setUser(response.user);
      queryClient.invalidateQueries({ queryKey: authKeys.user() });
    },
  });

  // Logout mutation
  const logoutMutation = useMutation({
    mutationFn: authApi.logout,
    onSuccess: () => {
      clearUser();
      queryClient.clear();
    },
    onError: () => {
      // Clear user even on error
      clearUser();
      queryClient.clear();
    },
  });

  return {
    user: user ?? userQuery.data,
    isLoading: userQuery.isLoading,
    isAuthenticated,
    login: loginMutation.mutateAsync,
    loginStatus: loginMutation,
    register: registerMutation.mutateAsync,
    registerStatus: registerMutation,
    logout: logoutMutation.mutateAsync,
    logoutStatus: logoutMutation,
    refetchUser: () => queryClient.invalidateQueries({ queryKey: authKeys.user() }),
  };
}

{{- if .EnableMFA}}

export function useMFA() {
  const queryClient = useQueryClient();
  const { setUser } = useAuthStore();

  const setupMutation = useMutation({
    mutationFn: mfaApi.setupMFA,
  });

  const verifySetupMutation = useMutation({
    mutationFn: (data: MFAVerifyRequest) => mfaApi.verifyMFASetup(data),
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: authKeys.user() });
    },
  });

  const verifyLoginMutation = useMutation({
    mutationFn: (data: MFAVerifyRequest) => mfaApi.verifyMFALogin(data),
    onSuccess: (response) => {
      setUser(response.user);
      queryClient.invalidateQueries({ queryKey: authKeys.user() });
    },
  });

  const disableMutation = useMutation({
    mutationFn: (data: MFAVerifyRequest) => mfaApi.disableMFA(data),
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: authKeys.user() });
    },
  });

  return {
    setupMFA: setupMutation.mutateAsync,
    setupStatus: setupMutation,
    verifySetup: verifySetupMutation.mutateAsync,
    verifySetupStatus: verifySetupMutation,
    verifyLogin: verifyLoginMutation.mutateAsync,
    verifyLoginStatus: verifyLoginMutation,
    disableMFA: disableMutation.mutateAsync,
    disableStatus: disableMutation,
  };
}
{{- end}}

{{- if .HasOAuth}}

export function useOAuth() {
  const queryClient = useQueryClient();
  const { setUser } = useAuthStore();

{{- if .HasGoogleOAuth}}
  const googleUrlQuery = useQuery({
    queryKey: ['oauth', 'google', 'url'],
    queryFn: oauthApi.getGoogleAuthUrl,
    enabled: false,
  });

  const googleCallbackMutation = useMutation({
    mutationFn: (code: string) => oauthApi.handleGoogleCallback(code),
    onSuccess: (response) => {
      setUser(response.user);
      queryClient.invalidateQueries({ queryKey: authKeys.user() });
    },
  });
{{- end}}

{{- if .HasMicrosoftOAuth}}
  const microsoftUrlQuery = useQuery({
    queryKey: ['oauth', 'microsoft', 'url'],
    queryFn: oauthApi.getMicrosoftAuthUrl,
    enabled: false,
  });

  const microsoftCallbackMutation = useMutation({
    mutationFn: (code: string) => oauthApi.handleMicrosoftCallback(code),
    onSuccess: (response) => {
      setUser(response.user);
      queryClient.invalidateQueries({ queryKey: authKeys.user() });
    },
  });
{{- end}}

{{- if .HasAppleOAuth}}
  const appleUrlQuery = useQuery({
    queryKey: ['oauth', 'apple', 'url'],
    queryFn: oauthApi.getAppleAuthUrl,
    enabled: false,
  });

  const appleCallbackMutation = useMutation({
    mutationFn: (code: string) => oauthApi.handleAppleCallback(code),
    onSuccess: (response) => {
      setUser(response.user);
      queryClient.invalidateQueries({ queryKey: authKeys.user() });
    },
  });
{{- end}}

  return {
{{- if .HasGoogleOAuth}}
    getGoogleUrl: googleUrlQuery.refetch,
    handleGoogleCallback: googleCallbackMutation.mutateAsync,
    googleCallbackStatus: googleCallbackMutation,
{{- end}}
{{- if .HasMicrosoftOAuth}}
    getMicrosoftUrl: microsoftUrlQuery.refetch,
    handleMicrosoftCallback: microsoftCallbackMutation.mutateAsync,
    microsoftCallbackStatus: microsoftCallbackMutation,
{{- end}}
{{- if .HasAppleOAuth}}
    getAppleUrl: appleUrlQuery.refetch,
    handleAppleCallback: appleCallbackMutation.mutateAsync,
    appleCallbackStatus: appleCallbackMutation,
{{- end}}
  };
}
{{- end}}

{{- else}}
// Redux version
import { useSelector, useDispatch } from 'react-redux';
import type { RootState, AppDispatch } from '../store';
import {
  loginAsync,
  registerAsync,
  logoutAsync,
  fetchCurrentUser,
{{- if .EnableMFA}}
  setupMFAAsync,
  verifyMFASetupAsync,
  verifyMFALoginAsync,
  disableMFAAsync,
{{- end}}
{{- if .HasOAuth}}
{{- if .HasGoogleOAuth}}
  handleGoogleCallbackAsync,
{{- end}}
{{- if .HasMicrosoftOAuth}}
  handleMicrosoftCallbackAsync,
{{- end}}
{{- if .HasAppleOAuth}}
  handleAppleCallbackAsync,
{{- end}}
{{- end}}
  selectUser,
  selectIsAuthenticated,
  selectAuthLoading,
  selectAuthError,
{{- if .EnableMFA}}
  selectMFARequired,
  selectMFASetup,
{{- end}}
} from '../store/auth-slice';
import type { LoginRequest, RegisterRequest{{if .EnableMFA}}, MFAVerifyRequest{{end}} } from '../types/auth';

export function useAuth() {
  const dispatch = useDispatch<AppDispatch>();
  const user = useSelector(selectUser);
  const isAuthenticated = useSelector(selectIsAuthenticated);
  const isLoading = useSelector(selectAuthLoading);
  const error = useSelector(selectAuthError);
{{- if .EnableMFA}}
  const mfaRequired = useSelector(selectMFARequired);
{{- end}}

  return {
    user,
    isLoading,
    isAuthenticated,
    error,
{{- if .EnableMFA}}
    mfaRequired,
{{- end}}
    login: (data: LoginRequest) => dispatch(loginAsync(data)),
    register: (data: RegisterRequest) => dispatch(registerAsync(data)),
    logout: () => dispatch(logoutAsync()),
    refetchUser: () => dispatch(fetchCurrentUser()),
  };
}

{{- if .EnableMFA}}

export function useMFA() {
  const dispatch = useDispatch<AppDispatch>();
  const mfaSetup = useSelector(selectMFASetup);
  const isLoading = useSelector(selectAuthLoading);
  const error = useSelector(selectAuthError);

  return {
    mfaSetup,
    isLoading,
    error,
    setupMFA: () => dispatch(setupMFAAsync()),
    verifySetup: (data: MFAVerifyRequest) => dispatch(verifyMFASetupAsync(data)),
    verifyLogin: (data: MFAVerifyRequest) => dispatch(verifyMFALoginAsync(data)),
    disableMFA: (data: MFAVerifyRequest) => dispatch(disableMFAAsync(data)),
  };
}
{{- end}}

{{- if .HasOAuth}}

export function useOAuth() {
  const dispatch = useDispatch<AppDispatch>();
  const isLoading = useSelector(selectAuthLoading);
  const error = useSelector(selectAuthError);

  return {
    isLoading,
    error,
{{- if .HasGoogleOAuth}}
    handleGoogleCallback: (code: string) => dispatch(handleGoogleCallbackAsync(code)),
{{- end}}
{{- if .HasMicrosoftOAuth}}
    handleMicrosoftCallback: (code: string) => dispatch(handleMicrosoftCallbackAsync(code)),
{{- end}}
{{- if .HasAppleOAuth}}
    handleAppleCallback: (code: string) => dispatch(handleAppleCallbackAsync(code)),
{{- end}}
  };
}
{{- end}}
{{- end}}
