// User invitation endpoints (tenant-less tokens)
export const invitationApi = {
  /**
   * Get current user's pending invitations
   */
  async getMyInvitations(): Promise<Invitation[]> {
    return api.get<Invitation[]>('/api/v1/auth/invitations');
  },

  /**
   * Accept an invitation
   */
  async acceptInvitation(invitationId: string): Promise<{ status: string; tenant_id: string }> {
    return api.post<{ status: string; tenant_id: string }>(`/api/v1/auth/invitations/${invitationId}/accept`);
  },

  /**
   * Decline an invitation
   */
  async declineInvitation(invitationId: string): Promise<{ status: string }> {
    return api.post<{ status: string }>(`/api/v1/auth/invitations/${invitationId}/decline`);
  },
};

// Admin invitation endpoints (tenant-scoped tokens)
export const tenantInvitationApi = {
  /**
   * Get all invitations for the current tenant
   */
  async getTenantInvitations(): Promise<Invitation[]> {
    return api.get<Invitation[]>('/api/v1/auth/tenant/invitations');
  },

  /**
   * Create invitations in bulk
   */
  async createInvitations(data: CreateInvitationRequest): Promise<InvitationResult[]> {
    return api.post<InvitationResult[]>('/api/v1/auth/tenant/invitations', data);
  },

  /**
   * Resend an invitation
   */
  async resendInvitation(invitationId: string): Promise<{ status: string }> {
    return api.post<{ status: string }>(`/api/v1/auth/tenant/invitations/${invitationId}/resend`);
  },

  /**
   * Revoke an invitation
   */
  async revokeInvitation(invitationId: string): Promise<{ status: string }> {
    return api.delete<{ status: string }>(`/api/v1/auth/tenant/invitations/${invitationId}`);
  },
};

// Tenant management endpoints (tenant-scoped tokens)
export const tenantApi = {
  /**
   * Get current tenant details
   */
  async getCurrentTenant(): Promise<Tenant> {
    return api.get<Tenant>('/api/v1/auth/tenant');
  },

  /**
   * Update current tenant
   */
  async updateTenant(data: UpdateTenantRequest): Promise<Tenant> {
    return api.put<Tenant>('/api/v1/auth/tenant', data);
  },

  /**
   * Delete current tenant (owner only)
   */
  async deleteTenant(): Promise<void> {
    await api.delete('/api/v1/auth/tenant');
  },

  /**
   * Get tenant members
   */
  async getMembers(): Promise<TenantMember[]> {
    return api.get<TenantMember[]>('/api/v1/auth/tenant/members');
  },

  /**
   * Update a member's role
   */
  async updateMemberRole(userId: string, data: UpdateMemberRoleRequest): Promise<{ status: string }> {
    return api.put<{ status: string }>(`/api/v1/auth/tenant/members/${userId}/role`, data);
  },

  /**
   * Remove a member from the tenant
   */
  async removeMember(userId: string): Promise<{ status: string }> {
    return api.delete<{ status: string }>(`/api/v1/auth/tenant/members/${userId}`);
  },
};
