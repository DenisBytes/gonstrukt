// Auth API functions for {{.ProjectName}}
// Generated by gonstrukt

import { api, tokenStorage } from './client';
import type {
  User,
  LoginRequest,
  LoginResponse,
  RegisterRequest,
  RegisterResponse,
  RefreshTokenResponse,
  Session,
  PasswordChangeRequest,
  ForgotPasswordRequest,
  ResetPasswordRequest,
{{- if .EnableMFA}}
  MFASetupResponse,
  MFAVerifyRequest,
  MFAVerifyResponse,
{{- end}}
{{- if .HasGDPRConsent}}
  Consent,
  UpdateConsentRequest,
{{- end}}
{{- if .HasGDPRDataExport}}
  DataExportRequest,
  DataExportResponse,
{{- end}}
{{- if .HasGDPRDataDeletion}}
  DeleteAccountRequest,
{{- end}}
} from '../types/auth';

// Auth endpoints
export const authApi = {
  /**
   * Register a new user
   */
  async register(data: RegisterRequest): Promise<RegisterResponse> {
    const response = await api.post<RegisterResponse>('/api/auth/register', data, { skipAuth: true });
{{- if .IsMobileFrontend}}
    await tokenStorage.setTokens(response.tokens);
{{- else}}
    tokenStorage.setTokens(response.tokens);
{{- end}}
    return response;
  },

  /**
   * Login with email and password
   */
  async login(data: LoginRequest): Promise<LoginResponse> {
    const response = await api.post<LoginResponse>('/api/auth/login', data, { skipAuth: true });
{{- if .EnableMFA}}
    if (!response.mfa_required) {
{{- if .IsMobileFrontend}}
      await tokenStorage.setTokens(response.tokens);
{{- else}}
      tokenStorage.setTokens(response.tokens);
{{- end}}
    }
{{- else}}
{{- if .IsMobileFrontend}}
    await tokenStorage.setTokens(response.tokens);
{{- else}}
    tokenStorage.setTokens(response.tokens);
{{- end}}
{{- end}}
    return response;
  },

  /**
   * Logout and clear tokens
   */
  async logout(): Promise<void> {
    try {
      await api.post('/api/auth/logout');
    } finally {
{{- if .IsMobileFrontend}}
      await tokenStorage.clearTokens();
{{- else}}
      tokenStorage.clearTokens();
{{- end}}
    }
  },

  /**
   * Refresh the access token
   */
  async refreshToken(): Promise<RefreshTokenResponse> {
{{- if .IsMobileFrontend}}
    const refreshToken = await tokenStorage.getRefreshToken();
{{- else}}
    const refreshToken = tokenStorage.getRefreshToken();
{{- end}}
    if (!refreshToken) {
      throw new Error('No refresh token available');
    }
    const response = await api.post<RefreshTokenResponse>(
      '/api/auth/refresh',
      { refresh_token: refreshToken },
      { skipAuth: true }
    );
{{- if .IsMobileFrontend}}
    await tokenStorage.setTokens(response.tokens);
{{- else}}
    tokenStorage.setTokens(response.tokens);
{{- end}}
    return response;
  },

  /**
   * Get current user profile
   */
  async getCurrentUser(): Promise<User> {
    return api.get<User>('/api/auth/me');
  },

  /**
   * Update user profile
   */
  async updateProfile(data: Partial<Pick<User, 'name' | 'email'>>): Promise<User> {
    return api.patch<User>('/api/auth/me', data);
  },

  /**
   * Change password
   */
  async changePassword(data: PasswordChangeRequest): Promise<void> {
    await api.post('/api/auth/password/change', data);
  },

  /**
   * Request password reset email
   */
  async forgotPassword(data: ForgotPasswordRequest): Promise<void> {
    await api.post('/api/auth/password/forgot', data, { skipAuth: true });
  },

  /**
   * Reset password with token
   */
  async resetPassword(data: ResetPasswordRequest): Promise<void> {
    await api.post('/api/auth/password/reset', data, { skipAuth: true });
  },
};

// Session management
export const sessionsApi = {
  /**
   * Get all active sessions
   */
  async getSessions(): Promise<Session[]> {
    return api.get<Session[]>('/api/auth/sessions');
  },

  /**
   * Revoke a specific session
   */
  async revokeSession(sessionId: string): Promise<void> {
    await api.delete(`/api/auth/sessions/${sessionId}`);
  },

  /**
   * Revoke all sessions except current
   */
  async revokeAllSessions(): Promise<void> {
    await api.post('/api/auth/sessions/revoke-all');
  },
};

{{- if .EnableMFA}}

// MFA endpoints
export const mfaApi = {
  /**
   * Start MFA setup - returns secret and QR code
   */
  async setupMFA(): Promise<MFASetupResponse> {
    return api.post<MFASetupResponse>('/api/auth/mfa/setup');
  },

  /**
   * Verify MFA setup with code
   */
  async verifyMFASetup(data: MFAVerifyRequest): Promise<MFAVerifyResponse> {
    return api.post<MFAVerifyResponse>('/api/auth/mfa/verify', data);
  },

  /**
   * Verify MFA code during login
   */
  async verifyMFALogin(data: MFAVerifyRequest): Promise<LoginResponse> {
    const response = await api.post<LoginResponse>('/api/auth/mfa/login', data, { skipAuth: true });
{{- if .IsMobileFrontend}}
    await tokenStorage.setTokens(response.tokens);
{{- else}}
    tokenStorage.setTokens(response.tokens);
{{- end}}
    return response;
  },

  /**
   * Disable MFA
   */
  async disableMFA(data: MFAVerifyRequest): Promise<void> {
    await api.post('/api/auth/mfa/disable', data);
  },
};
{{- end}}

