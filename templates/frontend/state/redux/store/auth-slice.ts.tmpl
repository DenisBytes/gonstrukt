export const handleMicrosoftCallbackAsync = createAsyncThunk(
  'auth/handleMicrosoftCallback',
  async (code: string, { rejectWithValue }) => {
    try {
      return await oauthApi.handleMicrosoftCallback(code)
    } catch (error: any) {
