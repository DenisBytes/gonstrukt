// Auth slice using Redux Toolkit for {{.ProjectName}}
// Generated by gonstrukt

import { createSlice, createAsyncThunk, PayloadAction } from '@reduxjs/toolkit'
import { authApi, sessionsApi{{if .EnableMFA}}, mfaApi{{end}}{{if .HasOAuth}}, oauthApi{{end}} } from '../../api/auth'
import type { User, LoginRequest, RegisterRequest, Session{{if .EnableMFA}}, MFASetupResponse, MFAVerifyRequest{{end}} } from '../../types/auth'
import type { RootState } from './index'

interface AuthState {
  user: User | null
  isAuthenticated: boolean
  isLoading: boolean
  error: string | null
{{- if .EnableMFA}}
  mfaRequired: boolean
  mfaSetup: MFASetupResponse | null
{{- end}}
  sessions: Session[]
  sessionsLoading: boolean
  sessionsError: string | null
}

const initialState: AuthState = {
  user: null,
  isAuthenticated: false,
  isLoading: false,
  error: null,
{{- if .EnableMFA}}
  mfaRequired: false,
  mfaSetup: null,
{{- end}}
  sessions: [],
  sessionsLoading: false,
  sessionsError: null,
}

// Async thunks
export const loginAsync = createAsyncThunk(
  'auth/login',
  async (data: LoginRequest, { rejectWithValue }) => {
    try {
      return await authApi.login(data)
    } catch (error: any) {
      return rejectWithValue(error.message)
    }
  }
)

export const registerAsync = createAsyncThunk(
  'auth/register',
  async (data: RegisterRequest, { rejectWithValue }) => {
    try {
      return await authApi.register(data)
    } catch (error: any) {
      return rejectWithValue(error.message)
    }
  }
)

export const logoutAsync = createAsyncThunk(
  'auth/logout',
  async (_, { rejectWithValue }) => {
    try {
      await authApi.logout()
    } catch (error: any) {
      return rejectWithValue(error.message)
    }
  }
)

export const fetchCurrentUser = createAsyncThunk(
  'auth/fetchCurrentUser',
  async (_, { rejectWithValue }) => {
    try {
      return await authApi.getCurrentUser()
    } catch (error: any) {
      return rejectWithValue(error.message)
    }
  }
)

export const fetchSessions = createAsyncThunk(
  'auth/fetchSessions',
  async (_, { rejectWithValue }) => {
    try {
      return await sessionsApi.getSessions()
    } catch (error: any) {
      return rejectWithValue(error.message)
    }
  }
)

export const revokeSessionAsync = createAsyncThunk(
  'auth/revokeSession',
  async (sessionId: string, { rejectWithValue, dispatch }) => {
    try {
      await sessionsApi.revokeSession(sessionId)
      dispatch(fetchSessions())
    } catch (error: any) {
      return rejectWithValue(error.message)
    }
  }
)

export const revokeAllSessionsAsync = createAsyncThunk(
  'auth/revokeAllSessions',
  async (_, { rejectWithValue, dispatch }) => {
    try {
      await sessionsApi.revokeAllSessions()
      dispatch(fetchSessions())
    } catch (error: any) {
      return rejectWithValue(error.message)
    }
  }
)

