# {{.ProjectName}} Frontend Environment Variables
# =============================================
# Copy this file to .env and fill in the values
# =============================================

# API Connection
# TODO: Update this to your backend API URL
VITE_API_URL={{.APIBaseURL}}
{{- if .HasPostHog}}

# PostHog Analytics
# Get your project API key from: https://app.posthog.com/project/settings
# TODO: Replace with your PostHog project API key
VITE_POSTHOG_KEY=phc_XXXXXXXXXX
# TODO: Update host if using EU cloud (https://eu.posthog.com)
VITE_POSTHOG_HOST=https://us.i.posthog.com
{{- end}}
{{- if .HasSentry}}

# Sentry Error Tracking
# Get your DSN from: https://sentry.io/settings/projects/YOUR_PROJECT/keys/
# TODO: Replace with your Sentry DSN
VITE_SENTRY_DSN=https://xxxxxxxx@sentry.io/xxxxxxxx
{{- end}}
