{{- if .EnableMFA}}
import { useState } from 'react'
import { useNavigate } from 'react-router-dom'
import { toast } from 'sonner'
import { mfaApi } from '../lib/api/auth'
import type { MFASetupResponse } from '../lib/types/auth'
{{- if .HasShadcn}}
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '../components/ui/card'
import { Input } from '../components/ui/input'
import { Button } from '../components/ui/button'
import { Label } from '../components/ui/label'
{{- else}}
import { Card, StyledBody } from 'baseui/card'
import { Input } from 'baseui/input'
import { Button } from 'baseui/button'
import { FormControl } from 'baseui/form-control'
import { HeadingSmall, ParagraphSmall } from 'baseui/typography'
{{- end}}

export function MFASetupPage() {
  const navigate = useNavigate()
  const [setupData, setSetupData] = useState<MFASetupResponse | null>(null)
  const [code, setCode] = useState('')
  const [isLoading, setIsLoading] = useState(false)
  const [step, setStep] = useState<'init' | 'verify'>('init')

  const handleSetup = async () => {
    setIsLoading(true)
    try {
      const data = await mfaApi.setupMFA()
      setSetupData(data)
      setStep('verify')
    } catch (error: any) {
      toast.error(error.message || 'Failed to start MFA setup')
    } finally {
      setIsLoading(false)
    }
  }

  const handleVerify = async (e: React.FormEvent) => {
    e.preventDefault()
    setIsLoading(true)
    try {
      await mfaApi.verifyMFASetup({ code })
      toast.success('Two-factor authentication enabled!')
      navigate('/settings/security')
    } catch (error: any) {
      toast.error(error.message || 'Invalid verification code')
    } finally {
      setIsLoading(false)
    }
  }

  return (
{{- if .HasShadcn}}
    <Card className="max-w-md mx-auto">
      <CardHeader>
        <CardTitle>Set Up Two-Factor Authentication</CardTitle>
        <CardDescription>Add an extra layer of security to your account</CardDescription>
      </CardHeader>
      <CardContent>
        {step === 'init' && (
          <div className="space-y-4">
            <p className="text-sm text-muted-foreground">
              Two-factor authentication adds an extra layer of security by requiring a code from your authenticator app in addition to your password.
            </p>
            <Button onClick={handleSetup} className="w-full" disabled={isLoading}>
              {isLoading ? 'Setting up...' : 'Start Setup'}
            </Button>
          </div>
        )}
        {step === 'verify' && setupData && (
          <div className="space-y-4">
            <div className="space-y-2">
              <p className="text-sm font-medium">1. Scan this QR code with your authenticator app:</p>
              <div className="flex justify-center p-4 bg-white rounded">
                <img src={setupData.qr_code} alt="MFA QR Code" className="w-48 h-48" />
              </div>
              <p className="text-xs text-muted-foreground">
                Or enter this key manually: <code className="bg-muted px-1 rounded">{setupData.secret}</code>
              </p>
            </div>
            <div className="space-y-2">
              <p className="text-sm font-medium">2. Save your backup codes:</p>
              <div className="grid grid-cols-2 gap-1 p-3 bg-muted rounded text-xs font-mono">
                {setupData.backup_codes.map((code, i) => (
                  <span key={i}>{code}</span>
                ))}
              </div>
            </div>
            <form onSubmit={handleVerify} className="space-y-4">
              <div className="space-y-2">
                <Label htmlFor="verify-code">3. Enter verification code:</Label>
                <Input
                  id="verify-code"
                  type="text"
                  inputMode="numeric"
                  pattern="[0-9]*"
                  maxLength={6}
                  placeholder="000000"
                  value={code}
                  onChange={(e) => setCode(e.target.value)}
                  autoFocus
                  autoComplete="one-time-code"
                />
              </div>
              <Button type="submit" className="w-full" disabled={isLoading || code.length < 6}>
                {isLoading ? 'Verifying...' : 'Enable MFA'}
              </Button>
            </form>
          </div>
        )}
      </CardContent>
    </Card>
{{- else}}
    <Card>
      <StyledBody>
        <HeadingSmall>Set Up Two-Factor Authentication</HeadingSmall>
        {step === 'init' && (
          <div>
            <ParagraphSmall>
              Two-factor authentication adds an extra layer of security by requiring a code from your authenticator app.
            </ParagraphSmall>
            <Button onClick={handleSetup} overrides={{"{{" }} BaseButton: { style: { width: '100%' } } {{ "}}" }} isLoading={isLoading}>
              Start Setup
            </Button>
          </div>
        )}
        {step === 'verify' && setupData && (
          <div>
            <ParagraphSmall>1. Scan this QR code with your authenticator app:</ParagraphSmall>
            <div style={{"{{" }} display: 'flex', justifyContent: 'center', padding: '16px' {{ "}}" }}>
              <img src={setupData.qr_code} alt="MFA QR Code" style={{"{{" }} width: 192, height: 192 {{ "}}" }} />
            </div>
            <ParagraphSmall>Or enter this key manually: <code>{setupData.secret}</code></ParagraphSmall>
            <ParagraphSmall>2. Save your backup codes:</ParagraphSmall>
            <div style={{"{{" }} display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 4, padding: 12, background: '#f5f5f5', borderRadius: 4, fontFamily: 'monospace', fontSize: 12 {{ "}}" }}>
              {setupData.backup_codes.map((code, i) => (
                <span key={i}>{code}</span>
              ))}
            </div>
            <form onSubmit={handleVerify}>
              <FormControl label="3. Enter verification code:">
                <Input
                  type="text"
                  inputMode="numeric"
                  maxLength={6}
                  placeholder="000000"
                  value={code}
                  onChange={(e) => setCode(e.target.value)}
                  autoFocus
                  autoComplete="one-time-code"
                />
              </FormControl>
              <Button type="submit" overrides={{"{{" }} BaseButton: { style: { width: '100%' } } {{ "}}" }} isLoading={isLoading} disabled={code.length < 6}>
                Enable MFA
              </Button>
            </form>
          </div>
        )}
      </StyledBody>
    </Card>
{{- end}}
  )
}
{{- end}}
