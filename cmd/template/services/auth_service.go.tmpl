type OAuthService struct {
	DB          *db.Client
	VaultConfig *vault.VaultConfig
	SESClient   *ses.Client
	GoogleOAuth *oauth2.Config

	Logger *zap.SugaredLogger
	Tracer trace.Tracer
	Meter  metric.Meter

	// Metrics
	RequestCounter       metric.Int64Counter
	RequestDuration      metric.Float64Histogram
	ErrorCounter         metric.Int64Counter
	SignupCounter        metric.Int64Counter
	LoginCounter         metric.Int64Counter
	LogoutCounter        metric.Int64Counter
	EmailVerifications   metric.Int64Counter
	PasswordResetCounter metric.Int64Counter
	OTPVerificationCounter metric.Int64Counter
	PasswordChangeCounter metric.Int64Counter
	CleanupCounter       metric.Int64Counter
	ActiveSessions       metric.Int64UpDownCounter
}

