// ResponseWriter wrapper to capture status code
type responseWriter struct {
	http.ResponseWriter
	statusCode int
}

func (rw *responseWriter) WriteHeader(code int) {
	rw.statusCode = code
	rw.ResponseWriter.WriteHeader(code)
}

func NewOAuthService(db *db.Client, logger *zap.SugaredLogger, vaultConfig *vault.VaultConfig, tracer trace.Tracer, meter metric.Meter) (*OAuthService, error) {
	// Create AWS config with credentials from Vault
	awsConfig, err := awsconfig.LoadDefaultConfig(context.Background(),
		awsconfig.WithRegion(vaultConfig.AWSRegion),
		awsconfig.WithCredentialsProvider(aws.NewCredentialsCache(aws.CredentialsProviderFunc(func(ctx context.Context) (aws.Credentials, error) {
			return aws.Credentials{
				AccessKeyID:     vaultConfig.AWSAccessKeyID,
				SecretAccessKey: vaultConfig.AWSSecretAccessKey,
			}, nil
		}))),
	)
	if err != nil {
		return nil, err
	}

	sesClient := ses.NewFromConfig(awsConfig)

	// Initialize Google OAuth config
	googleOAuth := &oauth2.Config{
		ClientID:     vaultConfig.GoogleClientID,
		ClientSecret: vaultConfig.GoogleClientSecret,
		RedirectURL:  vaultConfig.GoogleRedirectURL,
		Scopes: []string{
			"https://www.googleapis.com/auth/userinfo.email",
			"https://www.googleapis.com/auth/userinfo.profile",
		},
		Endpoint: google.Endpoint,
	}

	// Initialize metrics
	requestCounter, err := meter.Int64Counter("auth_requests_total", metric.WithDescription("Total number of auth requests"))
	if err != nil {
		return nil, fmt.Errorf("failed to create request counter: %w", err)
	}

	requestDuration, err := meter.Float64Histogram("auth_request_duration_seconds", metric.WithDescription("Auth request duration in seconds"))
	if err != nil {
		return nil, fmt.Errorf("failed to create request duration histogram: %w", err)
	}

	errorCounter, err := meter.Int64Counter("auth_errors_total", metric.WithDescription("Total number of auth errors"))
	if err != nil {
		return nil, fmt.Errorf("failed to create error counter: %w", err)
	}

	signupCounter, err := meter.Int64Counter("auth_signups_total", metric.WithDescription("Total number of signups"))
	if err != nil {
		return nil, fmt.Errorf("failed to create signup counter: %w", err)
	}

	loginCounter, err := meter.Int64Counter("auth_logins_total", metric.WithDescription("Total number of logins"))
	if err != nil {
		return nil, fmt.Errorf("failed to create login counter: %w", err)
	}

	logoutCounter, err := meter.Int64Counter("auth_logouts_total", metric.WithDescription("Total number of logouts"))
	if err != nil {
		return nil, fmt.Errorf("failed to create logouts counter: %w", err)
	}

	emailVerifications, err := meter.Int64Counter("auth_email_verifications_total", metric.WithDescription("Total number of email verifications"))
	if err != nil {
		return nil, fmt.Errorf("failed to create email verification counter: %w", err)
	}

	passwordResetCounter, err := meter.Int64Counter("auth_password_resets_total", metric.WithDescription("Total number of password resets"))
	if err != nil {
		return nil, fmt.Errorf("failed to create password reset counter: %w", err)
	}

	activeSessions, err := meter.Int64UpDownCounter("auth_active_sessions", metric.WithDescription("Number of active sessions"))
	if err != nil {
		return nil, fmt.Errorf("failed to create active sessions counter: %w", err)
	}

	otpVerificationCounter, err := meter.Int64Counter("auth_otp_verifications_total", metric.WithDescription("Total number of OTP verifications"))
	if err != nil {
		return nil, fmt.Errorf("failed to create OTP verification counter: %w", err)
	}

	passwordChangeCounter, err := meter.Int64Counter("auth_password_changes_total", metric.WithDescription("Total number of password changes"))
	if err != nil {
		return nil, fmt.Errorf("failed to create password change counter: %w", err)
	}

	cleanupCounter, err := meter.Int64Counter("auth_cleanup_operations_total", metric.WithDescription("Total number of cleanup operations"))
	if err != nil {
		return nil, fmt.Errorf("failed to create cleanup counter: %w", err)
	}

	service := &OAuthService{
		DB:          db,
		Logger:      logger,
		GoogleOAuth: googleOAuth,
		SESClient:   sesClient,
		VaultConfig: vaultConfig,

		Tracer: tracer,
		Meter:  meter,

		RequestCounter:         requestCounter,
		RequestDuration:        requestDuration,
		ErrorCounter:           errorCounter,
		SignupCounter:          signupCounter,
		LoginCounter:           loginCounter,
		LogoutCounter:          logoutCounter,
		EmailVerifications:     emailVerifications,
		PasswordResetCounter:   passwordResetCounter,
		OTPVerificationCounter: otpVerificationCounter,
		PasswordChangeCounter:  passwordChangeCounter,
		CleanupCounter:         cleanupCounter,
		ActiveSessions:         activeSessions,
	}

	return service, nil
}

// ObservabilityMiddleware adds comprehensive observability
func (s *OAuthService) ObservabilityMiddleware(next http.Handler) http.Handler {
	return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		start := time.Now()

		// Extract trace context from request headers
		ctx := otel.GetTextMapPropagator().Extract(r.Context(), propagation.HeaderCarrier(r.Header))

		// Create trace span
		ctx, span := s.Tracer.Start(ctx, fmt.Sprintf("auth_%s_%s", r.Method, r.URL.Path))
		defer span.End()

		// Add span attributes
		span.SetAttributes(
			attribute.String("http.method", r.Method),
			attribute.String("http.url", r.URL.String()),
			attribute.String("http.remote_addr", r.RemoteAddr),
			attribute.String("http.user_agent", r.UserAgent()),
			attribute.String("service.name", "auth-service"),
		)

		// Wrap the ResponseWriter to capture status code
		wrapped := &responseWriter{ResponseWriter: w, statusCode: http.StatusOK}

		// Update request context with span context
		r = r.WithContext(ctx)

		next.ServeHTTP(wrapped, r)

		duration := time.Since(start)

		// Record metrics
		labels := []attribute.KeyValue{
			attribute.String("method", r.Method),
			attribute.String("endpoint", r.URL.Path),
			attribute.Int("status_code", wrapped.statusCode),
			attribute.String("service", "auth-service"),
		}

		s.RequestCounter.Add(ctx, 1, metric.WithAttributes(labels...))
		s.RequestDuration.Record(ctx, duration.Seconds(), metric.WithAttributes(labels...))

		if wrapped.statusCode >= 400 {
			s.ErrorCounter.Add(ctx, 1, metric.WithAttributes(labels...))
		}

		// Add status to span
		span.SetAttributes(attribute.Int("http.status_code", wrapped.statusCode))

		if wrapped.statusCode >= 400 {
			span.SetStatus(codes.Error, fmt.Sprintf("HTTP %d", wrapped.statusCode))
		} else {
			span.SetStatus(codes.Ok, "Request completed successfully")
		}

		// Log request
		s.Logger.Infow("auth request processed",
			"method", r.Method,
			"path", r.URL.Path,
			"status", wrapped.statusCode,
			"duration", duration.String(),
			"remote_addr", r.RemoteAddr,
			"user_agent", r.UserAgent(),
			"trace_id", span.SpanContext().TraceID().String(),
			"span_id", span.SpanContext().SpanID().String(),
		)
	})
}

func (s *OAuthService) RegisterHandlers(router *http.ServeMux) {
	// Health endpoints
	router.HandleFunc("GET /health", s.HealthCheck)
	router.HandleFunc("GET /ready", s.ReadinessCheck)
	
	// API endpoints
	router.HandleFunc("POST /api/"+s.VaultConfig.Version+"/signup", s.Signup)
	router.HandleFunc("POST /api/"+s.VaultConfig.Version+"/login", s.Login)
