// SendPasswordResetEmail sends a professional password reset email with OTP
func (s *OAuthService) SendPasswordResetEmail(userEmail, otp, resetToken string) error {
	ctx := context.Background()
	_, span := s.Tracer.Start(ctx, "password_reset_email_send")
	defer span.End()

	// Add span attributes
	span.SetAttributes(
		attribute.String("email.recipient", userEmail),
		attribute.String("email.type", "password_reset"),
		attribute.String("reset.token_prefix", resetToken[:8]+"..."),
	)

	// Create password reset URL - Frontend is always served over HTTPS via Kubernetes Ingress
	resetURL := fmt.Sprintf("https://%s:%s/reset-password?token=%s",
		s.VaultConfig.FrontendHost,
		s.VaultConfig.FrontendPort,
		resetToken)

	// Create professional password reset email template
	emailHTML := s.createProfessionalPasswordResetEmail(userEmail, otp, resetURL)

	// Send the email using AWS SES
	input := &ses.SendEmailInput{
		Source: aws.String("no-reply@plyer.org"),
		Destination: &awstypes.Destination{
			ToAddresses: []string{userEmail},
		},
		Message: &awstypes.Message{
			Subject: &awstypes.Content{
				Data: aws.String("Password Reset Request - Plyer"),
			},
			Body: &awstypes.Body{
				Html: &awstypes.Content{
					Data: aws.String(emailHTML),
				},
			},
		},
	}

	resp, err := s.SESClient.SendEmail(ctx, input)
	if err != nil {
		span.RecordError(err)
		span.SetStatus(codes.Error, "Failed to send password reset email")
		s.Logger.Errorw("Failed to send password reset email",
			"error", err,
			"email", userEmail)
		return fmt.Errorf("failed to send password reset email: %w", err)
	}

	// Add span attributes for successful sending
	span.SetAttributes(
		attribute.String("email.message_id", *resp.MessageId),
		attribute.String("email.status", "sent"),
	)
	span.SetStatus(codes.Ok, "Password reset email sent successfully")

	s.Logger.Infow("Password reset email sent successfully",
		"email", userEmail,
		"message_id", *resp.MessageId,
		"reset_url_length", len(resetURL))

	return nil
}

